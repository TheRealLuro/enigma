@using Enigma.Client.Models
@implements IAsyncDisposable
@inject IJSRuntime JS

<CascadingValue Value="Controller">
    <section class="archive-terminal @GetThemeClass()" @ref="_terminalRef">
        <ArchiveBackgroundFx />

        @if (!Controller.IsReady)
        {
            <div class="archive-terminal-loading" role="status" aria-live="polite">
                <span class="archive-terminal-loading-kicker">Enigma Research Archive</span>
                <strong>Syncing observer terminal...</strong>
            </div>
        }
        else
        {
            @if (Controller.ShowBootSequence || Controller.ShowReentryFlash)
            {
                <ArchiveBootSequence IsFullBoot="@Controller.ShowBootSequence"
                                     OnCompleted="@OnBootComplete" />
            }
            else
            {
                <ArchiveShell SectorImages="SectorImages"
                              IsSectorImagesLoading="IsSectorImagesLoading"
                              IsAuthenticatedUser="IsAuthenticatedUser"
                              OnSelectFile="OnSelectFile"
                              OnHoverFile="OnHoverFile"
                              OnFilterChanged="OnFilterChanged"
                              OnOpenFragment="OnOpenFragment"
                              OnToggleSidebar="OnToggleSidebar"
                              OnCloseSidebar="OnCloseSidebar" />
            }
        }

        @if (Controller.IsFragmentOpen && Controller.FragmentFile is not null)
        {
            <ArchiveFragmentModal File="Controller.FragmentFile"
                                  OnClose="OnCloseFragment" />
        }
    </section>
</CascadingValue>

@code {
    private ElementReference _terminalRef;

    [Parameter, EditorRequired]
    public required ArchiveTerminalController Controller { get; set; }

    [Parameter]
    public IReadOnlyList<LoreSectorImageRecord> SectorImages { get; set; } = [];

    [Parameter]
    public bool IsSectorImagesLoading { get; set; }

    [Parameter]
    public bool IsAuthenticatedUser { get; set; }

    [Parameter]
    public EventCallback OnBootComplete { get; set; }

    [Parameter]
    public EventCallback<string> OnSelectFile { get; set; }

    [Parameter]
    public EventCallback<string?> OnHoverFile { get; set; }

    [Parameter]
    public EventCallback<ArchiveDirectoryFilter> OnFilterChanged { get; set; }

    [Parameter]
    public EventCallback<string> OnOpenFragment { get; set; }

    [Parameter]
    public EventCallback OnCloseFragment { get; set; }

    [Parameter]
    public EventCallback OnToggleSidebar { get; set; }

    [Parameter]
    public EventCallback OnCloseSidebar { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("enigmaArchiveTerminal.registerAmbientGlow", _terminalRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("enigmaArchiveTerminal.disposeAmbientGlow");
        }
        catch
        {
        }
    }

    private string GetThemeClass()
    {
        return Controller.SelectedFile is null
            ? "theme-boot"
            : $"theme-{Controller.SelectedFile.Definition.VisualTheme}";
    }
}
