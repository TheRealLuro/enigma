@using System.Globalization

<div class="enigma-stepper @Class">
    <button type="button"
            class="enigma-stepper-button @(CanDecrease ? string.Empty : "is-disabled")"
            @onclick="DecreaseAsync"
            @onclick:stopPropagation="true"
            @onmousedown:preventDefault="true"
            @onmousedown:stopPropagation="true"
            aria-label="Decrease value">
        <span aria-hidden="true">-</span>
    </button>
    <input class="enigma-stepper-input"
           type="text"
           inputmode="numeric"
           value="@_draftValue"
           @oninput="HandleInputAsync"
           @onblur="CommitAsync"
           disabled="@Disabled" />
    <button type="button"
            class="enigma-stepper-button @(CanIncrease ? string.Empty : "is-disabled")"
            @onclick="IncreaseAsync"
            @onclick:stopPropagation="true"
            @onmousedown:preventDefault="true"
            @onmousedown:stopPropagation="true"
            aria-label="Increase value">
        <span aria-hidden="true">+</span>
    </button>
</div>

@code {
    [Parameter] public int Value { get; set; }
    [Parameter] public EventCallback<int> ValueChanged { get; set; }
    [Parameter] public int Min { get; set; } = int.MinValue;
    [Parameter] public int Max { get; set; } = int.MaxValue;
    [Parameter] public int Step { get; set; } = 1;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Class { get; set; } = string.Empty;

    private string _draftValue = string.Empty;
    private bool CanDecrease => !Disabled && Value > Min;
    private bool CanIncrease => !Disabled && Value < Max;

    protected override void OnParametersSet()
    {
        _draftValue = Value.ToString(CultureInfo.InvariantCulture);
    }

    private async Task HandleInputAsync(ChangeEventArgs args)
    {
        _draftValue = args.Value?.ToString() ?? string.Empty;
        if (int.TryParse(_draftValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed))
        {
            await SetValueAsync(parsed);
        }
    }

    private Task CommitAsync(FocusEventArgs _)
    {
        if (!int.TryParse(_draftValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed))
        {
            parsed = Value;
        }

        return SetValueAsync(parsed);
    }

    private Task IncreaseAsync()
    {
        if (!CanIncrease)
        {
            return Task.CompletedTask;
        }

        return SetValueAsync(Value + Math.Max(1, Step));
    }

    private Task DecreaseAsync()
    {
        if (!CanDecrease)
        {
            return Task.CompletedTask;
        }

        return SetValueAsync(Value - Math.Max(1, Step));
    }

    private async Task SetValueAsync(int nextValue)
    {
        nextValue = Math.Clamp(nextValue, Min, Max);
        _draftValue = nextValue.ToString(CultureInfo.InvariantCulture);

        if (nextValue == Value)
        {
            return;
        }

        Value = nextValue;
        await ValueChanged.InvokeAsync(nextValue);
    }
}
