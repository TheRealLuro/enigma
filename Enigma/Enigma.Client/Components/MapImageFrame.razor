<div class="@BuildClassName()">
    @if (!string.IsNullOrWhiteSpace(ImageUrl))
    {
        <img class="map-art-image" src="@ImageUrl" alt="@AltText" loading="lazy" />
    }
    else
    {
        <div class="map-art-placeholder">
            <span>@FallbackText</span>
        </div>
    }
</div>

@code {
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string AltText { get; set; } = "Map artwork";
    [Parameter] public string FallbackText { get; set; } = "Image pending";
    [Parameter] public string? Class { get; set; }

    private string BuildClassName()
    {
        return string.IsNullOrWhiteSpace(Class) ? "map-art-frame" : $"map-art-frame {Class}";
    }
}
