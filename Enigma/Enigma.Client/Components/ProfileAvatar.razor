@using System.Globalization
@using Enigma.Client.Models

<div class="profile-avatar-frame @Class">
    @if (ShouldRenderImage)
    {
        <div class="profile-avatar-crop-shell" style="@BuildCropShellStyle()">
            <img src="@Image!.ImageUrl"
                 alt="@AltText"
                 class="profile-avatar-image"
                 loading="eager"
                 @onerror="HandleImageError" />
        </div>
    }
    else
    {
        <span class="profile-avatar-fallback">@FallbackText</span>
    }

    @if (IsOnline.HasValue)
    {
        <span class="profile-avatar-presence @(IsOnline.Value ? "online" : "offline")"
              title="@(IsOnline.Value ? "Online" : "Offline")"
              aria-label="@(IsOnline.Value ? "Online" : "Offline")"></span>
    }
</div>

@code {
    [Parameter] public ProfileImageState? Image { get; set; }
    [Parameter] public string AltText { get; set; } = "Profile picture";
    [Parameter] public string FallbackText { get; set; } = "??";
    [Parameter] public string Class { get; set; } = string.Empty;
    [Parameter] public bool? IsOnline { get; set; }

    private bool _imageFailed;
    private string? _lastImageUrl;

    private bool ShouldRenderImage => !_imageFailed && !string.IsNullOrWhiteSpace(Image?.ImageUrl);

    protected override void OnParametersSet()
    {
        if (!string.Equals(_lastImageUrl, Image?.ImageUrl, StringComparison.Ordinal))
        {
            _lastImageUrl = Image?.ImageUrl;
            _imageFailed = false;
        }
    }

    private void HandleImageError()
    {
        _imageFailed = true;
    }

    private string BuildCropShellStyle()
    {
        var crop = Image?.Crop ?? new ImageCropState();
        var size = Math.Clamp(crop.Size, 1d, 100d);
        var maxOffset = Math.Max(0d, 100d - size);
        var x = Math.Clamp(crop.X, 0d, maxOffset);
        var y = Math.Clamp(crop.Y, 0d, maxOffset);
        var scale = 100d / size;
        var left = -(x / size) * 100d;
        var top = -(y / size) * 100d;
        var scaleText = scale.ToString("F4", CultureInfo.InvariantCulture);
        var leftText = left.ToString("F4", CultureInfo.InvariantCulture);
        var topText = top.ToString("F4", CultureInfo.InvariantCulture);

        return $"--avatar-scale:{scaleText};--avatar-left:{leftText}%;--avatar-top:{topText}%;";
    }
}
