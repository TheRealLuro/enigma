    private void HandleNotificationPublished(UiNotificationMessage notification)
    {
        _ = InvokeAsync(async () =>
        {
            _notifications.Insert(0, notification);
            if (_notifications.Count > 6)
            {
                var overflow = _notifications.Skip(6).ToList();
                _notifications.RemoveRange(6, _notifications.Count - 6);
                foreach (var extra in overflow)
                {
                    Notifications.Remove(extra.Id);
                }
            }

            StateHasChanged();

            try
            {
                await Task.Delay(notification.Duration);
            }
            catch
            {
            }

            Notifications.Remove(notification.Id);
            var removed = _notifications.RemoveAll(entry => string.Equals(entry.Id, notification.Id, StringComparison.Ordinal));
            if (removed > 0)
            {
                StateHasChanged();
            }
        });
    }

    private string GetNotificationCssClass(UiNotificationLevel level)
    {
        return level switch
        {
            UiNotificationLevel.Success => "success",
            UiNotificationLevel.Warning => "warning",
            UiNotificationLevel.Error => "error",
            _ => "info",
        };
    }

    private void NotifySessionDeltas(LoginUserSummary? previousSession, LoginUserSummary? latestSession)
    {
        if (latestSession is null || string.IsNullOrWhiteSpace(latestSession.Username))
        {
            _sessionDeltaInitialized = false;
            return;
        }

        if (!_sessionDeltaInitialized
            || previousSession is null
            || !string.Equals(previousSession.Username, latestSession.Username, StringComparison.OrdinalIgnoreCase))
        {
            _sessionDeltaInitialized = true;
            return;
        }

        var mazeNuggetDelta = latestSession.MazeNuggets - previousSession.MazeNuggets;
        if (mazeNuggetDelta > 0)
        {
            Notifications.Success($"Balance updated +{mazeNuggetDelta:N0} MN.");
        }
        else if (mazeNuggetDelta < 0)
        {
            Notifications.Info($"Balance updated {mazeNuggetDelta:N0} MN.");
        }

        var friendDelta = latestSession.Friends.Count - previousSession.Friends.Count;
        if (friendDelta > 0)
        {
            Notifications.Success(friendDelta == 1 ? "You have a new friend." : $"{friendDelta} new friends added.");
        }

        var stakedDelta = latestSession.StakedMapsCount - previousSession.StakedMapsCount;
        if (stakedDelta > 0)
        {
            Notifications.Info(stakedDelta == 1 ? "1 map was submitted for anomaly research." : $"{stakedDelta} maps were submitted for anomaly research.");
        }
        else if (stakedDelta < 0)
        {
            var unstakedCount = Math.Abs(stakedDelta);
            Notifications.Info(unstakedCount == 1 ? "1 map was withdrawn from anomaly research." : $"{unstakedCount} maps were withdrawn from anomaly research.");
        }
    }

    private async Task CheckGovernanceStateAsync(CancellationToken cancellationToken)
    {
        if (cancellationToken.IsCancellationRequested || IsPublicPath() || !IsAuthenticated)
        {
            return;
        }

        try
        {
            var payload = await Api.GetFromJsonAsync<GovernanceSessionResponse>("api/auth/voting/session", cancellationToken);
            if (payload is null)
            {
                return;
            }

            var activeSessionId = (payload.ActiveSession?.SessionId ?? string.Empty).Trim();
            var hasActiveSession = !string.IsNullOrWhiteSpace(activeSessionId);
            if (!_governanceTrackingInitialized)
            {
                _governanceTrackingInitialized = true;
                _knownGovernanceVotingOpen = hasActiveSession;
                _knownGovernanceSessionId = activeSessionId;
                return;
            }

            if (_knownGovernanceVotingOpen && !hasActiveSession)
            {
                Notifications.Info("Council voting has ended.");
            }
            else if (!_knownGovernanceVotingOpen && hasActiveSession)
            {
                var sessionTitle = string.IsNullOrWhiteSpace(payload.ActiveSession?.Title)
                    ? "New council session"
                    : payload.ActiveSession!.Title;
                Notifications.Info($"Council voting is open: {sessionTitle}");
            }
            else if (hasActiveSession && !string.Equals(_knownGovernanceSessionId, activeSessionId, StringComparison.OrdinalIgnoreCase))
            {
                var sessionTitle = string.IsNullOrWhiteSpace(payload.ActiveSession?.Title)
                    ? "A new council session"
                    : payload.ActiveSession!.Title;
                Notifications.Info($"Council session changed: {sessionTitle}");
            }

            _knownGovernanceVotingOpen = hasActiveSession;
            _knownGovernanceSessionId = activeSessionId;
        }
        catch
        {
            // Ignore transient polling failures.
        }
    }

    private void ResetRealtimeTracking()
    {
        CancelPendingTutorialRouteCompletion();
        _sessionDeltaInitialized = false;
        _governanceTrackingInitialized = false;
        _knownGovernanceVotingOpen = false;
        _knownGovernanceSessionId = string.Empty;
        _governanceRefreshTick = 0;
        _friendRequestsInitialized = false;
        _knownFriendRequests = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        _invitesInitialized = false;
        _knownInviteSessionIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        _completedTutorialStepIndexes.Clear();
        _announcedTutorialStepIndexes.Clear();
        _notifications.Clear();
    }

