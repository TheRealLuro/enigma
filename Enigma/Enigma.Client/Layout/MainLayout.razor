@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject Enigma.Client.Services.EnigmaApiClient Api
@implements IAsyncDisposable
@using Enigma.Client.Models
@using Enigma.Client.Models.Gameplay
@using Microsoft.JSInterop

<div class="page">
    @if (ShouldShowHeader)
    {
        <header class="app-header app-shell-header">
            <div class="app-shell-brand">
                <div class="app-shell-brand-copy">
                    <button class="app-brand-button" @onclick="GoHome">Enigma</button>
                    <span class="app-shell-brand-tag">Question Everything</span>
                </div>
            </div>

            <nav class="app-shell-nav">
                <NavLink class="nav-link" href="/home">Home</NavLink>
                <NavLink class="nav-link" href="/play">Play</NavLink>
                <NavLink class="nav-link" href="/leaderboard">Leaderboard</NavLink>
                <NavLink class="nav-link" href="/players">Players</NavLink>
                <NavLink class="nav-link" href="/profile">Profile</NavLink>
                <NavLink class="nav-link" href="/marketplace">Marketplace</NavLink>
            </nav>

            <div class="app-shell-account">
                @if (ShouldShowHeaderBalance)
                {
                    <div class="app-shell-balance-chip">
                        <span>Maze Nuggets</span>
                        <strong>@Session!.MazeNuggets.ToString("N0") MN</strong>
                    </div>
                }

                <button class="app-shell-user-chip" @onclick="ToggleAccountMenu">
                    <span class="app-shell-user-kicker">Signed in</span>
                    <strong>@(Session?.Username ?? "Explorer")</strong>
                </button>

                @if (IsAccountMenuOpen)
                {
                    <div class="app-shell-account-menu">
                        <button class="app-shell-account-link" @onclick="GoProfile">View Profile</button>
                        <button class="app-shell-account-link" @onclick="GoToSettings">Settings</button>
                        <button class="app-shell-account-link danger" @onclick="LogoutAsync">Sign Out</button>
                    </div>
                }
            </div>
        </header>
    }

    <main>
        @if (CanRenderCurrentRoute)
        {
            <article class="content px-4 app-shell-content">
                @Body
            </article>
        }
        else
        {
            <div class="content app-shell-content">
                <div class="card enigma-game-message">
                    <div class="loader"></div>
                    <p>Checking session...</p>
                </div>
            </div>
        }
    </main>
</div>

@if (TutorialVisible && CurrentTutorialStep is not null)
{
    <div class="enigma-modal-backdrop tutorial-backdrop @(IsGamePath() ? "tutorial-backdrop-game" : string.Empty)">
        <div class="enigma-modal-card tutorial-modal-card">
            <span class="profile-kicker">@CurrentTutorialStep.Eyebrow</span>
            <h2>@CurrentTutorialStep.Title</h2>
            <p>@CurrentTutorialStep.Description</p>
            @if (!string.IsNullOrWhiteSpace(CurrentTutorialStep.HelperText))
            {
                <p class="tutorial-helper-copy">@CurrentTutorialStep.HelperText</p>
            }
            @if (_tutorialIndex == _tutorialSteps.Count - 1)
            {
                <p class="tutorial-helper-copy">Inactive for 60 consecutive days means permanent deletion of this account and all owned maps.</p>
            }
            <div class="tutorial-progress-row">
                <span>Step @(_tutorialIndex + 1) of @_tutorialSteps.Count</span>
                <span>@GetTutorialRouteLabel()</span>
            </div>
            <div class="enigma-end-actions tutorial-action-row">
                <button class="btn btn-secondary" type="button" @onclick="SkipTutorialAsync">Skip</button>
                <button class="btn btn-secondary" type="button" disabled="@(_tutorialIndex == 0)" @onclick="GoToPreviousTutorialStepAsync">Previous</button>
                <button class="btn btn-primary" type="button" @onclick="GoToNextTutorialStepAsync">@(_tutorialIndex == _tutorialSteps.Count - 1 ? "Finish" : "Next")</button>
            </div>
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    private static readonly HashSet<string> PublicPaths = new(StringComparer.OrdinalIgnoreCase)
    {
        "",
        "register",
        "about",
        "how-enigma-works",
        "enigma-game-mechanics",
        "enigma-multiplayer",
    };
    private const string TutorialDemoSeed = "easy-0,0BrS-1,0JqR-2,0HrF";

    private LoginUserSummary? Session { get; set; }
    private bool AuthCheckComplete { get; set; }
    private bool IsAuthenticated { get; set; }
    private bool IsAccountMenuOpen { get; set; }
    private bool TutorialVisible { get; set; }
    private bool _tutorialSeenRecorded;
    private int _tutorialIndex;
    private bool _tutorialListenerRegistered;
    private DotNetObjectReference<MainLayout>? _tutorialListenerRef;

    private readonly List<TutorialStepDefinition> _tutorialSteps =
    [
        new()
        {
            Eyebrow = "Home",
            Title = "Home",
            Description = "Home is the main hub. From here you jump into Play, Leaderboard, Players, Profile, and Marketplace without hunting through nested menus.",
            HelperText = "Use the header for fast navigation on normal pages. The home cards are the quick launch version of the same major sections.",
            Path = "/home"
        },
        new()
        {
            Eyebrow = "Play",
            Title = "Start a Discovery",
            Description = "Play is where single-player runs start. Generate a new maze, load a saved one, choose your run items, and then enter the maze.",
            HelperText = "The fullscreen choice is remembered. If you lock in fullscreen and choose not to be asked again, future runs try that mode on the next start click.",
            Path = "/play"
        },
        new()
        {
            Eyebrow = "Co-op",
            Title = "Dual Expedition",
            Description = "Co-op is the shared session lobby. Create a run, invite exactly one friend, wait for both players to ready up, then enter together.",
            HelperText = "This page is only for session setup. If a new co-op maze is saved after completion, the host becomes the owner and both explorers receive discovery credit.",
            Path = "/play/coop"
        },
        new()
        {
            Eyebrow = "Game",
            Title = "Maze Run",
            Description = "This safe demo shows the live maze layout. Move through rooms, watch the in-room HUD, walk to the console, and press E to open puzzle overlays.",
            HelperText = "Some puzzles are console-based and some resolve directly on the stage. Real runs are permanent if you leave them; this tutorial demo is exempt so you can revisit it safely.",
            Path = "/game"
        },
        new()
        {
            Eyebrow = "Leaderboard",
            Title = "Top Maps and Players",
            Description = "Leaderboard switches between ranked maps and ranked players. It now loads in rank sections instead of trying to dump the whole board at once.",
            HelperText = "Map mode tracks records, ratings, founders, and plays. Player mode tracks discoverers, owned maps, Maze Nuggets, wins, losses, and overall performance.",
            Path = "/leaderboard"
        },
        new()
        {
            Eyebrow = "Marketplace",
            Title = "Marketplace",
            Description = "Marketplace is split into Map Shop and Item Shop. Use Map Shop to list or buy maps, and use Item Shop to stock your run inventory.",
            HelperText = "Map sales transfer ownership. Item purchases go straight into inventory and are equipped later from Play before a run starts.",
            Path = "/marketplace"
        },
        new()
        {
            Eyebrow = "Players",
            Title = "Find Players",
            Description = "Players is the live explorer search page. Search usernames, jump straight into exact profiles, and review the featured top discoverers.",
            HelperText = "Results update as you type. The featured explorers here are the current top three by discovered maps, not just a generic popularity list.",
            Path = "/players"
        },
        new()
        {
            Eyebrow = "Profile",
            Title = "Explorer Ledger",
            Description = "Profile holds your overview, map collection, inventory, and social state. When you view another explorer, only the public sections stay visible.",
            HelperText = "Owned maps, discovered maps, run stats, and relationship state all live here. This is also where you check whether a map is owned or only discovered.",
            Path = "/profile"
        },
        new()
        {
            Eyebrow = "Settings",
            Title = "Profile Settings",
            Description = "Settings hold your account controls: update email, change password, save a profile picture, replay the tutorial, and manage account deletion.",
            HelperText = "Profile pictures come from owned map art and use the default crop automatically. There is no manual crop workflow in the current app.",
            Path = "/profile?tab=settings"
        },
        new()
        {
            Eyebrow = "Retention",
            Title = "60-Day Inactivity Rule",
            Description = "If the account is inactive for 60 consecutive days, the account and all owned maps are deleted permanently.",
            HelperText = "This rule matters because ownership and discovery are separate. Losing the account removes your owned maps, so keep the inactivity window in mind.",
            Path = "/profile?tab=settings&tutorialstep=policy"
        },
    ];

    private TutorialStepDefinition? CurrentTutorialStep =>
        _tutorialIndex >= 0 && _tutorialIndex < _tutorialSteps.Count
            ? _tutorialSteps[_tutorialIndex]
            : null;

    private bool ShouldShowHeader => !IsPublicPath() && !IsGamePath() && AuthCheckComplete && IsAuthenticated;
    private bool ShouldShowHeaderBalance => ShouldShowHeader && Session is not null;

    private bool CanRenderCurrentRoute => IsPublicPath() || (AuthCheckComplete && IsAuthenticated);

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
        ResetAuthStateForCurrentPath();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_tutorialListenerRegistered)
        {
            _tutorialListenerRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("enigmaGame.registerTutorialListener", _tutorialListenerRef);
            _tutorialListenerRegistered = true;
        }

        if (IsPublicPath())
        {
            return;
        }

        if (AuthCheckComplete && IsAuthenticated && Session is not null)
        {
            return;
        }

        try
        {
            var session = await Api.GetSessionAsync();
            if (!string.Equals(Session?.Username, session?.Username, StringComparison.OrdinalIgnoreCase))
            {
                _tutorialSeenRecorded = false;
            }
            AuthCheckComplete = true;
            IsAuthenticated = session is not null && !string.IsNullOrWhiteSpace(session.Username);
            Session = session;

            if (!IsAuthenticated)
            {
                await ClearBrowserSessionAsync();
                NavigationManager.NavigateTo("/", replace: true);
                return;
            }

            var pendingLoss = await JS.InvokeAsync<PendingLossSummary?>("enigmaGame.getPendingLossSummary");
            if (pendingLoss is not null && !IsLosePath())
            {
                NavigationManager.NavigateTo("/lose", replace: true);
                return;
            }

            await JS.InvokeVoidAsync("enigmaGame.refreshUserSession", session);
            var rememberSession = await GetRememberedSessionStateAsync();
            await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new Enigma.Client.Models.Gameplay.PlayerIdentity { Username = session!.Username }, rememberSession);
            await EnsureTutorialStateAsync(session);
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            AuthCheckComplete = true;
            IsAuthenticated = false;
            Session = null;
            await ClearBrowserSessionAsync();
            NavigationManager.NavigateTo("/", replace: true);
        }
    }

    private void GoHome()
    {
        IsAccountMenuOpen = false;
        NavigationManager.NavigateTo("/home");
    }

    private void GoProfile()
    {
        if (string.IsNullOrWhiteSpace(Session?.Username))
        {
            return;
        }

        IsAccountMenuOpen = false;
        NavigationManager.NavigateTo($"/profile/{Uri.EscapeDataString(Session.Username)}");
    }

    private void GoToSettings()
    {
        IsAccountMenuOpen = false;
        NavigationManager.NavigateTo("/profile?tab=settings");
    }

    private void ToggleAccountMenu()
    {
        IsAccountMenuOpen = !IsAccountMenuOpen;
    }

    private async Task LogoutAsync()
    {
        IsAccountMenuOpen = false;
        try
        {
            await Api.LogoutAsync();
        }
        catch
        {
        }

        await ClearBrowserSessionAsync();
        Session = null;
        AuthCheckComplete = true;
        IsAuthenticated = false;
        TutorialVisible = false;
        _tutorialSeenRecorded = false;
        NavigationManager.NavigateTo("/", replace: true);
    }

    private async Task ClearBrowserSessionAsync()
    {
        await JS.InvokeVoidAsync("enigmaGame.clearPlayerIdentity");
        await JS.InvokeVoidAsync("enigmaGame.clearUserSession");
        await JS.InvokeVoidAsync("enigmaGame.clearActiveGameSession");
        await JS.InvokeVoidAsync("enigmaGame.clearLivePlayerState");
        await JS.InvokeVoidAsync("enigmaGame.clearPendingLossSummary");
        await JS.InvokeVoidAsync("enigmaGame.clearRunLoadout");
        await JS.InvokeVoidAsync("enigmaGame.consumeTutorialRequest");
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        IsAccountMenuOpen = false;
        UpdateTutorialIndexFromUri(args.Location);
        ResetAuthStateForCurrentPath(args.Location);
        _ = InvokeAsync(StateHasChanged);
    }

    private void ResetAuthStateForCurrentPath(string? uri = null)
    {
        if (IsPublicPath(uri))
        {
            AuthCheckComplete = true;
            IsAuthenticated = true;
            Session = null;
            TutorialVisible = false;
            return;
        }

        if (Session is not null && IsAuthenticated)
        {
            AuthCheckComplete = true;
            return;
        }

        AuthCheckComplete = false;
        IsAuthenticated = false;
    }

    private bool IsGamePath(string? uri = null)
    {
        var cleanPath = GetCleanPath(uri ?? NavigationManager.Uri);
        return string.Equals(cleanPath, "game", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsLosePath(string? uri = null)
    {
        var cleanPath = GetCleanPath(uri ?? NavigationManager.Uri);
        return string.Equals(cleanPath, "lose", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsPublicPath(string? uri = null)
    {
        var cleanPath = GetCleanPath(uri ?? NavigationManager.Uri);
        return PublicPaths.Contains(cleanPath);
    }

    private static string GetCleanPath(string uri)
    {
        var relativePath = new Uri(uri, UriKind.Absolute).AbsolutePath.Trim('/');
        return relativePath.ToLowerInvariant();
    }

    private async Task EnsureTutorialStateAsync(LoginUserSummary session)
    {
        if (session.IsSystemAccount || IsPublicPath() || IsLosePath())
        {
            return;
        }

        var requested = await JS.InvokeAsync<bool>("enigmaGame.consumeTutorialRequest");
        var shouldAutoStart = requested || string.IsNullOrWhiteSpace(session.TutorialState.SeenAt);
        if (!shouldAutoStart)
        {
            return;
        }

        if (!_tutorialSeenRecorded)
        {
            _tutorialSeenRecorded = true;
            try
            {
                using var response = await Api.PostJsonAsync("api/auth/account/tutorial", new { action = "seen" });
                if (response.IsSuccessStatusCode)
                {
                    var payload = await Api.ReadJsonAsync<LoginResponse>(response);
                    if (payload?.User is not null)
                    {
                        Session = payload.User;
                        await JS.InvokeVoidAsync("enigmaGame.refreshUserSession", payload.User);
                    }
                }
            }
            catch
            {
            }
        }

        TutorialVisible = true;
        UpdateTutorialIndexFromUri(NavigationManager.Uri);
    }

    [JSInvokable]
    public async Task HandleTutorialRequestedAsync()
    {
        if (IsPublicPath() || !IsAuthenticated)
        {
            return;
        }

        await JS.InvokeAsync<bool>("enigmaGame.consumeTutorialRequest");
        TutorialVisible = true;
        _tutorialIndex = 0;

        if (!string.Equals(GetCleanPath(NavigationManager.Uri), "home", StringComparison.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo(_tutorialSteps[0].Path, replace: true);
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void UpdateTutorialIndexFromUri(string uri)
    {
        if (!TutorialVisible)
        {
            return;
        }

        _tutorialIndex = GetTutorialIndexForUri(uri);
    }

    private int GetTutorialIndexForUri(string uri)
    {
        var current = new Uri(uri, UriKind.Absolute);
        var path = current.AbsolutePath.Trim('/').ToLowerInvariant();
        var query = current.Query.ToLowerInvariant();

        if (path == "play/coop")
        {
            return 2;
        }

        if (path == "play")
        {
            return 1;
        }

        if (path == "game" && (query.Contains("tutorial=1", StringComparison.Ordinal) || query.Contains("tutorial=true", StringComparison.Ordinal)))
        {
            return 3;
        }

        if (path == "leaderboard")
        {
            return 4;
        }

        if (path == "marketplace")
        {
            return 5;
        }

        if (path == "players")
        {
            return 6;
        }

        if (path == "profile" && query.Contains("tutorialstep=policy", StringComparison.Ordinal))
        {
            return 9;
        }

        if (path == "profile" && query.Contains("tab=settings", StringComparison.Ordinal))
        {
            return 8;
        }

        if (path == "profile")
        {
            return 7;
        }

        return 0;
    }

    private string GetTutorialRouteLabel()
    {
        var step = CurrentTutorialStep;
        if (step is null)
        {
            return string.Empty;
        }

        return step.Eyebrow;
    }

    private async Task GoToPreviousTutorialStepAsync()
    {
        if (_tutorialIndex <= 0)
        {
            return;
        }

        _tutorialIndex--;
        await NavigateToTutorialStepAsync(_tutorialIndex);
    }

    private async Task GoToNextTutorialStepAsync()
    {
        if (_tutorialIndex >= _tutorialSteps.Count - 1)
        {
            await CompleteTutorialAsync();
            return;
        }

        _tutorialIndex++;
        await NavigateToTutorialStepAsync(_tutorialIndex);
    }

    private Task NavigateToTutorialStepAsync(int index)
    {
        if (index < 0 || index >= _tutorialSteps.Count)
        {
            return Task.CompletedTask;
        }

        var step = _tutorialSteps[index];
        if (string.Equals(GetCleanPath(new Uri(new Uri(NavigationManager.BaseUri), step.Path).AbsoluteUri), "game", StringComparison.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo($"/game?seed={Uri.EscapeDataString(TutorialDemoSeed)}&source=new&tutorial=true", replace: true);
            return Task.CompletedTask;
        }

        NavigationManager.NavigateTo(step.Path, replace: true);
        return Task.CompletedTask;
    }

    private async Task SkipTutorialAsync()
    {
        TutorialVisible = false;
        await JS.InvokeAsync<bool>("enigmaGame.consumeTutorialRequest");
        try
        {
            await Api.PostJsonAsync("api/auth/account/tutorial", new { action = "skipped" });
        }
        catch
        {
        }
    }

    private async Task CompleteTutorialAsync()
    {
        TutorialVisible = false;
        await JS.InvokeAsync<bool>("enigmaGame.consumeTutorialRequest");
        try
        {
            await Api.PostJsonAsync("api/auth/account/tutorial", new { action = "completed" });
        }
        catch
        {
        }

        NavigationManager.NavigateTo("/home", replace: true);
    }

    private async Task<bool> GetRememberedSessionStateAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("enigmaGame.isUserSessionRemembered");
        }
        catch (JSException)
        {
            return false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;

        if (_tutorialListenerRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("enigmaGame.disposeTutorialListener");
            }
            catch
            {
            }
        }

        _tutorialListenerRef?.Dispose();
    }
}
