    private TutorialStepDefinition? CurrentTutorialStep =>
        _tutorialIndex >= 0 && _tutorialIndex < _tutorialSteps.Count
            ? _tutorialSteps[_tutorialIndex]
            : null;
    private bool IsCurrentTutorialStepComplete => _completedTutorialStepIndexes.Contains(_tutorialIndex);
    private bool CanAdvanceTutorialStep => _tutorialSteps.Count > 0;
    private int CompletedTutorialStepCount => _completedTutorialStepIndexes.Count;

    private bool ShouldShowHeader => !IsPublicPath() && !IsGamePath() && AuthCheckComplete && IsAuthenticated;
    private bool ShouldShowHeaderBalance => ShouldShowHeader && Session is not null;

    private bool CanRenderCurrentRoute => IsPublicPath() || (AuthCheckComplete && IsAuthenticated);

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
        Notifications.NotificationPublished += HandleNotificationPublished;
        ResetAuthStateForCurrentPath();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_tutorialListenerRegistered)
        {
            _tutorialListenerRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("enigmaGame.registerTutorialListener", _tutorialListenerRef);
            _tutorialListenerRegistered = true;
        }

        if (firstRender && !_userSessionListenerRegistered)
        {
            _userSessionListenerRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("enigmaGame.registerUserSessionListener", _userSessionListenerRef);
            _userSessionListenerRegistered = true;
        }

        if (IsPublicPath())
        {
            return;
        }

        if (AuthCheckComplete && IsAuthenticated && Session is not null)
        {
            return;
        }

        try
        {
            var previousSession = Session;
            var session = await Api.GetSessionAsync(lightweight: true);
            if (!string.Equals(Session?.Username, session?.Username, StringComparison.OrdinalIgnoreCase))
            {
                _tutorialSeenRecorded = false;
            }
            AuthCheckComplete = true;
            IsAuthenticated = session is not null && !string.IsNullOrWhiteSpace(session.Username);
            Session = session;
            UpdateFriendRequestTracking(session);
            UpdateInviteTracking(session);
            NotifySessionDeltas(previousSession, session);

            if (!IsAuthenticated)
            {
                StopGlobalSessionRefreshLoop();
                ResetRealtimeTracking();
                await ClearBrowserSessionAsync();
                NavigationManager.NavigateTo("/", replace: true);
                return;
            }

            var pendingLoss = await JS.InvokeAsync<PendingLossSummary?>("enigmaGame.getPendingLossSummary");
            if (pendingLoss is not null && !IsLosePath())
            {
                NavigationManager.NavigateTo("/lose", replace: true);
                return;
            }

            await JS.InvokeVoidAsync("enigmaGame.refreshUserSession", session);
            var rememberSession = await GetRememberedSessionStateAsync();
            await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new Enigma.Client.Models.Gameplay.PlayerIdentity { Username = session!.Username }, rememberSession);
            await EnsureTutorialStateAsync(session);
            EnsureGlobalSessionRefreshLoop();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            AuthCheckComplete = true;
            IsAuthenticated = false;
            Session = null;
            StopGlobalSessionRefreshLoop();
            ResetRealtimeTracking();
            await ClearBrowserSessionAsync();
            NavigationManager.NavigateTo("/", replace: true);
        }
    }

    private void GoHome()
    {
        IsAccountMenuOpen = false;
        NavigationManager.NavigateTo("/home");
    }

    private void GoProfile()
    {
        if (string.IsNullOrWhiteSpace(Session?.Username))
        {
            return;
        }

        IsAccountMenuOpen = false;
        NavigationManager.NavigateTo($"/profile/{Uri.EscapeDataString(Session.Username)}");
    }

    private void GoToSettings()
    {
        IsAccountMenuOpen = false;
        NavigationManager.NavigateTo("/profile?tab=settings");
    }

    private void ToggleAccountMenu()
    {
        IsAccountMenuOpen = !IsAccountMenuOpen;
    }

    private async Task LogoutAsync()
    {
        IsAccountMenuOpen = false;
        StopGlobalSessionRefreshLoop();
        ResetRealtimeTracking();
        try
        {
            await Api.LogoutAsync();
        }
        catch
        {
        }

        await ClearBrowserSessionAsync();
        Session = null;
        AuthCheckComplete = true;
        IsAuthenticated = false;
        TutorialVisible = false;
        _tutorialSeenRecorded = false;
        NavigationManager.NavigateTo("/", replace: true);
    }

    private async Task ClearBrowserSessionAsync()
    {
        await JS.InvokeVoidAsync("enigmaGame.clearPlayerIdentity");
        await JS.InvokeVoidAsync("enigmaGame.clearUserSession");
        await JS.InvokeVoidAsync("enigmaGame.clearActiveGameSession");
        await JS.InvokeVoidAsync("enigmaGame.clearLivePlayerState");
        await JS.InvokeVoidAsync("enigmaGame.clearPendingLossSummary");
        await JS.InvokeVoidAsync("enigmaGame.clearRunLoadout");
        await JS.InvokeVoidAsync("enigmaGame.consumeTutorialRequest");
        await JS.InvokeVoidAsync("enigmaGame.clearTutorialJourneyState");
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        IsAccountMenuOpen = false;
        if (TutorialVisible)
        {
            UpdateTutorialIndexFromUri(args.Location);
            QueueTutorialRouteCompletion(args.Location, announce: true);
            _ = PersistTutorialJourneyStateAsync();
        }
        ResetAuthStateForCurrentPath(args.Location);
        if (IsPublicPath(args.Location) || !IsAuthenticated)
        {
            StopGlobalSessionRefreshLoop();
        }
        else
        {
            EnsureGlobalSessionRefreshLoop();
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private void ResetAuthStateForCurrentPath(string? uri = null)
    {
        if (IsPublicPath(uri))
        {
            AuthCheckComplete = true;
            IsAuthenticated = true;
            Session = null;
            TutorialVisible = false;
            return;
        }

        if (Session is not null && IsAuthenticated)
        {
            AuthCheckComplete = true;
            return;
        }

        AuthCheckComplete = false;
        IsAuthenticated = false;
    }

    private bool IsGamePath(string? uri = null)
    {
        var cleanPath = GetCleanPath(uri ?? NavigationManager.Uri);
        return string.Equals(cleanPath, "game", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsLosePath(string? uri = null)
    {
        var cleanPath = GetCleanPath(uri ?? NavigationManager.Uri);
        return string.Equals(cleanPath, "lose", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsPublicPath(string? uri = null)
    {
        var cleanPath = GetCleanPath(uri ?? NavigationManager.Uri);
        return PublicPaths.Contains(cleanPath);
    }

    private static string GetCleanPath(string uri)
    {
        var (path, _) = SplitPathAndQuery(uri);
        return path;
    }

    private async Task EnsureTutorialStateAsync(LoginUserSummary session)
    {
        if (session.IsSystemAccount || IsPublicPath() || IsLosePath())
        {
            return;
        }

        var requested = await JS.InvokeAsync<bool>("enigmaGame.consumeTutorialRequest");
        if (requested)
        {
            StartTutorialJourney(resetProgress: true);
            return;
        }

        if (await RestoreTutorialJourneyStateAsync(session))
        {
            return;
        }

        var shouldAutoStart = string.IsNullOrWhiteSpace(session.TutorialState.SeenAt);
        if (!shouldAutoStart)
        {
            return;
        }

        if (!_tutorialSeenRecorded)
        {
            _tutorialSeenRecorded = true;
            try
            {
                using var response = await Api.PostJsonAsync("api/auth/account/tutorial", new { action = "seen" });
                if (response.IsSuccessStatusCode)
                {
                    var payload = await Api.ReadJsonAsync<LoginResponse>(response);
                    if (payload?.User is not null)
                    {
                        Session = payload.User;
                        await JS.InvokeVoidAsync("enigmaGame.refreshUserSession", payload.User);
                    }
                }
            }
            catch
            {
            }
        }

        StartTutorialJourney(resetProgress: true);
    }

    [JSInvokable]
    public async Task HandleTutorialRequestedAsync()
    {
        if (IsPublicPath() || !IsAuthenticated)
        {
            return;
        }

        await JS.InvokeAsync<bool>("enigmaGame.consumeTutorialRequest");
        StartTutorialJourney(resetProgress: true);

        if (!string.Equals(GetCleanPath(NavigationManager.Uri), "home", StringComparison.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo(_tutorialSteps[0].Path, replace: true);
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task HandleUserSessionUpdatedAsync()
    {
        if (_handlingUserSessionUpdate || IsPublicPath())
        {
            return;
        }

        _handlingUserSessionUpdate = true;
        try
        {
            var previousSession = Session;
            var session = await Api.GetSessionAsync();
            AuthCheckComplete = true;
            IsAuthenticated = session is not null && !string.IsNullOrWhiteSpace(session.Username);
            Session = session;
            UpdateFriendRequestTracking(session);
            UpdateInviteTracking(session);
            NotifySessionDeltas(previousSession, session);

            if (!IsAuthenticated)
            {
                StopGlobalSessionRefreshLoop();
                ResetRealtimeTracking();
                await ClearBrowserSessionAsync();
                NavigationManager.NavigateTo("/", replace: true);
                return;
            }

            EnsureGlobalSessionRefreshLoop();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
        finally
        {
            _handlingUserSessionUpdate = false;
        }
    }

    private void UpdateTutorialIndexFromUri(string uri)
    {
        if (!TutorialVisible)
        {
            return;
        }

        var nextIndex = GetTutorialIndexForUri(uri);
        if (nextIndex >= 0)
        {
            _tutorialIndex = nextIndex;
        }
    }

    private int GetTutorialIndexForUri(string uri)
    {
        var bestIndex = -1;
        var bestScore = -1;
        for (var index = 0; index < _tutorialSteps.Count; index++)
        {
            var score = GetTutorialStepMatchScore(_tutorialSteps[index], uri);
            if (score > bestScore)
            {
                bestScore = score;
                bestIndex = index;
            }
        }

        return bestIndex;
    }

    private static (string Path, string Query) SplitPathAndQuery(string? uri)
    {
        var raw = (uri ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(raw))
        {
            return (string.Empty, string.Empty);
        }

        var withoutFragment = raw;
        var fragmentIndex = withoutFragment.IndexOf('#');
        if (fragmentIndex >= 0)
        {
            withoutFragment = withoutFragment[..fragmentIndex];
        }

        var query = string.Empty;
        var pathPortion = withoutFragment;
        var queryIndex = withoutFragment.IndexOf('?');
        if (queryIndex >= 0)
        {
            query = withoutFragment[queryIndex..].ToLowerInvariant();
            pathPortion = withoutFragment[..queryIndex];
        }

        var path = pathPortion;
        var schemeIndex = path.IndexOf("://", StringComparison.Ordinal);
        if (schemeIndex >= 0)
        {
            var firstSlashAfterHost = path.IndexOf('/', schemeIndex + 3);
            path = firstSlashAfterHost >= 0 ? path[firstSlashAfterHost..] : "/";
        }

        path = path.Trim('/').ToLowerInvariant();
        return (path, query);
    }

    private void StartTutorialJourney(bool resetProgress)
    {
        if (resetProgress)
        {
            ResetTutorialJourneyProgress();
        }

        TutorialVisible = true;
        var matchedIndex = GetTutorialIndexForUri(NavigationManager.Uri);
        if (matchedIndex >= 0)
        {
            _tutorialIndex = matchedIndex;
        }
        else
        {
            _tutorialIndex = GetFirstIncompleteTutorialStepIndex();
        }

        QueueTutorialRouteCompletion(NavigationManager.Uri, announce: false);
        _ = PersistTutorialJourneyStateAsync();
    }

    private void ResetTutorialJourneyProgress()
    {
        CancelPendingTutorialRouteCompletion();
        _completedTutorialStepIndexes.Clear();
        _announcedTutorialStepIndexes.Clear();
        _tutorialIndex = 0;
    }

    private int GetFirstIncompleteTutorialStepIndex()
    {
        for (var index = 0; index < _tutorialSteps.Count; index++)
        {
            if (!_completedTutorialStepIndexes.Contains(index))
            {
                return index;
            }
        }

        return 0;
    }

    private bool MarkTutorialStepCompleted(int index, bool announce)
    {
        if (index < 0 || index >= _tutorialSteps.Count)
        {
            return false;
        }

        if (!_completedTutorialStepIndexes.Add(index))
        {
            return false;
        }

        if (announce && _announcedTutorialStepIndexes.Add(index))
        {
            Notifications.Success($"Guide page visited: {_tutorialSteps[index].Title}", 3);
        }

        return true;
    }

    private int GetBestIncompleteRouteMatchIndex(string uri)
    {
        var bestIndex = -1;
        var bestScore = -1;
        for (var index = 0; index < _tutorialSteps.Count; index++)
        {
            if (_completedTutorialStepIndexes.Contains(index))
            {
                continue;
            }

            var step = _tutorialSteps[index];
            if (!string.IsNullOrWhiteSpace(step.CompletionEventKey))
            {
                continue;
            }

            var score = GetTutorialStepMatchScore(step, uri);
            if (score > bestScore)
            {
                bestScore = score;
                bestIndex = index;
            }
        }

        return bestIndex;
    }

    private void QueueTutorialRouteCompletion(string uri, bool announce)
    {
        CancelPendingTutorialRouteCompletion();
        if (!TutorialVisible)
        {
            return;
        }

        var targetIndex = GetBestIncompleteRouteMatchIndex(uri);
        if (targetIndex < 0)
        {
            return;
        }

        var step = _tutorialSteps[targetIndex];
        var delayMs = Math.Max(0, step.RouteCompletionDelayMs);
        if (delayMs == 0)
        {
            if (MarkTutorialStepCompleted(targetIndex, announce))
            {
                _ = PersistTutorialJourneyStateAsync();
            }

            return;
        }

        _tutorialRouteCompletionCts = new CancellationTokenSource();
        _ = CompleteRouteMatchAfterDelayAsync(targetIndex, announce, delayMs, _tutorialRouteCompletionCts.Token);
    }

    private async Task CompleteRouteMatchAfterDelayAsync(int targetIndex, bool announce, int delayMs, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(delayMs, cancellationToken);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        if (cancellationToken.IsCancellationRequested)
        {
            return;
        }

        await InvokeAsync(async () =>
        {
            if (cancellationToken.IsCancellationRequested || !TutorialVisible)
            {
                return;
            }

            if (GetBestIncompleteRouteMatchIndex(NavigationManager.Uri) != targetIndex)
            {
                return;
            }

            if (MarkTutorialStepCompleted(targetIndex, announce))
            {
                await PersistTutorialJourneyStateAsync();
                StateHasChanged();
            }
        });
    }

    private void CancelPendingTutorialRouteCompletion()
    {
        if (_tutorialRouteCompletionCts is null)
        {
            return;
        }

        try
        {
            _tutorialRouteCompletionCts.Cancel();
        }
        catch
        {
        }

        _tutorialRouteCompletionCts.Dispose();
        _tutorialRouteCompletionCts = null;
    }

    [JSInvokable]
    public async Task HandleTutorialObjectiveCompletedAsync(string? completionEventKey)
    {
        if (!TutorialVisible)
        {
            return;
        }

        var normalizedKey = (completionEventKey ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(normalizedKey))
        {
            return;
        }

        var markedAny = false;
        for (var index = 0; index < _tutorialSteps.Count; index++)
        {
            if (!string.Equals(_tutorialSteps[index].CompletionEventKey, normalizedKey, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (MarkTutorialStepCompleted(index, announce: true))
            {
                markedAny = true;
            }
        }

        if (!markedAny)
        {
            return;
        }

        await PersistTutorialJourneyStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private bool DoesUriMatchTutorialStep(TutorialStepDefinition step, string uri)
    {
        return GetTutorialStepMatchScore(step, uri) >= 0;
    }

    private int GetTutorialStepMatchScore(TutorialStepDefinition step, string uri)
    {
        var matchCandidates = step.MatchPaths.Count > 0 ? step.MatchPaths : [step.Path];
        var (actualPath, actualQueryRaw) = SplitPathAndQuery(uri);
        var actualQuery = ParseQueryMap(actualQueryRaw);
        var bestScore = -1;

        foreach (var candidate in matchCandidates)
        {
            var (expectedPath, expectedQueryRaw) = SplitPathAndQuery(candidate);
            if (!PathMatches(actualPath, expectedPath, step.AllowPathPrefixMatch))
            {
                continue;
            }

            var expectedQuery = ParseQueryMap(expectedQueryRaw);
            if (QueryMatches(actualQuery, expectedQuery))
            {
                var score = (expectedQuery.Count * 10) + expectedPath.Length;
                if (score > bestScore)
                {
                    bestScore = score;
                }
            }
        }

        return bestScore;
    }

    private static bool PathMatches(string actualPath, string expectedPath, bool allowPrefix)
    {
        if (string.Equals(actualPath, expectedPath, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        if (!allowPrefix || string.IsNullOrWhiteSpace(expectedPath))
        {
            return false;
        }

        return actualPath.StartsWith(expectedPath + "/", StringComparison.OrdinalIgnoreCase);
    }

    private static bool QueryMatches(
        Dictionary<string, string> actualQuery,
        Dictionary<string, string> expectedQuery)
    {
        if (expectedQuery.Count == 0)
        {
            return true;
        }

        foreach (var required in expectedQuery)
        {
            if (!actualQuery.TryGetValue(required.Key, out var actualValue))
            {
                return false;
            }

            if (!string.Equals(actualValue, required.Value, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }
        }

        return true;
    }

    private static Dictionary<string, string> ParseQueryMap(string query)
    {
        var values = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var trimmed = (query ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            return values;
        }

        var withoutQuestionMark = trimmed.TrimStart('?');
        if (string.IsNullOrWhiteSpace(withoutQuestionMark))
        {
            return values;
        }

        var pairs = withoutQuestionMark.Split('&', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var pair in pairs)
        {
            var delimiterIndex = pair.IndexOf('=');
            string key;
            string value;
            if (delimiterIndex < 0)
            {
                key = Uri.UnescapeDataString(pair).Trim();
                value = string.Empty;
            }
            else
            {
                key = Uri.UnescapeDataString(pair[..delimiterIndex]).Trim();
                value = Uri.UnescapeDataString(pair[(delimiterIndex + 1)..]).Trim();
            }

            if (string.IsNullOrWhiteSpace(key))
            {
                continue;
            }

            values[key] = value;
        }

        return values;
    }

    private async Task<bool> RestoreTutorialJourneyStateAsync(LoginUserSummary session)
    {
        TutorialJourneyState? savedState;
        try
        {
            savedState = await JS.InvokeAsync<TutorialJourneyState?>("enigmaGame.getTutorialJourneyState");
        }
        catch
        {
            return false;
        }

        if (savedState is null)
        {
            return false;
        }

        var username = (session.Username ?? string.Empty).Trim();
        var stateUsername = (savedState.Username ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(stateUsername) ||
            !string.Equals(stateUsername, username, StringComparison.OrdinalIgnoreCase))
        {
            await ClearTutorialJourneyStateAsync();
            return false;
        }

        var completedIndexes = savedState.CompletedIndexes
            .Where(index => index >= 0 && index < _tutorialSteps.Count)
            .Distinct()
            .ToList();
        if (completedIndexes.Count >= _tutorialSteps.Count)
        {
            await ClearTutorialJourneyStateAsync();
            return false;
        }

        _completedTutorialStepIndexes.Clear();
        _announcedTutorialStepIndexes.Clear();
        foreach (var index in completedIndexes)
        {
            _completedTutorialStepIndexes.Add(index);
            _announcedTutorialStepIndexes.Add(index);
        }

        var normalizedIndex = savedState.CurrentIndex;
        if (normalizedIndex < 0 || normalizedIndex >= _tutorialSteps.Count)
        {
            normalizedIndex = GetFirstIncompleteTutorialStepIndex();
        }

        _tutorialIndex = normalizedIndex;
        TutorialVisible = true;
        QueueTutorialRouteCompletion(NavigationManager.Uri, announce: false);
        await PersistTutorialJourneyStateAsync();
        return true;
    }

    private async Task PersistTutorialJourneyStateAsync()
    {
        if (string.IsNullOrWhiteSpace(Session?.Username))
        {
            return;
        }

        if (!TutorialVisible && _completedTutorialStepIndexes.Count == 0)
        {
            await ClearTutorialJourneyStateAsync();
            return;
        }

        try
        {
            await JS.InvokeVoidAsync(
                "enigmaGame.setTutorialJourneyState",
                new TutorialJourneyState
                {
                    Username = Session!.Username,
                    Visible = TutorialVisible,
                    CurrentIndex = _tutorialIndex,
                    CompletedIndexes = _completedTutorialStepIndexes.OrderBy(index => index).ToList(),
                    UpdatedAtUtc = DateTimeOffset.UtcNow.ToString("O"),
                });
        }
        catch
        {
        }
    }

