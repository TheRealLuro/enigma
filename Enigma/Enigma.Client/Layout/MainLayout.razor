@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject Enigma.Client.Services.EnigmaApiClient Api
@inject Enigma.Client.Services.UiNotificationService Notifications
@implements IAsyncDisposable
@using Enigma.Client.Models
@using Enigma.Client.Models.Gameplay
@using Enigma.Client.Services
@using Microsoft.JSInterop

<div class="page">
    @if (ShouldShowHeader)
    {
        <header class="app-header app-shell-header">
            <div class="app-shell-brand">
                <div class="app-shell-brand-copy">
                    <button class="app-brand-button" @onclick="GoHome">Enigma</button>
                    <span class="app-shell-brand-tag">Anomaly Research Division</span>
                </div>
            </div>

            <nav class="app-shell-nav">
                <NavLink class="nav-link" href="/home" data-tour-id="nav-home">Home</NavLink>
                <NavLink class="nav-link" href="/play" data-tour-id="nav-play">Play</NavLink>
                <NavLink class="nav-link" href="/leaderboard" data-tour-id="nav-leaderboard">Leaderboard</NavLink>
                <NavLink class="nav-link" href="/players" data-tour-id="nav-players">Players</NavLink>
                <NavLink class="nav-link" href="/profile" data-tour-id="nav-profile">Profile</NavLink>
                <NavLink class="nav-link" href="/economy" data-tour-id="nav-economy">Economy</NavLink>
            </nav>

            <div class="app-shell-account">
                @if (ShouldShowHeaderBalance)
                {
                    <div class="app-shell-balance-chip">
                        <span>Maze Nuggets</span>
                        <strong>@Session!.MazeNuggets.ToString("N0") MN</strong>
                    </div>
                }

                <button class="app-shell-user-chip" @onclick="ToggleAccountMenu">
                    <span class="app-shell-user-kicker">Signed in</span>
                    <strong>@(Session?.Username ?? "Explorer")</strong>
                </button>

                @if (IsAccountMenuOpen)
                {
                    <div class="app-shell-account-menu">
                        <button class="app-shell-account-link" @onclick="GoProfile">View Profile</button>
                        <button class="app-shell-account-link" @onclick="GoToSettings">Settings</button>
                        <button class="app-shell-account-link danger" @onclick="LogoutAsync">Sign Out</button>
                    </div>
                }
            </div>
        </header>
    }

    @if (IsAuthenticated && !IsPublicPath() && _notifications.Count > 0)
    {
        <div class="global-notification-stack" role="status" aria-live="polite">
            @foreach (var notification in _notifications)
            {
                <div class="global-notification @GetNotificationCssClass(notification.Level)">
                    <span class="global-notification-dot" aria-hidden="true"></span>
                    <span>@notification.Message</span>
                </div>
            }
        </div>
    }

    <main>
        @if (CanRenderCurrentRoute)
        {
            <article class="content px-4 app-shell-content">
                @Body
            </article>
        }
        else
        {
            <div class="content app-shell-content">
                <div class="card enigma-game-message">
                    <div class="loader"></div>
                    <p>Syncing explorer session...</p>
                </div>
            </div>
        }
    </main>
</div>

@if (TutorialVisible && CurrentTutorialStep is not null)
{
    <div class="enigma-modal-backdrop tutorial-backdrop @(IsGamePath() ? "tutorial-backdrop-game" : string.Empty)">
        <div class="enigma-modal-card tutorial-modal-card">
            <div class="tutorial-head-row">
                <span class="profile-kicker">@CurrentTutorialStep.Chapter</span>
                <span class="tutorial-step-chip">Step @(_tutorialIndex + 1) / @_tutorialSteps.Count</span>
            </div>
            <h2>@CurrentTutorialStep.Title</h2>
            <p>@CurrentTutorialStep.Description</p>
            <div class="tutorial-route-hint">
                <span>Target Route</span>
                <strong>@GetTutorialDestinationLabel(CurrentTutorialStep)</strong>
            </div>
            <div class="tutorial-step-rail" role="list" aria-label="Tutorial guide steps">
                @for (var index = 0; index < _tutorialSteps.Count; index++)
                {
                    var step = _tutorialSteps[index];
                    <button class="@GetTutorialStepButtonClass(index)"
                            type="button"
                            role="listitem"
                            title="@step.Title"
                            @onclick="(() => JumpToTutorialStepAsync(index))">
                        <span class="tutorial-step-number">@((index + 1).ToString("00"))</span>
                        <span class="tutorial-step-name">@step.Eyebrow</span>
                    </button>
                }
            </div>
            <div class="tutorial-objective-card">
                <span class="profile-eyebrow">@CurrentTutorialStep.Eyebrow Guide</span>
                <p>@CurrentTutorialStep.Objective</p>
                <span class="tutorial-objective-status @(IsCurrentTutorialStepComplete ? "complete" : string.Empty)">
                    @(IsCurrentTutorialStepComplete ? "Page visited." : "Visit this page to mark it complete.")
                </span>
            </div>
            @if (!string.IsNullOrWhiteSpace(CurrentTutorialStep.HelperText))
            {
                <p class="tutorial-helper-copy">@CurrentTutorialStep.HelperText</p>
            }
            <div class="tutorial-progress-track" aria-hidden="true">
                <span class="tutorial-progress-fill" style="@GetTutorialProgressStyle()"></span>
            </div>
            <div class="tutorial-progress-row">
                <span>Step @(_tutorialIndex + 1) of @_tutorialSteps.Count</span>
                <span>@CompletedTutorialStepCount / @_tutorialSteps.Count pages visited</span>
            </div>
            <div class="enigma-end-actions tutorial-action-row">
                <button class="btn btn-secondary" type="button" @onclick="RestartTutorialJourneyAsync">Restart</button>
                <button class="btn btn-secondary" type="button" @onclick="SkipTutorialAsync">Skip</button>
                <button class="btn btn-secondary" type="button" disabled="@(_tutorialIndex == 0)" @onclick="GoToPreviousTutorialStepAsync">Previous</button>
                <button class="btn btn-secondary" type="button" @onclick="OpenCurrentTutorialObjectiveAsync">Open Page</button>
                <button class="btn btn-primary" type="button" disabled="@(!CanAdvanceTutorialStep)" @onclick="GoToNextTutorialStepAsync">@(_tutorialIndex == _tutorialSteps.Count - 1 ? "Finish" : "Continue")</button>
            </div>
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

