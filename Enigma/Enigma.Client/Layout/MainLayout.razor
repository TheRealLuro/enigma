        _tutorialListenerRef?.Dispose();
        if (_userSessionListenerRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("enigmaGame.disposeUserSessionListener");
            }
            catch
            {
            }
        }

        _userSessionListenerRef?.Dispose();
    }
}
