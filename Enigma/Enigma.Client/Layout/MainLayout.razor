    private void EnsureGlobalSessionRefreshLoop()
    {
        if (IsPublicPath() || !IsAuthenticated)
        {
            return;
        }

        if (_sessionRefreshTask is { IsCompleted: false })
        {
            return;
        }

        StopGlobalSessionRefreshLoop();
        _sessionRefreshCancellation = new CancellationTokenSource();
        _sessionRefreshTask = RunGlobalSessionRefreshLoopAsync(_sessionRefreshCancellation.Token);
    }

    private void StopGlobalSessionRefreshLoop()
    {
        if (_sessionRefreshCancellation is not null)
        {
            try
            {
                _sessionRefreshCancellation.Cancel();
            }
            catch
            {
            }

            _sessionRefreshCancellation.Dispose();
            _sessionRefreshCancellation = null;
        }

        _sessionRefreshTask = null;
    }

    private async Task RunGlobalSessionRefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(GlobalSessionRefreshInterval);
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (cancellationToken.IsCancellationRequested || IsPublicPath() || !IsAuthenticated || _handlingUserSessionUpdate)
                {
                    continue;
                }

                LoginUserSummary? latestSession;
                try
                {
                    latestSession = await Api.GetSessionAsync(cancellationToken, lightweight: true);
                }
                catch (OperationCanceledException)
                {
                    break;
                }
                catch
                {
                    continue;
                }

                await InvokeAsync(async () =>
                {
                    var previousSession = Session;
                    AuthCheckComplete = true;
                    IsAuthenticated = latestSession is not null && !string.IsNullOrWhiteSpace(latestSession.Username);
                    Session = latestSession;
                    UpdateFriendRequestTracking(latestSession);
                    UpdateInviteTracking(latestSession);
                    NotifySessionDeltas(previousSession, latestSession);

                    if (!IsAuthenticated)
                    {
                        StopGlobalSessionRefreshLoop();
                        ResetRealtimeTracking();
                        await ClearBrowserSessionAsync();
                        NavigationManager.NavigateTo("/", replace: true);
                        return;
                    }

                    await StateHasChangedAsync();
                });

                _governanceRefreshTick++;
                if (_governanceRefreshTick >= 5)
                {
                    _governanceRefreshTick = 0;
                    await CheckGovernanceStateAsync(cancellationToken);
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void UpdateFriendRequestTracking(LoginUserSummary? session)
    {
        if (session is null || string.IsNullOrWhiteSpace(session.Username))
        {
            _friendRequestsInitialized = false;
            _knownFriendRequests = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            HideFriendRequestToast();
            return;
        }

        var latest = session.FriendRequests
            .Select(request => (request ?? string.Empty).Trim())
            .Where(static request => !string.IsNullOrWhiteSpace(request))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!_friendRequestsInitialized)
        {
            _knownFriendRequests = latest;
            _friendRequestsInitialized = true;
            return;
        }

        var addedRequests = latest
            .Where(requester => !_knownFriendRequests.Contains(requester))
            .OrderBy(requester => requester, StringComparer.OrdinalIgnoreCase)
            .ToList();

        _knownFriendRequests = latest;
        if (addedRequests.Count == 0)
        {
            return;
        }

        var toastMessage = addedRequests.Count == 1
            ? $"New friend request received from {addedRequests[0]}."
            : $"{addedRequests.Count} new friend requests received.";
        ShowFriendRequestToast(toastMessage);
    }

    private void UpdateInviteTracking(LoginUserSummary? session)
    {
        if (session is null || string.IsNullOrWhiteSpace(session.Username))
        {
            _invitesInitialized = false;
            _knownInviteSessionIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            HideInviteToast();
            return;
        }

        var latest = session.PendingMultiplayerInvites
            .Select(invite => (invite.SessionId ?? string.Empty).Trim())
            .Where(static sessionId => !string.IsNullOrWhiteSpace(sessionId))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!_invitesInitialized)
        {
            _knownInviteSessionIds = latest;
            _invitesInitialized = true;
            if (latest.Count > 0 && !string.Equals(GetCleanPath(NavigationManager.Uri), "play/coop", StringComparison.OrdinalIgnoreCase))
            {
                var initialInvite = session.PendingMultiplayerInvites.FirstOrDefault();
                var initialSender = string.IsNullOrWhiteSpace(initialInvite?.OwnerUsername) ? "a teammate" : initialInvite!.OwnerUsername.Trim();
                var initialToast = latest.Count == 1
                    ? $"New co-op invite received from {initialSender}."
                    : $"{latest.Count} co-op invites are waiting.";
                ShowInviteToast(initialToast);
            }
            return;
        }

        var addedInviteIds = latest
            .Where(sessionId => !_knownInviteSessionIds.Contains(sessionId))
            .OrderBy(sessionId => sessionId, StringComparer.OrdinalIgnoreCase)
            .ToList();

        _knownInviteSessionIds = latest;
        if (addedInviteIds.Count == 0)
        {
            return;
        }

        var firstInvite = session.PendingMultiplayerInvites
            .FirstOrDefault(invite => string.Equals(invite.SessionId, addedInviteIds[0], StringComparison.OrdinalIgnoreCase));
        var sender = string.IsNullOrWhiteSpace(firstInvite?.OwnerUsername) ? "a teammate" : firstInvite!.OwnerUsername.Trim();
        var toastMessage = addedInviteIds.Count == 1
            ? $"New co-op invite received from {sender}."
            : $"{addedInviteIds.Count} new co-op invites received.";
        ShowInviteToast(toastMessage);
    }

