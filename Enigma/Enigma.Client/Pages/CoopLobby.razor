@page "/play/coop"
@using System.ComponentModel.DataAnnotations
@using Enigma.Client.Models
@using Enigma.Client.Models.Gameplay
@using Microsoft.JSInterop
@inject Enigma.Client.Services.EnigmaApiClient Api
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<SeoHead Title="Enigma Co-op Lobby | Create a Shared Maze Session"
         Description="Create or join a two-player Enigma co-op session, invite a friend, and prepare a synchronized maze expedition."
         Robots="noindex,follow"
         OpenGraphType="website"
         SchemaType="WebPage" />

@if (IsLoading && !HasLoadedOnce)
{
    <div class="content">
        <div class="card enigma-game-message">
            <div class="loader"></div>
            <p>Loading co-op lobby...</p>
        </div>
    </div>
}
else if (Session is null)
{
    <div class="content">
        <div class="card enigma-game-message">
            <h1>Co-op Lobby Unavailable</h1>
            <p>Sign in before creating or joining a co-op session.</p>
            <div class="enigma-end-actions">
                <button class="btn btn-primary" @onclick="GoPlay">Play</button>
                <button class="btn btn-secondary" @onclick="GoHome">Home</button>
            </div>
        </div>
    </div>
}
else
{
    <div class="content coop-shell">
        <section class="coop-banner">
            <div>
                <span class="profile-kicker">Co-op Lobby</span>
                <h1>Dual Expedition</h1>
            </div>
            <div class="play-header-actions">
                <button class="btn btn-secondary" type="button" disabled="@IsActionBusy" @onclick="RefreshSessionSummaryAsync">Refresh Lobby</button>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert @(HasError ? "alert-warning" : "alert-info")">@StatusMessage</div>
        }

        @if (CurrentSession is null)
        {
            <div class="coop-grid coop-setup-grid">
                <section class="panel coop-join-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="profile-eyebrow">Invites</span>
                            <h2>Pending Co-op Invites</h2>
                        </div>
                        <span class="section-count">@Session.PendingMultiplayerInvites.Count</span>
                    </div>
                    @if (Session.PendingMultiplayerInvites.Count == 0)
                    {
                        <div class="empty-state-inline">No active co-op invites right now. Ask a friend to invite you from their co-op lobby, then refresh here.</div>
                    }
                    else
                    {
                        <div class="coop-catalog-stack">
                            @foreach (var invite in Session.PendingMultiplayerInvites)
                            {
                                <article class="coop-invite-card">
                                    <div>
                                        <span class="profile-eyebrow">Invite from @invite.OwnerUsername</span>
                                        <strong>@(string.IsNullOrWhiteSpace(invite.MapName) ? "Generated Co-op Run" : invite.MapName)</strong>
                                    </div>
                                    <div class="coop-player-meta">
                                        <span>@FormatSessionStatus(invite.Status)</span>
                                        <span>@FormatDifficulty(invite.Difficulty)</span>
                                        <span>@invite.Size x @invite.Size</span>
                                    </div>
                                    <div class="coop-player-meta mono-numeric">
                                        <span>Session</span>
                                        <strong>@invite.SessionId</strong>
                                    </div>
                                    <button class="btn btn-primary" type="button" disabled="@IsActionBusy" @onclick="(() => JoinPendingInviteAsync(invite.SessionId))">
                                        Join Invite
                                    </button>
                                </article>
                            }
                        </div>
                    }
                </section>

                <section class="panel coop-create-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="profile-eyebrow">Create</span>
                            <h2>Start a Session</h2>
                        </div>
                    </div>

                    <div class="coop-form-stack">
                        <EditForm FormName="CoopGenerateForm" Model="CreateRequest" OnValidSubmit="CreateGeneratedSessionAsync">
                            <DataAnnotationsValidator />
                            <div class="coop-create-block">
                                <div class="coop-create-block-head">
                                    <span class="profile-eyebrow">Fresh Run</span>
                                    <h3>Generate a New Co-op Maze</h3>
                                </div>
                                <div class="coop-form-grid">
                                    <div>
                                        <label class="form-label">Difficulty</label>
                                        <EnigmaDropdown TValue="Difficulty"
                                                        Class="form-control"
                                                        Options="DifficultyOptions"
                                                        @bind-Value="CreateRequest.Difficulty" />
                                    </div>
                                    <div>
                                        <label class="form-label">Size</label>
                                        <EnigmaIntStepper Class="form-control"
                                                          Min="2"
                                                          Max="250"
                                                          @bind-Value="CreateRequest.Size" />
                                    </div>
                                </div>
                                <ValidationMessage For="() => CreateRequest.Size" />
                                <div class="coop-form-grid coop-form-grid-single">
                                    <div>
                                        <label class="form-label">Invite Friend</label>
                                        <EnigmaDropdown TValue="string"
                                                        Class="form-control"
                                                        Options="AvailableFriendOptions"
                                                        @bind-Value="SelectedInviteFriend" />
                                    </div>
                                </div>
                                <button class="btn btn-primary w-100" type="submit" disabled="@IsActionBusy">
                                    @(IsActionBusy ? "Creating..." : "Generate Co-op Maze")
                                </button>
                            </div>
                        </EditForm>

                        <div class="coop-divider"><span>or</span></div>

                        <EditForm FormName="CoopLoadForm" Model="LoadRequest" OnValidSubmit="CreateLoadedSessionAsync">
                            <DataAnnotationsValidator />
                            <div class="coop-create-block">
                                <div class="coop-create-block-head">
                                    <span class="profile-eyebrow">Saved Map</span>
                                    <h3>Load an Existing Maze</h3>
                                </div>
                                <div>
                                    <MapSearchBox Label="Saved Map Name"
                                                  InputId="coop-map-search"
                                                  Placeholder="type a saved maze name"
                                                  Value="@LoadRequest.MapName"
                                                  ValueChanged="OnCoopMapNameChanged" />
                                    <ValidationMessage For="() => LoadRequest.MapName" />
                                </div>
                                <div>
                                    <label class="form-label">Invite Friend</label>
                                    <EnigmaDropdown TValue="string"
                                                    Class="form-control"
                                                    Options="AvailableFriendOptions"
                                                    @bind-Value="SelectedInviteFriend" />
                                </div>
                                <button class="btn btn-secondary w-100" type="submit" disabled="@IsActionBusy">
                                    @(IsActionBusy ? "Loading..." : "Load Map Into Co-op")
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </section>

                <section class="panel coop-join-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="profile-eyebrow">Join</span>
                            <h2>Enter a Session</h2>
                        </div>
                    </div>
                    <div class="coop-form-stack">
                        <div>
                            <label class="form-label">Session ID</label>
                            <InputText class="form-control" @bind-Value="JoinSessionId" placeholder="mp-xxxxxxxxxx" />
                        </div>
                        <button class="btn btn-primary w-100" type="button" disabled="@IsActionBusy || string.IsNullOrWhiteSpace(JoinSessionId)" @onclick="JoinSessionAsync">
                            @(IsActionBusy ? "Joining..." : "Join Lobby")
                        </button>
                        <div class="empty-state-inline">Manual session join only works after the owner has invited you. If you were just invited, hit Refresh Lobby and use the invite card above.</div>
                    </div>
                </section>
            </div>
        }
        else
        {
            <div class="coop-grid coop-active-grid">
                <section class="panel coop-session-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="profile-eyebrow">Session</span>
                            <h2>@GetSessionHeading()</h2>
                        </div>
                        <span class="section-count">@CurrentSession.SessionId</span>
                    </div>

                    <div class="coop-session-meta-compact">
                        <div class="coop-meta-pill">
                            <span>Status</span>
                            <strong>@FormatSessionStatus(CurrentSession.Status)</strong>
                        </div>
                        <div class="coop-meta-pill map" title="@(string.IsNullOrWhiteSpace(CurrentSession.MapName) ? "Generated Seed" : CurrentSession.MapName)">
                            <span>Map</span>
                            <strong>@(string.IsNullOrWhiteSpace(CurrentSession.MapName) ? "Generated Seed" : CurrentSession.MapName)</strong>
                        </div>
                        <div class="coop-meta-pill">
                            <span>Difficulty</span>
                            <strong>@CurrentSession.Difficulty</strong>
                        </div>
                        <div class="coop-meta-pill">
                            <span>Size</span>
                            <strong>@CurrentSession.Size x @CurrentSession.Size</strong>
                        </div>
                    </div>

                    <div class="coop-player-stack">
                        @if (CurrentSession.You is not null)
                        {
                            <article class="coop-player-card you">
                                <div class="coop-player-main">
                                    <strong>@CurrentSession.You.Username</strong>
                                    <span class="coop-player-context">Blue console</span>
                                </div>
                                <div class="coop-player-meta">
                                    <span>@(CurrentSession.You.Ready ? "Ready" : "Not ready")</span>
                                    <span>MN @CurrentSession.TeamGold</span>
                                </div>
                            </article>
                        }

                        <article class="coop-player-card partner">
                            <div class="coop-player-main">
                                <strong>@(CurrentSession.OtherPlayer?.Username ?? CurrentSession.GuestUsername ?? "Waiting for invited friend")</strong>
                                <span class="coop-player-context">Red console</span>
                            </div>
                            <div class="coop-player-meta">
                                <span>@(CurrentSession.OtherPlayer?.Ready == true ? "Ready" : "Not ready")</span>
                                <span>@GetPartnerRoomLabel()</span>
                            </div>
                        </article>
                    </div>

                    @if (IsOwner && !HasGuest && InviteCandidates.Count > 0)
                    {
                        <div class="coop-inline-form">
                            <EnigmaDropdown TValue="string"
                                            Class="form-control"
                                            Options="InvitePendingFriendOptions"
                                            @bind-Value="InvitePendingFriend" />
                            <button class="btn btn-secondary" type="button" disabled="@IsActionBusy || string.IsNullOrWhiteSpace(InvitePendingFriend)" @onclick="InviteFriendAsync">
                                Invite
                            </button>
                        </div>
                    }

                    @if (CurrentSession.InvitedFriends.Count > 0)
                    {
                        <div class="coop-invited-strip">
                            <span>Invited</span>
                            <strong>@string.Join(", ", CurrentSession.InvitedFriends)</strong>
                        </div>
                    }

                    @if (CurrentSession.MoveVote is not null)
                    {
                        <div class="coop-move-vote">
                            <strong>Room vote in progress:</strong>
                            <span>@CurrentSession.MoveVote.Target.ToString()</span>
                            <span>@string.Join(", ", CurrentSession.MoveVote.Votes)</span>
                        </div>
                    }

                    <div class="enigma-end-actions coop-action-row">
                        <button class="btn btn-primary" type="button" disabled="@IsActionBusy" @onclick="ToggleReadyAsync">
                            @(CurrentSession.You?.Ready == true ? "Unready" : "Ready Up")
                        </button>
                        <button class="btn btn-secondary" type="button" disabled="@(!CanEnterGame || IsEnteringActiveSession)" @onclick="EnterActiveSessionAsync">
                            Enter Maze
                        </button>
                        <button class="btn btn-danger" type="button" disabled="@IsActionBusy" @onclick="LeaveSessionAsync">
                            Leave Session
                        </button>
                    </div>

                    <div class="empty-state-inline coop-session-note">The maze starts once both players are present and ready. Movement and room changes stay synchronized after entry.</div>
                </section>

            </div>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "sessionId")]
    public string? RequestedSessionId { get; set; }

    private sealed class GenerateSessionForm
    {
        [Required]
        public Difficulty Difficulty { get; set; } = Difficulty.Easy;

        [Range(2, 250, ErrorMessage = "Co-op maze size must be between 2 and 250.")]
        public int Size { get; set; } = 4;
    }

    private sealed class LoadSessionForm
    {
        [Required]
        public string MapName { get; set; } = string.Empty;
    }

    private sealed class SeedApiResponse
    {
        public string Seed { get; set; } = string.Empty;
    }

    private LoginUserSummary? Session { get; set; }
    private bool IsLoading { get; set; } = true;
    private bool HasLoadedOnce { get; set; }
    private bool IsActionBusy { get; set; }
    private bool HasError { get; set; }
    private string? StatusMessage { get; set; }
    private string? LoadedSessionId { get; set; }
    private string JoinSessionId { get; set; } = string.Empty;
    private string SelectedInviteFriend { get; set; } = string.Empty;
    private string InvitePendingFriend { get; set; } = string.Empty;
    private GenerateSessionForm CreateRequest { get; set; } = new();
    private LoadSessionForm LoadRequest { get; set; } = new();
    private MultiplayerSessionState? CurrentSession { get; set; }
    private CancellationTokenSource? PollCancellation { get; set; }
    private Task? PollTask { get; set; }
    private CancellationTokenSource? InviteRefreshCancellation { get; set; }
    private Task? InviteRefreshTask { get; set; }
    private bool HasEnteredActiveSession { get; set; }
    private bool IsEnteringActiveSession { get; set; }
    private bool CoopSocketOpen { get; set; }
    private DotNetObjectReference<CoopLobby>? LobbySocketRef { get; set; }

    private IReadOnlyList<string> AvailableFriends => Session?.Friends.OrderBy(static friend => friend, StringComparer.OrdinalIgnoreCase).ToList() ?? [];
    private static readonly IReadOnlyList<SelectOption<Difficulty>> DifficultyOptions =
        Enum.GetValues<Difficulty>()
            .Select(static difficulty => new SelectOption<Difficulty>(difficulty, difficulty.ToString()))
            .ToArray();
    private IReadOnlyList<SelectOption<string>> AvailableFriendOptions =>
        [new(string.Empty, "Choose later"), .. AvailableFriends.Select(static friend => new SelectOption<string>(friend, friend))];
    private IReadOnlyList<SelectOption<string>> InvitePendingFriendOptions =>
        [new(string.Empty, "Invite a friend"), .. InviteCandidates.Select(static friend => new SelectOption<string>(friend, friend))];
    private bool IsOwner => CurrentSession is not null && string.Equals(CurrentSession.OwnerUsername, Session?.Username, StringComparison.OrdinalIgnoreCase);
    private bool HasGuest => !string.IsNullOrWhiteSpace(CurrentSession?.GuestUsername);
    private bool CanEnterGame => CurrentSession is not null && string.Equals(CurrentSession.Status, "active", StringComparison.OrdinalIgnoreCase);

    private List<string> InviteCandidates =>
        AvailableFriends
            .Where(friend => !string.Equals(friend, Session?.Username, StringComparison.OrdinalIgnoreCase))
            .Where(friend => CurrentSession?.InvitedFriends.Contains(friend, StringComparer.OrdinalIgnoreCase) != true)
            .Where(friend => !string.Equals(friend, CurrentSession?.GuestUsername, StringComparison.OrdinalIgnoreCase))
            .ToList();

    protected override async Task OnParametersSetAsync()
    {
        if (!HasLoadedOnce || string.Equals(LoadedSessionId, RequestedSessionId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await LoadSessionAsync(RequestedSessionId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Session = await Api.GetSessionAsync();
            if (Session is null)
            {
                NavigationManager.NavigateTo("/", replace: true);
                return;
            }

            await JS.InvokeVoidAsync("enigmaGame.clearCoopLeaveUnload");
            LobbySocketRef = DotNetObjectReference.Create(this);
            HasLoadedOnce = true;
            IsLoading = false;
            StartInviteRefresh();

            if (!string.IsNullOrWhiteSpace(RequestedSessionId))
            {
                JoinSessionId = RequestedSessionId;
                if (Session.PendingMultiplayerInvites.Any(invite => string.Equals(invite.SessionId, RequestedSessionId, StringComparison.OrdinalIgnoreCase)))
                {
                    await JoinPendingInviteAsync(RequestedSessionId);
                }
                else
                {
                    await LoadSessionAsync(RequestedSessionId);
                }
            }

            await InvokeAsync(StateHasChanged);
        }

        if (CurrentSession is not null && !HasEnteredActiveSession && !IsEnteringActiveSession)
        {
            await EnsureLobbySocketConnectedAsync();
        }
        else if (CurrentSession is null && LobbySocketRef is not null)
        {
            await JS.InvokeVoidAsync("enigmaGame.disposeCoopSocket");
        }
    }

    private async Task CreateGeneratedSessionAsync()
    {
        await ExecuteActionAsync(async () =>
        {
            using var response = await Api.GetAsync(
                $"api/auth/newMap?difficulty={Uri.EscapeDataString(CreateRequest.Difficulty.ToString().ToLowerInvariant())}&size={CreateRequest.Size}");
            var seedResponse = await Api.ReadJsonAsync<SeedApiResponse>(response);

            if (!response.IsSuccessStatusCode || string.IsNullOrWhiteSpace(seedResponse?.Seed))
            {
                throw new InvalidOperationException(await ExtractErrorDetailAsync(response));
            }

            await CreateSessionAsync(seedResponse.Seed, null, "new");
        });
    }

    private async Task CreateLoadedSessionAsync()
    {
        await ExecuteActionAsync(async () =>
        {
            using var response = await Api.GetAsync(
                $"api/auth/loadMap?name={Uri.EscapeDataString(LoadRequest.MapName)}");
            var seedResponse = await Api.ReadJsonAsync<SeedApiResponse>(response);

            if (!response.IsSuccessStatusCode || string.IsNullOrWhiteSpace(seedResponse?.Seed))
            {
                throw new InvalidOperationException(await ExtractErrorDetailAsync(response));
            }

            await CreateSessionAsync(seedResponse.Seed, LoadRequest.MapName, "load");
        });
    }

    private Task OnCoopMapNameChanged(string mapName)
    {
        LoadRequest.MapName = mapName;
        return InvokeAsync(StateHasChanged);
    }

    private async Task CreateSessionAsync(string seed, string? mapName, string source)
    {
        using var response = await Api.PostJsonAsync("api/auth/multiplayer/session/create", new
        {
            seed,
            mapName,
            source,
            invitedFriends = string.IsNullOrWhiteSpace(SelectedInviteFriend) ? Array.Empty<string>() : new[] { SelectedInviteFriend },
        });

        var payload = await Api.ReadJsonAsync<MultiplayerSessionEnvelope>(response);
        await EnsureSuccessAsync(response, payload, "Unable to create a co-op session.");
        ApplySessionEnvelope(payload);
        StatusMessage = "Session created. Share the session id or invite a friend to join.";
        HasError = false;
    }

    private async Task JoinSessionAsync()
    {
        await ExecuteActionAsync(async () =>
        {
            using var response = await Api.PostJsonAsync("api/auth/multiplayer/session/join", new { sessionId = JoinSessionId.Trim() });
            var payload = await Api.ReadJsonAsync<MultiplayerSessionEnvelope>(response);
            await EnsureSuccessAsync(response, payload, "Unable to join the co-op session.");
            ApplySessionEnvelope(payload);
            StatusMessage = "Joined session. Ready up when both players are in the lobby.";
            HasError = false;
        });
    }

    private Task JoinPendingInviteAsync(string sessionId)
    {
        JoinSessionId = sessionId;
        return JoinSessionAsync();
    }

    private async Task ToggleReadyAsync()
    {
        if (CurrentSession is null || CurrentSession.You is null)
        {
            return;
        }

        await ExecuteActionAsync(async () =>
        {
            using var response = await Api.PostJsonAsync("api/auth/multiplayer/session/ready", new
            {
                sessionId = CurrentSession.SessionId,
                ready = !CurrentSession.You.Ready,
            });
            var payload = await Api.ReadJsonAsync<MultiplayerSessionEnvelope>(response);
            await EnsureSuccessAsync(response, payload, "Unable to update ready state.");
            ApplySessionEnvelope(payload);
        });
    }

    private async Task InviteFriendAsync()
    {
        if (CurrentSession is null || string.IsNullOrWhiteSpace(InvitePendingFriend))
        {
            return;
        }

        await ExecuteActionAsync(async () =>
        {
            using var response = await Api.PostJsonAsync("api/auth/multiplayer/session/invite", new
            {
                sessionId = CurrentSession.SessionId,
                friendUsername = InvitePendingFriend,
            });
            var payload = await Api.ReadJsonAsync<MultiplayerSessionEnvelope>(response);
            await EnsureSuccessAsync(response, payload, "Unable to invite that friend.");
            InvitePendingFriend = string.Empty;
            ApplySessionEnvelope(payload);
            StatusMessage = "Friend invited. They can now join with the session id.";
            HasError = false;
        });
    }

    private async Task LeaveSessionAsync()
    {
        if (CurrentSession is null)
        {
            return;
        }

        await ExecuteActionAsync(async () =>
        {
            using var response = await Api.PostJsonAsync("api/auth/multiplayer/session/leave", new
            {
                sessionId = CurrentSession.SessionId,
                reason = "left_lobby",
            });
            var payload = await Api.ReadJsonAsync<MultiplayerSessionEnvelope>(response);
            await EnsureSuccessAsync(response, payload, "Unable to leave the co-op session.");
            await StopPollingAsync();
            CurrentSession = null;
            LoadedSessionId = null;
            HasEnteredActiveSession = false;
            IsEnteringActiveSession = false;
            JoinSessionId = string.Empty;
            NavigationManager.NavigateTo("/play/coop", replace: true);
            StatusMessage = "Session closed.";
            HasError = false;
        });
    }

    private async Task LoadSessionAsync(string? sessionId)
    {
        var normalizedSessionId = (sessionId ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(normalizedSessionId))
        {
            await StopPollingAsync();
            CurrentSession = null;
            LoadedSessionId = null;
            return;
        }

        IsLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var response = await Api.GetAsync($"api/auth/multiplayer/session?sessionId={Uri.EscapeDataString(normalizedSessionId)}");
            var payload = await Api.ReadJsonAsync<MultiplayerSessionEnvelope>(response);
            await EnsureSuccessAsync(response, payload, "Unable to load the co-op session.");
            ApplySessionEnvelope(payload);
            HasError = false;
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshSessionSummaryAsync()
    {
        Session = await Api.GetSessionAsync();
        if (Session is null)
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        if (!string.IsNullOrWhiteSpace(RequestedSessionId))
        {
            if (Session.PendingMultiplayerInvites.Any(invite => string.Equals(invite.SessionId, RequestedSessionId, StringComparison.OrdinalIgnoreCase)))
            {
                await JoinPendingInviteAsync(RequestedSessionId);
            }
            else
            {
                await LoadSessionAsync(RequestedSessionId);
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private void StartInviteRefresh()
    {
        if (InviteRefreshTask is not null)
        {
            return;
        }

        InviteRefreshCancellation = new CancellationTokenSource();
        InviteRefreshTask = RefreshInviteLoopAsync(InviteRefreshCancellation.Token);
    }

    private async Task RefreshInviteLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(1500));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (IsActionBusy || IsEnteringActiveSession || HasEnteredActiveSession)
                {
                    continue;
                }

                LoginUserSummary? refreshedSession;
                try
                {
                    refreshedSession = await Api.GetSessionAsync(cancellationToken);
                }
                catch (OperationCanceledException)
                {
                    break;
                }
                catch
                {
                    continue;
                }

                if (refreshedSession is null)
                {
                    await InvokeAsync(() => NavigationManager.NavigateTo("/", replace: true));
                    break;
                }

                var previousInviteIds = Session?.PendingMultiplayerInvites
                    .Select(static invite => invite.SessionId)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase) ?? [];
                var refreshedInviteIds = refreshedSession.PendingMultiplayerInvites
                    .Select(static invite => invite.SessionId)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
                var hasInviteDelta = !previousInviteIds.SetEquals(refreshedInviteIds);

                if (CurrentSession is null && !string.IsNullOrWhiteSpace(RequestedSessionId) &&
                    refreshedSession.PendingMultiplayerInvites.Any(invite =>
                        string.Equals(invite.SessionId, RequestedSessionId, StringComparison.OrdinalIgnoreCase)))
                {
                    await InvokeAsync(async () =>
                    {
                        Session = refreshedSession;
                        await JoinPendingInviteAsync(RequestedSessionId);
                    });
                    continue;
                }

                if (!hasInviteDelta)
                {
                    continue;
                }

                await InvokeAsync(() =>
                {
                    Session = refreshedSession;
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void ApplySessionEnvelope(MultiplayerSessionEnvelope? payload)
    {
        CurrentSession = payload?.Session;
        LoadedSessionId = CurrentSession?.SessionId;
        JoinSessionId = CurrentSession?.SessionId ?? JoinSessionId;
        if (CurrentSession is null)
        {
            return;
        }

        if (!string.Equals(RequestedSessionId, CurrentSession.SessionId, StringComparison.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo($"/play/coop?sessionId={Uri.EscapeDataString(CurrentSession.SessionId)}", replace: true);
        }

        if (!CoopSocketOpen)
        {
            StartPolling();
        }

        if (CanEnterGame && !HasEnteredActiveSession && !IsEnteringActiveSession)
        {
            StatusMessage = "Both players are ready. Enter the unknown when you're ready.";
            HasError = false;
        }
    }

    private async Task EnterActiveSessionAsync()
    {
        if (CurrentSession is null || IsEnteringActiveSession)
        {
            return;
        }

        IsEnteringActiveSession = true;
        HasEnteredActiveSession = true;
        StatusMessage = "Entering the co-op maze...";
        HasError = false;
        await StopPollingAsync();

        try
        {
            await JS.InvokeVoidAsync("enigmaGame.clearCoopLeaveUnload");
            await JS.InvokeVoidAsync("enigmaGame.disposeCoopSocket");
        }
        catch (JSDisconnectedException)
        {
        }

        CoopSocketOpen = false;
        var url = $"/game?seed={Uri.EscapeDataString(CurrentSession.Seed)}&source={Uri.EscapeDataString(CurrentSession.Source)}&coop=true&coopSessionId={Uri.EscapeDataString(CurrentSession.SessionId)}";
        if (!string.IsNullOrWhiteSpace(CurrentSession.MapName))
        {
            url += $"&mapName={Uri.EscapeDataString(CurrentSession.MapName)}";
        }

        NavigationManager.NavigateTo(url, replace: true);
    }

    private void StartPolling()
    {
        if (CoopSocketOpen || CurrentSession is null || string.IsNullOrWhiteSpace(CurrentSession.SessionId))
        {
            return;
        }

        if (CurrentSession.Status is "completed" or "abandoned")
        {
            return;
        }

        PollCancellation?.Cancel();
        PollCancellation = new CancellationTokenSource();
        PollTask = PollSessionLoopAsync(CurrentSession.SessionId, PollCancellation.Token);
    }

    private async Task PollSessionLoopAsync(string sessionId, CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(1000));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                using var response = await Api.GetAsync($"api/auth/multiplayer/session?sessionId={Uri.EscapeDataString(sessionId)}", cancellationToken);
                var payload = await Api.ReadJsonAsync<MultiplayerSessionEnvelope>(response, cancellationToken);
                if (!response.IsSuccessStatusCode || payload?.Session is null)
                {
                    continue;
                }

                await InvokeAsync(() =>
                {
                    CurrentSession = payload.Session;
                    if (CanEnterGame && !HasEnteredActiveSession && !IsEnteringActiveSession)
                    {
                        StatusMessage = "Both players are ready. Enter the maze when you're ready.";
                        HasError = false;
                    }
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ExecuteActionAsync(Func<Task> operation)
    {
        IsActionBusy = true;
        HasError = false;
        StatusMessage = null;

        try
        {
            await operation();
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsActionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static async Task EnsureSuccessAsync(HttpResponseMessage response, MultiplayerSessionEnvelope? payload, string prefix)
    {
        if (response.IsSuccessStatusCode && payload?.Session is not null)
        {
            return;
        }

        var detail = await ExtractErrorDetailAsync(response);
        throw new InvalidOperationException(string.IsNullOrWhiteSpace(detail) ? prefix : $"{prefix} {detail}");
    }

    private static async Task<string> ExtractErrorDetailAsync(HttpResponseMessage response)
    {
        var raw = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(raw))
        {
            return response.StatusCode == System.Net.HttpStatusCode.TooManyRequests
                ? "The backend rate limit was hit. Wait a moment and try again."
                : string.Empty;
        }

        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(raw);
            if (document.RootElement.TryGetProperty("detail", out var detailElement))
            {
                return detailElement.ValueKind == System.Text.Json.JsonValueKind.String
                    ? detailElement.GetString() ?? string.Empty
                    : detailElement.ToString();
            }
        }
        catch (System.Text.Json.JsonException)
        {
        }

        return raw;
    }

    private string GetSessionHeading()
    {
        if (CurrentSession is null)
        {
            return "Session";
        }

        return string.IsNullOrWhiteSpace(CurrentSession.MapName)
            ? "Found an Uncharted Maze"
            : CurrentSession.MapName;
    }

    private string GetPartnerRoomLabel()
    {
        if (CurrentSession?.OtherPlayer?.Room is not null)
        {
            return $"Room {CurrentSession.OtherPlayer.Room}";
        }

        return "Room pending";
    }

    private static string FormatSessionStatus(string? value) => value switch
    {
        "waiting_for_guest" => "Waiting for guest",
        "ready_check" => "Ready check",
        "active" => "Active",
        "completed" => "Completed",
        "abandoned" => "Abandoned",
        _ => string.IsNullOrWhiteSpace(value) ? "Unknown" : value.Replace('_', ' '),
    };

    private static string FormatDifficulty(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Unknown";
        }

        var normalized = value.Trim();
        return char.ToUpperInvariant(normalized[0]) + normalized[1..].ToLowerInvariant();
    }

    private void GoPlay() => NavigationManager.NavigateTo("/play");
    private void GoHome() => NavigationManager.NavigateTo("/home");

    private async Task EnsureLobbySocketConnectedAsync()
    {
        if (CurrentSession is null || string.IsNullOrWhiteSpace(CurrentSession.SessionId) || LobbySocketRef is null)
        {
            return;
        }

        await JS.InvokeVoidAsync("enigmaGame.connectCoopSocket", CurrentSession.SessionId, LobbySocketRef);
    }

    [JSInvokable]
    public Task HandleCoopSocketStatusChanged(bool isOpen)
    {
        CoopSocketOpen = isOpen;
        if (isOpen)
        {
            _ = StopPollingAsync();
        }
        else if (CurrentSession is not null && !HasEnteredActiveSession)
        {
            StartPolling();
        }

        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleCoopSocketMessage(string rawJson)
    {
        if (string.IsNullOrWhiteSpace(rawJson))
        {
            return Task.CompletedTask;
        }

        MultiplayerSocketEnvelope? payload;
        try
        {
            payload = System.Text.Json.JsonSerializer.Deserialize<MultiplayerSocketEnvelope>(rawJson, new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web));
        }
        catch (System.Text.Json.JsonException)
        {
            return Task.CompletedTask;
        }

        if (payload?.Session is null)
        {
            return Task.CompletedTask;
        }

        return InvokeAsync(() =>
        {
            ApplySessionEnvelope(new MultiplayerSessionEnvelope
            {
                Status = payload.Status,
                RoomMoved = payload.RoomMoved,
                Session = payload.Session,
                Completion = payload.Completion,
            });
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        await StopInviteRefreshAsync();
        await StopPollingAsync();
        try
        {
            await JS.InvokeVoidAsync("enigmaGame.disposeCoopSocket");
        }
        catch (JSDisconnectedException)
        {
        }

        LobbySocketRef?.Dispose();
    }

    private async Task StopPollingAsync()
    {
        if (PollCancellation is not null)
        {
            PollCancellation.Cancel();
            PollCancellation.Dispose();
            PollCancellation = null;
        }

        if (PollTask is not null)
        {
            try
            {
                await PollTask;
            }
            catch (OperationCanceledException)
            {
            }

            PollTask = null;
        }
    }

    private async Task StopInviteRefreshAsync()
    {
        if (InviteRefreshCancellation is not null)
        {
            InviteRefreshCancellation.Cancel();
            InviteRefreshCancellation.Dispose();
            InviteRefreshCancellation = null;
        }

        if (InviteRefreshTask is not null)
        {
            try
            {
                await InviteRefreshTask;
            }
            catch (OperationCanceledException)
            {
            }

            InviteRefreshTask = null;
        }
    }
}
