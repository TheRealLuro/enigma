@page "/economy"
@using System.Globalization
@using Enigma.Client.Models
@inject Enigma.Client.Services.EnigmaApiClient Api
@inject Enigma.Client.Services.UiNotificationService Notifications
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IAsyncDisposable

<SeoHead Title="Enigma Economy | Circulation, Marketplace, Staking, and Voting"
         Description="Track MN and map circulation, user activity, and use marketplace, staking, and voting from one economy hub."
         Robots="noindex,follow"
         OpenGraphType="website"
         SchemaType="WebPage" />

@if (IsLoading && Overview is null)
{
    <div class="content"><div class="card enigma-game-message"><div class="loader"></div><p>Loading economy overview...</p></div></div>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage) && Overview is null)
{
    <div class="content">
        <div class="card enigma-game-message">
            <h1>Economy unavailable</h1>
            <p>@ErrorMessage</p>
            <button class="btn btn-primary" type="button" @onclick="ReloadAsync">Retry</button>
        </div>
    </div>
}
else
{
    <div class="content economy-shell" data-tour-id="economy-shell">
        <section class="economy-banner" data-tour-id="economy-banner">
            <div>
                <span class="profile-eyebrow">Economy</span>
                <h1>Market Pulse</h1>
                <p>Monitor MN circulation, map circulation, player activity, and governance spend in one place.</p>
            </div>
            <div class="economy-banner-meta">
                @if (!string.IsNullOrWhiteSpace(Overview?.GeneratedAt))
                {
                    <span class="profile-chip">Snapshot @FormatTimestamp(Overview.GeneratedAt)</span>
                }
                <button class="btn btn-secondary" type="button" disabled="@IsLoading" @onclick="ReloadAsync">
                    @(IsLoading ? "Refreshing..." : "Refresh")
                </button>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="alert alert-warning">@ErrorMessage</div>
        }

        <div class="profile-tabbar economy-tabbar">
            <button class="@GetTabClass(OverviewTab)" type="button" data-tour-id="economy-tab-overview" @onclick='@(() => SetActiveTab(OverviewTab))'>Overview</button>
            <button class="@GetTabClass(MarketplaceTab)" type="button" data-tour-id="economy-tab-marketplace" @onclick='@(() => SetActiveTab(MarketplaceTab))'>Marketplace</button>
            <button class="@GetTabClass(StakingTab)" type="button" data-tour-id="economy-tab-staking" @onclick='@(() => SetActiveTab(StakingTab))'>Staking</button>
            <button class="@GetTabClass(VotingTab)" type="button" data-tour-id="economy-tab-voting" @onclick='@(() => SetActiveTab(VotingTab))'>Voting</button>
        </div>

        @if (ActiveTab == OverviewTab)
        {
            <section class="economy-kpi-grid">
                <article class="economy-kpi-card">
                    <span class="economy-kpi-label">Total MN Supply</span>
                    <strong class="economy-kpi-value" @key="Overview?.GeneratedAt">@((Overview?.MnTotalKnown ?? 0).ToString("N0")) MN</strong>
                    <span class="economy-kpi-sub">Known wallets plus bank reserve</span>
                </article>
                <article class="economy-kpi-card">
                    <span class="economy-kpi-label">Maps Tracked</span>
                    <strong class="economy-kpi-value" @key="Overview?.GeneratedAt">@((Overview?.MapsTotal ?? 0).ToString("N0"))</strong>
                    <span class="economy-kpi-sub">@((Overview?.MapsListed ?? 0).ToString("N0")) listed | @((Overview?.MapsStaked ?? 0).ToString("N0")) staked</span>
                </article>
                <article class="economy-kpi-card">
                    <span class="economy-kpi-label">Players Online</span>
                    <strong class="economy-kpi-value" @key="Overview?.GeneratedAt">@((Overview?.UsersOnlineNow ?? 0).ToString("N0"))</strong>
                    <span class="economy-kpi-sub">@((Overview?.UsersActive24h ?? 0).ToString("N0")) active in 24h</span>
                </article>
            </section>

            <section class="economy-grid">
                <article class="panel profile-release-panel economy-card">
                    <span class="profile-eyebrow">Maze Nuggets</span>
                    <h2>MN Circulation</h2>
                    <div class="economy-donut-layout">
                        <div class="economy-donut economy-donut-mn" style="@GetMnDonutStyle()">
                            <div class="economy-donut-core">
                                <span>Total</span>
                                <strong>@((Overview?.MnTotalKnown ?? 0).ToString("N0"))</strong>
                            </div>
                        </div>
                        <div class="economy-donut-legend">
                            <div class="economy-legend-row">
                                <span class="economy-legend-dot wallets"></span>
                                <span>Player wallets</span>
                                <strong>@((Overview?.MnPlayerWalletsTotal ?? 0).ToString("N0")) MN (@GetMnWalletShare().ToString("0.##")%)</strong>
                            </div>
                            <div class="economy-legend-row">
                                <span class="economy-legend-dot bank"></span>
                                <span>Enigma bank</span>
                                <strong>@((Overview?.MnBankReserveTotal ?? 0).ToString("N0")) MN (@GetMnBankShare().ToString("0.##")%)</strong>
                            </div>
                        </div>
                    </div>
                </article>

                <article class="panel profile-release-panel economy-card">
                    <span class="profile-eyebrow">Map Supply</span>
                    <h2>Map Circulation</h2>
                    <div class="economy-donut-layout">
                        <div class="economy-donut economy-donut-maps" style="@GetMapDonutStyle()">
                            <div class="economy-donut-core">
                                <span>Maps</span>
                                <strong>@((Overview?.MapsTotal ?? 0).ToString("N0"))</strong>
                            </div>
                        </div>
                        <div class="economy-donut-legend">
                            <div class="economy-legend-row">
                                <span class="economy-legend-dot listed"></span>
                                <span>Listed maps</span>
                                <strong>@GetMapListedCount().ToString("N0") (@GetMapListedShare().ToString("0.##")%)</strong>
                            </div>
                            <div class="economy-legend-row">
                                <span class="economy-legend-dot staked"></span>
                                <span>Staked maps</span>
                                <strong>@GetMapStakedCount().ToString("N0") (@GetMapStakedShare().ToString("0.##")%)</strong>
                            </div>
                            <div class="economy-legend-row">
                                <span class="economy-legend-dot unlisted"></span>
                                <span>Unlisted maps</span>
                                <strong>@GetMapUnlistedCount().ToString("N0") (@GetMapUnlistedShare().ToString("0.##")%)</strong>
                            </div>
                        </div>
                    </div>

                    <div class="economy-progress-stack">
                        <div class="economy-progress-row">
                            <div class="economy-progress-label">
                                <span>Listed maps</span>
                                <strong>@((Overview?.MapsListedPercent ?? 0).ToString("0.##"))%</strong>
                            </div>
                            <div class="economy-progress-bar">
                                <span style="@GetProgressStyle(Overview?.MapsListedPercent ?? 0)"></span>
                            </div>
                        </div>
                        <div class="economy-progress-row">
                            <div class="economy-progress-label">
                                <span>Staked maps</span>
                                <strong>@((Overview?.MapsStakedPercent ?? 0).ToString("0.##"))%</strong>
                            </div>
                            <div class="economy-progress-bar">
                                <span style="@GetProgressStyle(Overview?.MapsStakedPercent ?? 0)"></span>
                            </div>
                        </div>
                    </div>
                </article>

                <article class="panel profile-release-panel economy-card">
                    <span class="profile-eyebrow">Players</span>
                    <h2>Activity Snapshot</h2>
                    <div class="economy-stat-line"><span>Total users</span><strong>@((Overview?.UsersTotal ?? 0).ToString("N0"))</strong></div>
                    <div class="economy-stat-line"><span>Online now</span><strong>@((Overview?.UsersOnlineNow ?? 0).ToString("N0"))</strong></div>
                    <div class="economy-stat-line"><span>Active (24h)</span><strong>@((Overview?.UsersActive24h ?? 0).ToString("N0"))</strong></div>
                    <div class="economy-stat-line"><span>Users staking</span><strong>@((Overview?.StakersTotal ?? 0).ToString("N0"))</strong></div>

                    <div class="economy-progress-stack">
                        <div class="economy-progress-row">
                            <div class="economy-progress-label">
                                <span>Online ratio</span>
                                <strong>@GetOnlineShare().ToString("0.##")%</strong>
                            </div>
                            <div class="economy-progress-bar">
                                <span style="@GetProgressStyle(GetOnlineShare())"></span>
                            </div>
                        </div>
                        <div class="economy-progress-row">
                            <div class="economy-progress-label">
                                <span>24h activity ratio</span>
                                <strong>@GetActiveShare().ToString("0.##")%</strong>
                            </div>
                            <div class="economy-progress-bar">
                                <span style="@GetProgressStyle(GetActiveShare())"></span>
                            </div>
                        </div>
                    </div>
                </article>

                <article class="panel profile-release-panel economy-card">
                    <span class="profile-eyebrow">Marketplace + Voting</span>
                    <h2>Market Signals</h2>
                    <div class="economy-market-grid">
                        <div class="economy-market-item">
                            <span>Listing value total</span>
                            <strong>@((Overview?.MarketplaceListingValueTotal ?? 0).ToString("N0")) MN</strong>
                            <em>@GetListingValueShareOfSupply().ToString("0.##")% of known MN supply</em>
                        </div>
                        <div class="economy-market-item">
                            <span>Average listing ticket</span>
                            <strong>@((Overview?.MarketplaceListingPriceAvg ?? 0).ToString("N2")) MN</strong>
                            <em>Across @((Overview?.MapsListed ?? 0).ToString("N0")) live listing(s)</em>
                        </div>
                        <div class="economy-market-item">
                            <span>Governance spend total</span>
                            <strong>@((Overview?.GovernanceTotalMnSpent ?? 0).ToString("N0")) MN</strong>
                            <em>@GetGovernanceSpendLabel()</em>
                        </div>
                        <div class="economy-market-item">
                            <span>Council status</span>
                            <strong>@(Overview?.GovernanceVotingOpen == true ? "Open" : "Closed")</strong>
                            <em>@GetGovernanceSessionLabel()</em>
                        </div>
                    </div>
                </article>

                <article class="panel profile-release-panel economy-card economy-card-span">
                    <span class="profile-eyebrow">Economy Health</span>
                    <h2>System Pulse</h2>
                    <div class="economy-health-grid">
                        <div class="economy-health-row">
                            <span>Liquidity</span>
                            <strong class="@GetLiquidityHealthClass()">@GetLiquidityHealthLabel()</strong>
                        </div>
                        <div class="economy-health-row">
                            <span>Player activity</span>
                            <strong class="@GetActivityHealthClass()">@GetActivityHealthLabel()</strong>
                        </div>
                        <div class="economy-health-row">
                            <span>Marketplace depth</span>
                            <strong class="@GetMarketplaceHealthClass()">@GetMarketplaceHealthLabel()</strong>
                        </div>
                        <div class="economy-health-row">
                            <span>Governance</span>
                            <strong class="@GetGovernanceHealthClass()">@GetGovernanceHealthLabel()</strong>
                        </div>
                    </div>
                </article>
            </section>

            <section class="panel profile-release-panel economy-faq">
                <div class="panel-heading">
                    <div>
                        <span class="profile-eyebrow">Economy FAQ</span>
                        <h2>Quick Guide</h2>
                    </div>
                </div>
                <details class="economy-faq-collapsible">
                    <summary>How to read this tab</summary>
                    <ol class="staking-faq-list">
                        <li>MN circulation shows player-held balance and bank-held reserve.</li>
                        <li>Map circulation shows listed, staked, and currently unlisted maps.</li>
                        <li>Activity uses two windows: online now and active in the last 24 hours.</li>
                        <li>Market signals track listing value, average listing price, and governance spend.</li>
                        <li>Use Marketplace, Staking, and Voting subtabs to take direct action from here.</li>
                    </ol>
                    @if (!string.IsNullOrWhiteSpace(Overview?.GeneratedAt))
                    {
                        <p class="economy-card-footnote">Snapshot generated @FormatTimestamp(Overview.GeneratedAt).</p>
                    }
                </details>
            </section>
        }
        else if (ActiveTab == MarketplaceTab)
        {
            <Marketplace Embedded="true" />
        }
        else if (ActiveTab == StakingTab)
        {
            <Staking Embedded="true" />
        }
        else
        {
            <Voting Embedded="true" />
        }
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "tab")] public string? Tab { get; set; }

    private const string OverviewTab = "overview";
    private const string MarketplaceTab = "marketplace";
    private const string StakingTab = "staking";
    private const string VotingTab = "voting";

    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private EconomyOverviewData? Overview { get; set; }
    private LoginUserSummary? Session { get; set; }
    private string ActiveTab { get; set; } = OverviewTab;
    private CancellationTokenSource? _pollCancellation;
    private Task? _pollTask;
    private bool _loadingOverview;
    private string? _lastOverviewSnapshotAt;
    private bool _economyTutorialInteractionReported;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        StartPolling();
    }

    protected override void OnParametersSet()
    {
        ActiveTab = NormalizeTab(Tab);
    }

    private async Task ReloadAsync()
    {
        await ReportEconomyTutorialInteractionAsync();
        await LoadAsync(silent: false);
    }

    private void StartPolling()
    {
        if (_pollTask is not null)
        {
            return;
        }

        _pollCancellation = new CancellationTokenSource();
        _pollTask = PollLoopAsync(_pollCancellation.Token);
    }

    private async Task PollLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (cancellationToken.IsCancellationRequested || !string.Equals(ActiveTab, OverviewTab, StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                await LoadAsync(silent: true);
            }
        }
        catch (OperationCanceledException)
        {
            // ignored
        }
    }

    private async Task LoadAsync(bool silent = false)
    {
        if (_loadingOverview)
        {
            return;
        }

        _loadingOverview = true;
        if (!silent)
        {
            IsLoading = true;
            ErrorMessage = null;
            await InvokeAsync(StateHasChanged);
        }

        try
        {
            var payload = await Api.GetFromJsonAsync<EconomyOverviewResponse>("api/auth/economy/overview");
            if (payload is null || payload.Overview is null)
            {
                throw new InvalidOperationException("Unable to load economy overview.");
            }

            Overview = payload.Overview;
            Session = payload.User ?? await Api.GetSessionAsync();
            await SyncClientSessionAsync(payload.User);

            if (!silent)
            {
                ErrorMessage = null;
            }
            else
            {
                var nextSnapshot = (payload.Overview.GeneratedAt ?? string.Empty).Trim();
                if (!string.IsNullOrWhiteSpace(nextSnapshot) && !string.Equals(_lastOverviewSnapshotAt, nextSnapshot, StringComparison.Ordinal))
                {
                    _lastOverviewSnapshotAt = nextSnapshot;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (Exception ex)
        {
            if (!silent)
            {
                ErrorMessage = ex.Message;
                Notifications.Warning(ErrorMessage);
            }
        }
        finally
        {
            IsLoading = false;
            if (!silent)
            {
                await InvokeAsync(StateHasChanged);
            }

            _loadingOverview = false;
        }
    }

    private void SetActiveTab(string tab)
    {
        var normalized = NormalizeTab(tab);
        if (string.Equals(ActiveTab, normalized, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _ = ReportEconomyTutorialInteractionAsync();
        ActiveTab = normalized;
        var target = normalized == OverviewTab ? "/economy" : $"/economy?tab={normalized}";
        NavigationManager.NavigateTo(target, replace: true);
    }

    private async Task ReportEconomyTutorialInteractionAsync()
    {
        if (_economyTutorialInteractionReported)
        {
            return;
        }

        _economyTutorialInteractionReported = true;
        try
        {
            await JS.InvokeVoidAsync("enigmaGame.reportTutorialObjective", "tutorial-economy-interacted");
        }
        catch (JSException)
        {
        }
    }

    private static string NormalizeTab(string? tab)
    {
        return (tab ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            MarketplaceTab => MarketplaceTab,
            StakingTab => StakingTab,
            VotingTab => VotingTab,
            _ => OverviewTab,
        };
    }

    private string GetTabClass(string tab)
    {
        return string.Equals(ActiveTab, tab, StringComparison.OrdinalIgnoreCase) ? "profile-tab active" : "profile-tab";
    }

    private async Task SyncClientSessionAsync(LoginUserSummary? session)
    {
        if (session is null)
        {
            return;
        }

        await JS.InvokeVoidAsync("enigmaGame.refreshUserSession", session);
        await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new Enigma.Client.Models.Gameplay.PlayerIdentity { Username = session.Username }, false);
    }

    private static string FormatTimestamp(string? isoUtc)
    {
        if (string.IsNullOrWhiteSpace(isoUtc))
        {
            return "Unknown";
        }

        return DateTimeOffset.TryParse(isoUtc, out var parsed)
            ? parsed.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
            : isoUtc;
    }

    private long GetMnTotal() => Math.Max(0L, (Overview?.MnPlayerWalletsTotal ?? 0L) + (Overview?.MnBankReserveTotal ?? 0L));

    private double GetMnWalletShare()
    {
        var total = GetMnTotal();
        return total <= 0 ? 0 : ((Overview?.MnPlayerWalletsTotal ?? 0L) * 100.0 / total);
    }

    private double GetMnBankShare()
    {
        var total = GetMnTotal();
        return total <= 0 ? 0 : ((Overview?.MnBankReserveTotal ?? 0L) * 100.0 / total);
    }

    private string GetMnDonutStyle()
    {
        var walletShare = Math.Clamp(GetMnWalletShare(), 0, 100);
        return $"--slice-a:{walletShare.ToString("0.##", CultureInfo.InvariantCulture)};";
    }

    private (int ListedCount, int StakedCount, int UnlistedCount, double ListedShare, double StakedShare, double UnlistedShare) GetMapDistribution()
    {
        var total = Math.Max(0, Overview?.MapsTotal ?? 0);
        var listed = Math.Max(0, Overview?.MapsListed ?? 0);
        var staked = Math.Max(0, Overview?.MapsStaked ?? 0);
        var unlisted = Math.Max(0, total - listed - staked);
        var distributionTotal = listed + staked + unlisted;
        if (distributionTotal <= 0)
        {
            return (0, 0, 0, 0, 0, 100);
        }

        var listedShare = listed * 100.0 / distributionTotal;
        var stakedShare = staked * 100.0 / distributionTotal;
        var unlistedShare = Math.Max(0, 100 - listedShare - stakedShare);
        return (listed, staked, unlisted, listedShare, stakedShare, unlistedShare);
    }

    private int GetMapListedCount() => GetMapDistribution().ListedCount;
    private int GetMapStakedCount() => GetMapDistribution().StakedCount;
    private int GetMapUnlistedCount() => GetMapDistribution().UnlistedCount;
    private double GetMapListedShare() => GetMapDistribution().ListedShare;
    private double GetMapStakedShare() => GetMapDistribution().StakedShare;
    private double GetMapUnlistedShare() => GetMapDistribution().UnlistedShare;

    private string GetMapDonutStyle()
    {
        var distribution = GetMapDistribution();
        return
            $"--slice-a:{Math.Clamp(distribution.ListedShare, 0, 100).ToString("0.##", CultureInfo.InvariantCulture)};" +
            $"--slice-b:{Math.Clamp(distribution.StakedShare, 0, 100).ToString("0.##", CultureInfo.InvariantCulture)};";
    }

    private static string GetProgressStyle(double value)
    {
        var width = Math.Clamp(value, 0, 100);
        return $"width:{width.ToString("0.##", CultureInfo.InvariantCulture)}%;";
    }

    private double GetOnlineShare()
    {
        var total = Math.Max(0, Overview?.UsersTotal ?? 0);
        if (total == 0)
        {
            return 0;
        }

        return Math.Clamp((Overview?.UsersOnlineNow ?? 0) * 100.0 / total, 0, 100);
    }

    private double GetActiveShare()
    {
        var total = Math.Max(0, Overview?.UsersTotal ?? 0);
        if (total == 0)
        {
            return 0;
        }

        return Math.Clamp((Overview?.UsersActive24h ?? 0) * 100.0 / total, 0, 100);
    }

    private double GetListingValueShareOfSupply()
    {
        var listingValue = Math.Max(0L, Overview?.MarketplaceListingValueTotal ?? 0L);
        var totalSupply = Math.Max(0L, Overview?.MnTotalKnown ?? 0L);
        if (totalSupply <= 0)
        {
            return 0;
        }

        return Math.Clamp((listingValue * 100.0) / totalSupply, 0, 100);
    }

    private string GetGovernanceSpendLabel()
    {
        var mnSpent = Math.Max(0L, Overview?.GovernanceTotalMnSpent ?? 0L);
        if (mnSpent <= 0)
        {
            return "No MN committed yet";
        }

        var supplyShare = GetGovernanceSpendShareOfSupply();
        return $"{supplyShare.ToString("0.##")}% of known MN supply";
    }

    private double GetGovernanceSpendShareOfSupply()
    {
        var mnSpent = Math.Max(0L, Overview?.GovernanceTotalMnSpent ?? 0L);
        var totalSupply = Math.Max(0L, Overview?.MnTotalKnown ?? 0L);
        if (mnSpent <= 0 || totalSupply <= 0)
        {
            return 0;
        }

        return Math.Clamp((mnSpent * 100.0) / totalSupply, 0, 100);
    }

    private string GetGovernanceSessionLabel()
    {
        if (Overview?.GovernanceVotingOpen == true && !string.IsNullOrWhiteSpace(Overview.GovernanceActiveTitle))
        {
            return $"Live: {Overview.GovernanceActiveTitle}";
        }

        return Overview?.GovernanceVotingOpen == true
            ? "Council meeting is active"
            : "Come back when The council is meeting.";
    }

    private string GetLiquidityHealthLabel()
    {
        var listedPercent = Math.Max(0, Overview?.MapsListedPercent ?? 0);
        return listedPercent switch
        {
            >= 18 => "Good",
            >= 8 => "Moderate",
            _ => "Low",
        };
    }

    private string GetLiquidityHealthClass() => GetHealthClass(GetLiquidityHealthLabel());

    private string GetActivityHealthLabel()
    {
        var activeShare = GetActiveShare();
        return activeShare switch
        {
            >= 35 => "Strong",
            >= 15 => "Moderate",
            _ => "Low",
        };
    }

    private string GetActivityHealthClass() => GetHealthClass(GetActivityHealthLabel());

    private string GetMarketplaceHealthLabel()
    {
        var listingValue = Math.Max(0L, Overview?.MarketplaceListingValueTotal ?? 0L);
        var listedMaps = Math.Max(0, Overview?.MapsListed ?? 0);
        if (listingValue >= 10000 && listedMaps >= 10)
        {
            return "Strong";
        }

        if (listingValue >= 1500 || listedMaps >= 4)
        {
            return "Moderate";
        }

        return "Light";
    }

    private string GetMarketplaceHealthClass() => GetHealthClass(GetMarketplaceHealthLabel());

    private string GetGovernanceHealthLabel() => Overview?.GovernanceVotingOpen == true ? "Council Meeting Live" : "Awaiting Council";

    private string GetGovernanceHealthClass() => Overview?.GovernanceVotingOpen == true ? "economy-health-status good" : "economy-health-status low";

    private static string GetHealthClass(string value)
    {
        return value switch
        {
            "Good" or "Strong" => "economy-health-status good",
            "Moderate" => "economy-health-status steady",
            _ => "economy-health-status low",
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (_pollCancellation is null)
        {
            return;
        }

        try
        {
            await _pollCancellation.CancelAsync();
        }
        catch
        {
            // ignored
        }

        if (_pollTask is not null)
        {
            try
            {
                await _pollTask;
            }
            catch (OperationCanceledException)
            {
                // ignored
            }
        }

        _pollCancellation.Dispose();
        _pollCancellation = null;
    }
}

