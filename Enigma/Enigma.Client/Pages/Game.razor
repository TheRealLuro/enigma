@page "/game"
@using Enigma.Client.Models.Gameplay
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Routing

<SeoHead Title="Enigma Live Expedition | Active Sector Session"
         Description="Play an active Enigma sector expedition with room-based puzzles, movement, and in-room interaction."
         Robots="noindex,nofollow"
         OpenGraphType="website"
         SchemaType="WebPage" />

@if (!string.IsNullOrWhiteSpace(LoadError))
{
    <div class="content">
        <div class="card enigma-game-message">
            <h1>Expedition Unavailable</h1>
            <p>@LoadError</p>
            <button class="btn btn-primary" @onclick='@(() => NavigationManager.NavigateTo("/play"))'>Return to Expeditions</button>
        </div>
    </div>
}
else if (!IsLoaded || !CanShowRoom)
{
    <div class="content">
        <div class="card enigma-game-message">
            <div class="loader"></div>
            <p>Entering anomaly...</p>
        </div>
    </div>
}
else
{
    <div class="enigma-game-page" data-tour-id="game-shell">
        <NavigationLock OnBeforeInternalNavigation="HandleBeforeInternalNavigation" ConfirmExternalNavigation="true" />
        <section class="enigma-game-shell" data-tour-id="game-stage">
            <div class="enigma-room-stage-wrap">
                <div id="@GameSurfaceId"
                     tabindex="0"
                     class="enigma-room-stage"
                     style="@GetRoomStageStyle()">
                        @foreach (var segment in GetWallSegments())
                        {
                            <div class="enigma-wall @segment.CssClass" style="@segment.Style"></div>
                        }
                        <div class="enigma-radar-darkness @(IsRadarInterferenceVisible ? "interference" : string.Empty)" aria-hidden="true"></div>
                        <div class="enigma-radar-pulse @(IsRadarInterferenceVisible ? "interference" : string.Empty)" aria-hidden="true"></div>

                        @if (IsCoopRun && HasCoopStageElements)
                        {
                            @foreach (var stageElement in GetCoopStageElements())
                            {
                                <div class="@GetCoopStageElementClass(stageElement)" style="@GetCoopStageElementStyle(stageElement)">
                                    <span>@stageElement.Label</span>
                                </div>
                            }
                        }
                        else if (CurrentRoomState!.Puzzle is IWorldInteractivePuzzle)
                        {
                            @foreach (var interactable in GetWorldInteractablesForRender())
                            {
                                var currentInteractable = interactable;
                                var renderLabel = GetWorldInteractableRenderLabel(currentInteractable);
                                @if (currentInteractable.Clickable)
                                {
                                    <button type="button"
                                            class="@GetWorldInteractableClass(currentInteractable)"
                                            style="@GetWorldInteractableStyle(currentInteractable)"
                                            title="@GetWorldInteractableTooltip(currentInteractable)"
                                            aria-label="@GetWorldInteractableTooltip(currentInteractable)"
                                            disabled="@(!CanClickWorldInteractable(currentInteractable))"
                                            @onclick="(() => InteractWithWorldInteractable(currentInteractable.Id))">
                                        @if (!string.IsNullOrWhiteSpace(renderLabel))
                                        {
                                            <span>@renderLabel</span>
                                        }
                                    </button>
                                }
                                else
                                {
                                    <div class="@GetWorldInteractableClass(currentInteractable)"
                                         style="@GetWorldInteractableStyle(currentInteractable)"
                                         aria-hidden="true">
                                        @if (!string.IsNullOrWhiteSpace(renderLabel))
                                        {
                                            <span>@renderLabel</span>
                                        }
                                    </div>
                                }
                            }
                        }

                        @if (CurrentRoomState!.RewardPickupVisible)
                        {
                            <div class="enigma-reward-pickup @GetRadarBandClass(CurrentRoomState.RewardPickupBounds, anomalySensitive: true)"
                                 style="@GetRectStyle(CurrentRoomState.RewardPickupBounds)"></div>
                        }

                        @if (CurrentRoomState!.FinishPortalVisible)
                        {
                            <div class="enigma-black-hole @GetRadarBandClass(CurrentRoomState.FinishPortalBounds, anomalySensitive: true)"
                                 style="@GetRectStyle(CurrentRoomState.FinishPortalBounds)"></div>
                        }

                        <div class="enigma-player @GetPlayerClass()" style="@GetPlayerStyle()"></div>
                        @if (ShowCarriedPayloadIndicator)
                        {
                            <div class="enigma-carried-payload" style="@GetCarriedPayloadStyle()">@GetCarriedPayloadLabel()</div>
                        }
                        @if (IsCoopRun && CoopOtherPlayer is not null)
                        {
                            <div class="enigma-player @GetOtherPlayerClass()" style="@GetOtherPlayerStyle()"></div>
                            <div class="enigma-player-tag partner-tag" style="@GetOtherPlayerTagStyle()">@CoopOtherPlayer.Username</div>
                        }

                        <div class="enigma-room-hud enigma-room-hud-right">Room: @RoomCoordinateLabel</div>
                        <div class="enigma-room-hud enigma-room-hud-left">@CurrentRoom!.Kind</div>
                        @if (!string.IsNullOrWhiteSpace(StatusBanner))
                        {
                            <div class="enigma-room-banner">@StatusBanner</div>
                        }

                        @if (CanInteractWithPuzzleConsole)
                        {
                            @foreach (var puzzleConsole in GetActivePuzzleConsoles())
                            {
                                if (puzzleConsole.IsLocal)
                                {
                                    <button type="button"
                                            class="enigma-puzzle-console console-blue @GetRadarBandClass(puzzleConsole.Bounds, anomalySensitive: true) @(IsNearPuzzleConsole() ? "nearby" : string.Empty)"
                                            style="@GetRectStyle(puzzleConsole.Bounds)"
                                            @onclick="OpenPuzzleOverlay">
                                        <span class="enigma-puzzle-console-screen"></span>
                                        <span class="enigma-puzzle-console-base"></span>
                                    </button>
                                }
                                else
                                {
                                    <div class="enigma-puzzle-console console-red partner-console @GetRadarBandClass(puzzleConsole.Bounds, anomalySensitive: true)"
                                         style="@GetRectStyle(puzzleConsole.Bounds)"
                                         aria-hidden="true">
                                        <span class="enigma-puzzle-console-screen"></span>
                                        <span class="enigma-puzzle-console-base"></span>
                                    </div>
                                }
                            }

                            @if (IsNearPuzzleConsole())
                            {
                                <div class="enigma-console-prompt" style="@GetPuzzleConsolePromptStyle()">@PuzzleConsolePromptText</div>
                            }
                        }

                        @if (ShowWorldActionPrompt)
                        {
                            <div class="@GetWorldActionPromptClass()" style="@GetWorldActionPromptStyle()">@GetWorldActionPromptText()</div>
                        }

                        @if (ShowRoomInteractionProgress)
                        {
                            <div class="enigma-room-interaction-progress" style="@GetRoomInteractionProgressStyle()">
                                <span class="enigma-room-interaction-progress-label">@GetRoomInteractionProgressLabel()</span>
                                <div class="enigma-room-interaction-progress-track">
                                    <div class="enigma-room-interaction-progress-fill" style="@GetRoomInteractionProgressFillStyle()"></div>
                                </div>
                            </div>
                        }

                    <div class="enigma-stage-run-status">
                        <div class="enigma-stage-run-head">
                            <span class="enigma-kicker">Expedition Status</span>
                            <span class="enigma-stage-goal">@(PortalReady ? "Enter the black hole" : "Solve and move")</span>
                        </div>
                        <div class="enigma-stage-run-grid">
                            <div>
                                <span>Difficulty</span>
                                <strong>@DifficultyLabel</strong>
                            </div>
                            <div>
                                <span>Size</span>
                                <strong>@ParsedSeed!.Size x @ParsedSeed.Size</strong>
                            </div>
                            <div>
                                <span>Elapsed</span>
                                <strong class="mono-numeric">@ElapsedTimeLabel</strong>
                            </div>
                            <div>
                                <span>Expedition Total</span>
                                <strong class="mono-numeric">@TotalGold.ToString("N0") MN</strong>
                            </div>
                            <div>
                                <span>Solved</span>
                                <strong>@SolvedRoomCount / @TotalRoomCount</strong>
                            </div>
                            <div>
                                <span>State</span>
                                <strong>@(IsCurrentPuzzleSolved ? "Unlocked" : "Locked")</strong>
                            </div>
                        </div>
                        <div class="enigma-stage-run-items">
                            <span class="enigma-stage-run-items-label">Equipped</span>
                            @if (HasHotkeyUsableItems)
                            {
                                <span class="enigma-stage-run-hotkey-hint">Hotkeys: 1-3</span>
                            }
                            @if (EquippedLoadout.Count == 0)
                            {
                                <div class="enigma-stage-run-empty">No items equipped.</div>
                            }
                            else
                            {
                                <div class="enigma-stage-run-pill-list">
                                    @foreach (var item in GetVisibleLoadoutItems())
                                    {
                                        <div class="enigma-stage-run-pill">
                                            <strong>@item.Name</strong>
                                            <span class="enigma-loadout-count">@($"x{item.Quantity}")</span>
                                            @if (CanActivateLoadoutItem(item))
                                            {
                                                <button type="button"
                                                        class="enigma-item-use-button"
                                                        disabled="@(!CanUseLoadoutItem(item))"
                                                        @onclick="() => UseLoadoutItemFromUiAsync(item.ItemId)">
                                                    <span>Use</span>
                                                    <kbd>@GetLoadoutHotkeyLabel(item)</kbd>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="enigma-item-passive-tag">Passive</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (IsPuzzleOverlayOpen)
            {
            <div class="enigma-puzzle-overlay-backdrop" @onclick="ClosePuzzleOverlay">
            <aside class="enigma-sidebar enigma-puzzle-overlay-shell" @onclick:stopPropagation="true">
                <button type="button" class="enigma-overlay-close" @onclick="ClosePuzzleOverlay">Close</button>
                <div class="enigma-sidebar-summary">
                    <div class="card enigma-sidebar-card enigma-status-card">
                        <div class="enigma-sidebar-card-head">
                            <span class="enigma-kicker">Expedition Status</span>
                            <span class="enigma-status-goal">@(PortalReady ? "Enter the black hole" : "Solve and move")</span>
                        </div>
                        <div class="enigma-status-metrics">
                            <div class="enigma-status-metric">
                                <span>Solved Rooms</span>
                                <strong>@SolvedRoomCount / @TotalRoomCount</strong>
                            </div>
                            <div class="enigma-status-metric">
                                <span>Explorer</span>
                                <strong>@Username</strong>
                            </div>
                            <div class="enigma-status-metric">
                                <span>Room State</span>
                                <strong>@((IsCoopRun ? IsCurrentCoopRoomSolved : CurrentRoomState.Puzzle.IsCompleted) ? "Unlocked" : "Locked")</strong>
                            </div>
                            <div class="enigma-status-metric">
                                <span>Expedition Total</span>
                                <strong>@TotalGold.ToString("N0") MN</strong>
                            </div>
                        </div>
                        <div class="enigma-status-loadout">
                            <span class="enigma-status-section-label">Equipped Items</span>
                            @if (HasHotkeyUsableItems)
                            {
                                <span class="enigma-stage-run-hotkey-hint">Hotkeys: 1-3</span>
                            }
                            @if (EquippedLoadout.Count == 0)
                            {
                                <div class="enigma-status-empty">No items equipped for this expedition.</div>
                            }
                            else
                            {
                                <div class="enigma-status-loadout-list">
                                    @foreach (var item in GetVisibleLoadoutItems())
                                    {
                                        <div class="enigma-status-loadout-pill">
                                            <strong>@item.Name</strong>
                                            <span class="enigma-loadout-count">@($"x{item.Quantity}")</span>
                                            @if (CanActivateLoadoutItem(item))
                                            {
                                                <button type="button"
                                                        class="enigma-item-use-button"
                                                        disabled="@(!CanUseLoadoutItem(item))"
                                                        @onclick="() => UseLoadoutItemFromUiAsync(item.ItemId)">
                                                    <span>Use</span>
                                                    <kbd>@GetLoadoutHotkeyLabel(item)</kbd>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="enigma-item-passive-tag">Passive</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                @if (IsCoopRun)
                {
                    <div class="card enigma-sidebar-card enigma-coop-card">
                        <span class="enigma-kicker">Co-op Link</span>
                        <h2>@CoopPartnerName</h2>
                        <div class="enigma-stat-grid">
                            <div>
                                <span>Session</span>
                                <strong>@(CoopSession?.SessionId ?? "Unknown")</strong>
                            </div>
                            <div>
                                <span>Status</span>
                                <strong>@CoopStatusLabel</strong>
                            </div>
                            <div>
                                <span>Partner Visible</span>
                                <strong>@(CoopOtherPlayer is null ? "No" : "Yes")</strong>
                            </div>
                            <div>
                                <span>Transport</span>
                                <strong>@(IsCoopSocketOpen ? "Socket" : "HTTP fallback")</strong>
                            </div>
                            <div>
                                <span>Vote</span>
                                <strong>@GetCoopVoteLabel()</strong>
                            </div>
                        </div>
                    </div>
                }
                </div>

                <div class="card enigma-sidebar-card enigma-puzzle-card @(HasCoopPuzzle ? string.Empty : CurrentRoomState.Puzzle is ISoloPanelPuzzle ? "enigma-puzzle-card-solo" : string.Empty)">
                    @if (HasCoopPuzzle)
                    {
                        <div class="enigma-puzzle-head enigma-puzzle-head-clean">
                            <span class="enigma-kicker">Co-op Puzzle</span>
                            <h2>@CurrentCoopPuzzle!.Name</h2>
                        </div>
                        <div class="enigma-puzzle-status">@CurrentCoopPuzzle.Status</div>

                        @if (!string.IsNullOrWhiteSpace(GetCoopClueText()))
                        {
                            <p class="enigma-helper">@GetCoopClueText()</p>
                        }

                        <div class="enigma-puzzle-surface">
                        @if (IsCoopPuzzleV2 && HasCoopV2Board())
                        {
                            @switch (GetCoopV2FamilyId())
                            {
                                case "split_signal":
                                case "echo_sync":
                                case "tidal_lock":
                                    <CoopSignalPanel View="CurrentCoopPuzzle!.View"
                                                     FamilyId="GetCoopV2FamilyId()"
                                                     OnCommand="TriggerCoopV2ActionAsync" />
                                    break;
                                case "pressure_exchange":
                                case "flood_control":
                                case "gravity_tandem":
                                case "strata_shift":
                                    <CoopSystemsPanel View="CurrentCoopPuzzle!.View"
                                                      FamilyId="GetCoopV2FamilyId()"
                                                      OnCommand="TriggerCoopV2ActionAsync" />
                                    break;
                                case "bridge_builder":
                                case "temporal_weave":
                                    <CoopTopologyPanel View="CurrentCoopPuzzle!.View"
                                                       FamilyId="GetCoopV2FamilyId()"
                                                       OnCommand="TriggerCoopV2ActionAsync" />
                                    break;
                                case "mirror_minds":
                                    <CoopDeductionPanel View="CurrentCoopPuzzle!.View"
                                                        FamilyId="GetCoopV2FamilyId()"
                                                        OnCommand="TriggerCoopV2ActionAsync" />
                                    break;
                                case "cipher_relay":
                                    <CoopRelayPanel View="CurrentCoopPuzzle!.View"
                                                    FamilyId="GetCoopV2FamilyId()"
                                                    OnCommand="TriggerCoopV2ActionAsync" />
                                    break;
                                default:
                                    <div class="@GetCoopV2ShellClass()">
                                        <div class="enigma-coop-v2-header">
                                            <span class="enigma-coop-v2-family">@GetCoopV2FamilyId().Replace('_', ' ')</span>
                                            <span class="enigma-coop-v2-phase">@GetCoopV2PhaseText().Replace('_', ' ')</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(GetCoopV2FailureLabel()))
                                        {
                                            <div class="enigma-coop-v2-failure">
                                                <strong>@GetCoopV2FailureLabel()</strong>
                                                @if (!string.IsNullOrWhiteSpace(GetCoopV2FailureVisualCue()))
                                                {
                                                    <span>@GetCoopV2FailureVisualCue()</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(GetCoopV2RecoveryText()))
                                                {
                                                    <small>@GetCoopV2RecoveryText()</small>
                                                }
                                            </div>
                                        }
                                        <div class="enigma-coop-v2-status">@GetCoopV2StatusText()</div>
                                        <div class="enigma-coop-v2-prompt">@GetCoopV2PromptText()</div>
                                        <div class="enigma-progress-shell enigma-coop-v2-progress">
                                            <div class="enigma-progress-bar" style="width: @(GetCoopV2ProgressPercent())%;"></div>
                                        </div>
                                        <div class="enigma-coop-v2-progress-axis @GetCoopV2ProgressTrendClass()">
                                            <span>@GetCoopV2ProgressLabel()</span>
                                            <strong>@($"{GetCoopV2ProgressPercent()}%")</strong>
                                            <small>@GetCoopV2ProgressTrend()</small>
                                        </div>
                                        <div class="enigma-coop-v2-hud-grid">
                                            @foreach (var hud in GetCoopV2HudItems())
                                            {
                                                <div class="enigma-coop-v2-hud-item">
                                                    <span class="enigma-coop-v2-hud-icon">@GetCoopV2IconGlyph(hud.Icon)</span>
                                                    <span class="enigma-coop-v2-hud-label">@hud.Label</span>
                                                    <strong>@hud.Value</strong>
                                                </div>
                                            }
                                        </div>
                                        <div class="enigma-coop-v2-action-grid">
                                            @foreach (var action in GetCoopV2Actions())
                                            {
                                                var command = action.Command;
                                                <button class="@GetCoopV2ActionClass(action)" @onclick="(() => TriggerCoopV2ActionAsync(command))" disabled="@(!action.Enabled)">
                                                    <span class="enigma-coop-v2-action-icon">@GetCoopV2IconGlyph(action.Icon)</span>
                                                    <span>@action.Label</span>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                    break;
                            }
                        }
                        else if (IsCoopPuzzleV2)
                        {
                            <div class="@GetCoopV2ShellClass()">
                                <div class="enigma-coop-v2-header">
                                    <span class="enigma-coop-v2-family">@GetCoopV2FamilyId().Replace('_', ' ')</span>
                                    <span class="enigma-coop-v2-phase">@GetCoopV2PhaseText().Replace('_', ' ')</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(GetCoopV2FailureLabel()))
                                {
                                    <div class="enigma-coop-v2-failure">
                                        <strong>@GetCoopV2FailureLabel()</strong>
                                        @if (!string.IsNullOrWhiteSpace(GetCoopV2FailureVisualCue()))
                                        {
                                            <span>@GetCoopV2FailureVisualCue()</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(GetCoopV2RecoveryText()))
                                        {
                                            <small>@GetCoopV2RecoveryText()</small>
                                        }
                                    </div>
                                }
                                <div class="enigma-coop-v2-status">@GetCoopV2StatusText()</div>
                                <div class="enigma-coop-v2-prompt">@GetCoopV2PromptText()</div>
                                <div class="enigma-progress-shell enigma-coop-v2-progress">
                                    <div class="enigma-progress-bar" style="width: @(GetCoopV2ProgressPercent())%;"></div>
                                </div>
                                <div class="enigma-coop-v2-progress-axis @GetCoopV2ProgressTrendClass()">
                                    <span>@GetCoopV2ProgressLabel()</span>
                                    <strong>@($"{GetCoopV2ProgressPercent()}%")</strong>
                                    <small>@GetCoopV2ProgressTrend()</small>
                                </div>
                                <div class="enigma-coop-v2-hud-grid">
                                    @foreach (var hud in GetCoopV2HudItems())
                                    {
                                        <div class="enigma-coop-v2-hud-item">
                                            <span class="enigma-coop-v2-hud-icon">@GetCoopV2IconGlyph(hud.Icon)</span>
                                            <span class="enigma-coop-v2-hud-label">@hud.Label</span>
                                            <strong>@hud.Value</strong>
                                        </div>
                                    }
                                </div>
                                <div class="enigma-coop-v2-action-grid">
                                    @foreach (var action in GetCoopV2Actions())
                                    {
                                        var command = action.Command;
                                        <button class="@GetCoopV2ActionClass(action)" @onclick="(() => TriggerCoopV2ActionAsync(command))" disabled="@(!action.Enabled)">
                                            <span class="enigma-coop-v2-action-icon">@GetCoopV2IconGlyph(action.Icon)</span>
                                            <span>@action.Label</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "pressure_systems", StringComparison.OrdinalIgnoreCase))
                        {
                        <div class="enigma-mini-stat-grid">
                            <div class="enigma-mini-stat">
                                <span>Phase</span>
                                <strong>@(GetCoopViewInt("phase_index", 0) + 1) / @GetCoopViewInt("phase_count", 1)</strong>
                                </div>
                                <div class="enigma-mini-stat">
                                <span>Hold</span>
                                <strong>@($"{GetCoopViewDouble("hold_seconds", 0.8):0.0}s")</strong>
                            </div>
                        </div>
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "sync_reaction", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="enigma-timing-track">
                                @if (CoopShowTarget)
                                {
                                    <div class="enigma-timing-window" style="left: @(Math.Round(CoopTargetStart * 100d, 2))%; width: @(Math.Round(CoopTargetWidth * 100d, 2))%;"></div>
                                }
                                @if (CoopShowPulse)
                                {
                                    <div class="enigma-timing-marker" style="left: @(Math.Round(GetCoopPulseMeter() * 100d, 2))%;"></div>
                                }
                            </div>
                            <div class="enigma-direction-grid">
                                <button class="btn @(CoopSelfLocked ? "btn-success" : "btn-primary")" @onclick="LockCoopReactionAsync">Lock Now</button>
                                <div class="enigma-mini-stat">
                                    <span>Partner</span>
                                    <strong>@(CoopPartnerLocked ? "Locked" : "Waiting")</strong>
                                </div>
                            </div>
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "deduction_riddle", StringComparison.OrdinalIgnoreCase))
                        {
                            @if (!string.IsNullOrWhiteSpace(GetCoopRiddlePrompt()))
                            {
                                <p class="enigma-helper">@GetCoopRiddlePrompt()</p>
                            }
                            @foreach (var clue in GetCoopRiddleClues())
                            {
                                <div class="enigma-statement">@clue</div>
                            }
                            <div class="enigma-option-grid">
                                @for (var index = 0; index < GetCoopRiddleOptions().Count; index++)
                                {
                                    var optionIndex = index;
                                    var isSelected = GetCoopSelectedOption("selected_self") == optionIndex;
                                    <button class="btn @(isSelected ? "btn-primary" : "btn-secondary")" @onclick="(() => SelectCoopRiddleOptionAsync(optionIndex))">@GetCoopRiddleOptions()[index]</button>
                                }
                            </div>
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "split_memory", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="enigma-sequence-display compact">
                                @foreach (var symbol in GetCoopMemoryVisibleSequence())
                                {
                                    <span>@symbol</span>
                                }
                            </div>
                            <p class="enigma-helper">Entered: @(GetCoopMemoryInput().Count == 0 ? "none" : string.Join(" ", GetCoopMemoryInput()))</p>
                            <p class="enigma-helper">Turn: @GetCoopMemoryNextRole() side</p>
                            <div class="enigma-option-grid compact">
                                @foreach (var symbol in GetCoopMemorySymbols())
                                {
                                    var currentSymbol = symbol;
                                    <button class="btn btn-secondary" @onclick="(() => PressCoopMemorySymbolAsync(currentSymbol))">@currentSymbol</button>
                                }
                            </div>
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "dual_rotation", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="coop-rotation-shell">
                                <div class="enigma-mini-stat-grid">
                                    <div class="enigma-mini-stat">
                                        <span>Perspective</span>
                                        <strong>@(GetCoopBoardRotation() == 0 ? "Aligned" : $"Rotated {GetCoopBoardRotation() * 90} deg")</strong>
                                    </div>
                                    <div class="enigma-mini-stat">
                                        <span>Palette</span>
                                        <strong>Blue / Red</strong>
                                    </div>
                                </div>
                                <div class="coop-rotation-board" style="grid-template-columns: repeat(@GetCoopRotationCols(), minmax(0, 1fr));">
                                    @foreach (var tile in GetCoopRotationTiles().OrderBy(tile => tile.Row).ThenBy(tile => tile.Col))
                                    {
                                        var tileId = tile.Id;
                                        <button class="@GetCoopRotationTileClass(tile)" @onclick="(() => RotateCoopTileAsync(tileId))" disabled="@(!tile.Controllable)">
                                            <span class="enigma-tile-arrow">@GetRotationGlyph(tile.DisplayRotation)</span>
                                            <span class="enigma-rotation-target">Target: @GetRotationGlyph(tile.Target)</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "opposing_pattern_input", StringComparison.OrdinalIgnoreCase))
                        {
                            <p class="enigma-helper">@GetCoopPatternClue()</p>
                            <div class="enigma-sequence-display enigma-direction-sequence">
                                @foreach (var direction in GetCoopPatternInput())
                                {
                                    <span class="enigma-direction-token visible">@direction</span>
                                }
                            </div>
                            <div class="enigma-direction-grid">
                                <button class="btn btn-secondary" @onclick="(() => PressCoopDirectionAsync(PlayerDirection.Up))">Up</button>
                                <button class="btn btn-secondary" @onclick="(() => PressCoopDirectionAsync(PlayerDirection.Left))">Left</button>
                                <button class="btn btn-secondary" @onclick="(() => PressCoopDirectionAsync(PlayerDirection.Down))">Down</button>
                                <button class="btn btn-secondary" @onclick="(() => PressCoopDirectionAsync(PlayerDirection.Right))">Right</button>
                            </div>
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "flow_transfer", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="enigma-option-grid compact">
                                @for (var index = 0; index < GetCoopIntList("values").Count; index++)
                                {
                                    <div class="enigma-mini-stat">
                                        <span>Output @(index + 1)</span>
                                        <strong>@GetCoopIntList("values")[index] / @GetCoopIntList("targets")[index]</strong>
                                    </div>
                                }
                            </div>
                            <div class="enigma-option-grid compact enigma-flow-control-grid">
                                @foreach (var control in GetCoopFlowControls())
                                {
                                    var controlIndex = control.Index;
                                    <button class="btn btn-secondary enigma-control-button" @onclick="(() => PulseCoopFlowAsync(controlIndex))">
                                        <strong>@control.Label</strong>
                                        <small>@control.Detail</small>
                                    </button>
                                }
                            </div>
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "distributed_weight", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="enigma-mini-stat-grid">
                                <div class="enigma-mini-stat">
                                    <span>Current Total</span>
                                    <strong>@GetCoopViewInt("current_total", 0)</strong>
                                </div>
                                <div class="enigma-mini-stat">
                                    <span>Target</span>
                                    <strong>@GetCoopViewInt("target", 0)</strong>
                                </div>
                                <div class="enigma-mini-stat">
                                    <span>Pad Limit</span>
                                    <strong>@GetCoopViewInt("limit_per_pad", 3)</strong>
                                </div>
                            </div>
                            <div class="enigma-option-grid compact enigma-weight-grid">
                                @for (var index = 0; index < GetCoopIntList("allocations").Count; index++)
                                {
                                    var padIndex = index;
                                    <div class="enigma-mini-stat coop-weight-card">
                                        <span>Pad @(padIndex + 1) x@(GetCoopIntList("multipliers")[padIndex])</span>
                                        <strong>@GetCoopIntList("allocations")[padIndex]</strong>
                                        <div class="enigma-direction-grid">
                                            <button class="btn btn-secondary" @onclick="(() => AdjustCoopWeightAsync(padIndex, -1))">-</button>
                                            <button class="btn btn-secondary" @onclick="(() => AdjustCoopWeightAsync(padIndex, 1))">+</button>
                                        </div>
                                    </div>
                                }
                            </div>
                            <p class="enigma-helper">@GetCoopWeightRuleText()</p>
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "binary_echo", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="enigma-mini-stat-grid">
                                <div class="enigma-mini-stat">
                                    <span>Current</span>
                                    <strong class="mono-numeric">@GetBinaryString(GetCoopBoolList("current"))</strong>
                                </div>
                                <div class="enigma-mini-stat">
                                    <span>Target</span>
                                    <strong class="mono-numeric">@GetBinaryString(GetCoopBoolList("target"))</strong>
                                </div>
                            </div>
                            @if (string.Equals(GetCoopViewString("mode"), "toggle_bits", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="enigma-option-grid compact">
                                    @foreach (var bitIndex in GetCoopIntList("controls"))
                                    {
                                        var currentBitIndex = bitIndex;
                                        <button class="btn btn-secondary" @onclick="(() => ToggleCoopBitAsync(currentBitIndex))">Toggle bit @(currentBitIndex + 1)</button>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="enigma-option-grid compact">
                                    @foreach (var operation in GetCoopStringList("operations"))
                                    {
                                        var currentOperation = operation;
                                        <button class="btn btn-secondary" @onclick="(() => ApplyCoopBinaryOperationAsync(currentOperation))">@currentOperation.Replace('_', ' ')</button>
                                    }
                                </div>
                                @if (GetCoopViewInt("moves_remaining", -1) >= 0)
                                {
                                    <p class="enigma-helper">Moves remaining: @GetCoopViewInt("moves_remaining", 0)</p>
                                }
                            }
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "signal_lines", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="coop-signal-board">
                                <svg viewBox="0 0 100 100" class="coop-signal-svg" aria-hidden="true">
                                    @foreach (var line in GetCoopSignalLines())
                                    {
                                        <line x1="@line.StartX" y1="@line.StartY" x2="@line.EndX" y2="@line.EndY" class="@( $"coop-signal-line {line.CssClass}" )"></line>
                                    }
                                </svg>
                                @foreach (var node in GetCoopSignalNodes(isLeft: true))
                                {
                                    <div class="@( $"coop-signal-node left {(node.Controllable ? "controllable" : "partner")}" )" style="left: @($"{node.X}%"); top: @($"{node.Y}%");">
                                        <span>@node.Label</span>
                                        @if (node.RouteTo is not null)
                                        {
                                            <small>@GetCoopStringList("right_nodes")[node.RouteTo.Value]</small>
                                        }
                                    </div>
                                }
                                @foreach (var node in GetCoopSignalNodes(isLeft: false))
                                {
                                    <div class="coop-signal-node right" style="left: @($"{node.X}%"); top: @($"{node.Y}%");">
                                        <span>@node.Label</span>
                                    </div>
                                }
                            </div>
                            @for (var leftIndex = 0; leftIndex < GetCoopStringList("left_nodes").Count; leftIndex++)
                            {
                                if (!GetCoopIntList("controls").Contains(leftIndex))
                                {
                                    continue;
                                }

                                <div class="enigma-signal-row">
                                    <span>@GetCoopStringList("left_nodes")[leftIndex]</span>
                                    <div class="enigma-option-grid compact">
                                        @for (var rightIndex = 0; rightIndex < GetCoopStringList("right_nodes").Count; rightIndex++)
                                        {
                                            var currentRightIndex = rightIndex;
                                            var isSelected = GetCoopSignalSelectedRoute(leftIndex) == rightIndex;
                                            <button class="btn @(isSelected ? "btn-primary" : "btn-secondary")" @onclick="(() => RouteCoopSignalAsync(leftIndex, currentRightIndex))">@GetCoopStringList("right_nodes")[rightIndex]</button>
                                        }
                                    </div>
                                </div>
                            }
                            <p class="enigma-helper">@((GetCoopViewBool("real_routes_visible", false) ? "You see the real blocked routes." : "Some blocked routes on your board are decoys."))</p>
                        }
                        else if (string.Equals(CurrentCoopPuzzle.ViewType, "spatial_sync", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="enigma-mini-stat-grid">
                                <div class="enigma-mini-stat">
                                    <span>Step</span>
                                    <strong>@(GetCoopViewInt("step_index", 0) + 1) / @GetCoopViewInt("step_count", 1)</strong>
                                </div>
                                <div class="enigma-mini-stat">
                                    <span>Hold</span>
                                    <strong>@($"{GetCoopViewDouble("hold_seconds", 0.8):0.0}s")</strong>
                                </div>
                            </div>
                        }
                        </div>
                    }
                    else
                    {
                    @if (CurrentRoomState.Puzzle is not ISoloPanelPuzzle)
                    {
                        <div class="enigma-puzzle-head enigma-puzzle-head-clean">
                            <span class="enigma-kicker">Current Puzzle</span>
                            <h2>@CurrentRoomState.Puzzle.Title</h2>
                        </div>
                    }
                    @if (CurrentRoomState.Puzzle is IWorldInteractivePuzzle)
                    {
                        <div class="enigma-puzzle-status enigma-world-puzzle-status">
                            <strong>@GetWorldPuzzlePressEInstruction()</strong>
                            <span>@CurrentRoomState.Puzzle.StatusText</span>
                        </div>
                    }
                    else if (CurrentRoomState.Puzzle is ISoloPanelPuzzle)
                    {
                    }
                    else
                    {
                        <div class="enigma-puzzle-status">@CurrentRoomState.Puzzle.StatusText</div>
                    }

                    <div class="enigma-puzzle-surface">
                    @if (CurrentRoomState.Puzzle is ISoloPanelPuzzle soloPanelPuzzle)
                    {
                        var panelView = GetSoloPanelView(soloPanelPuzzle);
                        if (panelView is not null)
                        {
                            var dialKeys = GetSoloPanelDialKeys(panelView);
                            var cellActions = GetSoloPanelCellActions(panelView);
                            var pipeActions = GetSoloPanelPipeActions(panelView);
                            var cardActions = GetSoloPanelCardActions(panelView);
                            var systemActions = GetSoloPanelSystemActions(panelView);
                            <div class="enigma-solo-panel-shell @GetSoloPanelFamilyClass(panelView.FamilyId) @GetSoloPanelStageClass(panelView)"
                                 @onpointermove="HandleSoloDialDragMove"
                                 @onpointerup="EndSoloDialDrag"
                                 @onpointercancel="EndSoloDialDrag">
                                <div class="enigma-solo-panel-head">
                                    <div>
                                        <span class="enigma-kicker">@panelView.FamilyId.Replace('_', ' ')</span>
                                        <p class="enigma-solo-panel-subtitle">@CurrentRoomState.Puzzle.Instruction</p>
                                    </div>
                                    <span class="enigma-solo-panel-icon">@GetSoloPanelFamilyIcon(panelView.FamilyId)</span>
                                </div>
                                <div class="enigma-solo-panel-meta">
                                    <span class="enigma-solo-chip">Tier L@(panelView.TierLevel)</span>
                                    <span class="enigma-solo-chip">@panelView.Phase.ToString().ToLowerInvariant()</span>
                                    <span class="enigma-solo-chip @GetSoloPanelStatusClass(panelView.Status)">@panelView.Status.ToString().ToLowerInvariant()</span>
                                    @if (panelView.Board.TryGetValue("page", out var pageValue) && panelView.Board.TryGetValue("page_total", out var pageTotal))
                                    {
                                        <span class="enigma-solo-chip">Page @pageValue / @pageTotal</span>
                                    }
                                </div>
                                <div class="enigma-puzzle-status enigma-solo-panel-status @GetSoloPanelStatusClass(panelView.Status)">
                                    @panelView.StatusText
                                </div>
                                @if (!string.IsNullOrWhiteSpace(panelView.FailureLabel))
                                {
                                    <div class="enigma-solo-failure-card @GetSoloPanelFailureClass(panelView)">
                                        <strong>@panelView.FailureLabel</strong>
                                        <span>@panelView.RecoveryText</span>
                                    </div>
                                }
                                <div class="enigma-solo-progress-axis @GetSoloPanelProgressTrendClass(panelView)">
                                    <span>@GetSoloPanelProgressLabel(panelView)</span>
                                    <strong>@($"{GetSoloPanelProgressPercent(panelView)}%")</strong>
                                    <small>@GetSoloPanelProgressTrendLabel(panelView)</small>
                                </div>
                                <div class="enigma-progress-shell">
                                    <div class="enigma-progress-bar" style="width: @(Math.Round(panelView.Progress * 100d, 2))%;"></div>
                                </div>
                                <div class="enigma-solo-hud-grid">
                                    @foreach (var hudItem in panelView.Hud)
                                    {
                                        <div class="enigma-solo-hud-card tone-@hudItem.Tone">
                                            <span>@hudItem.Label</span>
                                            <strong>@hudItem.Value</strong>
                                        </div>
                                    }
                                </div>
                                @if (IsSoloPanelChromaticLock(panelView))
                                {
                                    <ChromaticLockPanel View="panelView" OnAction="ApplySoloPanelAction" />
                                }
                                else if (IsSoloPanelSignalDecay(panelView))
                                {
                                    <SignalDecayPanel View="panelView" OnAction="ApplySoloPanelAction" />
                                }
                                else if (IsSoloPanelSystemTemplate(panelView))
                                {
                                    <SystemPuzzlePanel View="panelView" OnAction="ApplySoloPanelAction" />
                                }
                                else if (IsSoloPanelDialTemplate(panelView))
                                {
                                    <DialPuzzlePanel View="panelView" OnAction="ApplySoloPanelAction" />
                                }
                                else if (IsSoloPanelGridTemplate(panelView))
                                {
                                    <GridPuzzlePanel View="panelView" OnAction="ApplySoloPanelAction" />
                                }
                                else if (IsSoloPanelFlowTemplate(panelView))
                                {
                                    <FlowPuzzlePanel View="panelView" OnAction="ApplySoloPanelAction" />
                                }
                                else if (IsSoloPanelMemoryTemplate(panelView))
                                {
                                    <MemoryPuzzlePanel View="panelView" OnAction="ApplySoloPanelAction" />
                                }
                                else if (dialKeys.Count > 0)
                                {
                                    <div class="enigma-solo-dial-grid">
                                        @foreach (var dialKey in dialKeys)
                                        {
                                            var valueText = GetSoloPanelDialValueText(panelView, dialKey);
                                            var ringStyle = GetSoloPanelDialRingStyle(panelView, dialKey);
                                            var hasDown = TryGetSoloPanelDialAction(panelView, dialKey, "down", out var downAction);
                                            var hasUp = TryGetSoloPanelDialAction(panelView, dialKey, "up", out var upAction);
                                            <div class="enigma-solo-dial-card">
                                                <div class="enigma-solo-dial-ring"
                                                     style="@ringStyle"
                                                     @onpointerdown="((PointerEventArgs args) => BeginSoloDialDrag(args, dialKey))">
                                                    <span class="enigma-solo-dial-value">@valueText</span>
                                                </div>
                                                <header>
                                                    <span>@dialKey.ToUpperInvariant()</span>
                                                </header>
                                                <div class="enigma-solo-dial-controls">
                                                    @if (hasDown)
                                                    {
                                                        <button class="@GetSoloPanelActionClass(downAction)"
                                                                disabled="@(!downAction.Enabled)"
                                                                @onclick="(() => ApplySoloPanelAction(downAction.Command))">⟲</button>
                                                    }
                                                    @if (hasUp)
                                                    {
                                                        <button class="@GetSoloPanelActionClass(upAction)"
                                                                disabled="@(!upAction.Enabled)"
                                                                @onclick="(() => ApplySoloPanelAction(upAction.Command))">⟳</button>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (!HasDedicatedSoloPanel(panelView) && cellActions.Count > 0)
                                {
                                    <div class="enigma-solo-cell-grid @GetSoloPanelFamilyClass(panelView.FamilyId)">
                                        @foreach (var cellAction in cellActions)
                                        {
                                            var command = cellAction.Command;
                                            <button class="@GetSoloPanelCellActionClass(cellAction)"
                                                    disabled="@(!cellAction.Enabled)"
                                                    @onclick="(() => ApplySoloPanelAction(command))">
                                                <span class="enigma-solo-cell-glyph">@GetSoloPanelCellGlyph(cellAction, panelView.FamilyId)</span>
                                                <small>@GetSoloPanelCellLabel(cellAction)</small>
                                            </button>
                                        }
                                    </div>
                                }

                                @if (!HasDedicatedSoloPanel(panelView) && pipeActions.Count > 0)
                                {
                                    var pipeRows = Math.Max(1, GetSoloPanelBoardInt(panelView, "pipe_rows", 1));
                                    var pipeCols = Math.Max(1, GetSoloPanelBoardInt(panelView, "pipe_cols", 1));
                                    <div class="enigma-solo-pipe-grid"
                                         style="grid-template-columns: repeat(@pipeCols, minmax(0, 1fr)); grid-template-rows: repeat(@pipeRows, minmax(0, 1fr));">
                                        @foreach (var pipeAction in pipeActions)
                                        {
                                            var command = pipeAction.Command;
                                            <button class="@GetSoloPanelPipeActionClass(panelView, pipeAction)"
                                                    disabled="@(!pipeAction.Enabled)"
                                                    @onclick="(() => ApplySoloPanelAction(command))">
                                                <span class="enigma-solo-pipe-glyph">@GetSoloPanelPipeGlyph(panelView, pipeAction)</span>
                                            </button>
                                        }
                                    </div>
                                }

                                @if (!HasDedicatedSoloPanel(panelView) && cardActions.Count > 0)
                                {
                                    <div class="enigma-solo-card-grid @GetSoloPanelFamilyClass(panelView.FamilyId)">
                                        @foreach (var cardAction in cardActions)
                                        {
                                            var command = cardAction.Command;
                                            <button class="@GetSoloPanelActionClass(cardAction)"
                                                    disabled="@(!cardAction.Enabled)"
                                                    @onclick="(() => ApplySoloPanelAction(command))">
                                                <span class="enigma-solo-card-glyph">@GetSoloPanelCardGlyph(cardAction, panelView.FamilyId)</span>
                                                <small>@GetSoloPanelCardLabel(cardAction)</small>
                                            </button>
                                        }
                                    </div>
                                }

                                @if (!HasDedicatedSoloPanel(panelView) && systemActions.Count > 0)
                                {
                                    <div class="enigma-option-grid compact enigma-solo-panel-actions">
                                        @foreach (var panelAction in systemActions)
                                        {
                                            var panelActionCommand = panelAction.Command;
                                            <button class="@GetSoloPanelActionClass(panelAction)"
                                                    disabled="@(!panelAction.Enabled)"
                                                    @onclick="(() => ApplySoloPanelAction(panelActionCommand))">
                                                <span class="enigma-solo-system-glyph">@GetSoloPanelActionGlyph(panelAction)</span>
                                                <span>@panelAction.Label</span>
                                            </button>
                                        }
                                    </div>
                                }

                                <div class="enigma-mini-stat-grid enigma-solo-panel-board">
                                    @foreach (var entry in panelView.Board.Where(static kv => kv.Key is "hint" or "cells_total" or "aligned"))
                                    {
                                        <div class="enigma-mini-stat">
                                            <span>@entry.Key</span>
                                            <strong>@entry.Value</strong>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else if (CurrentRoomState.Puzzle is IWorldInteractivePuzzle)
                    {
                        <div class="enigma-world-puzzle-surface">
                            <div class="enigma-puzzle-guide enigma-world-puzzle-guide">
                                <div class="enigma-puzzle-guide-row">
                                    <span>Objective</span>
                                    <p>@CurrentRoomState.Puzzle.Instruction</p>
                                </div>
                                <div class="enigma-puzzle-guide-row">
                                    <span>Controls</span>
                                    <p>@GetWorldPuzzlePressEInstruction()</p>
                                </div>
                                <div class="enigma-puzzle-guide-row">
                                    <span>Lifecycle</span>
                                    <p><strong class="enigma-world-puzzle-state @GetWorldPuzzleStatusCssClass()">@GetWorldPuzzleStatusLabel()</strong></p>
                                </div>
                            </div>
                            @if (TryGetWorldPuzzleCardProgress(out var worldProgress, out var worldProgressLabel))
                            {
                                <div class="enigma-world-puzzle-progress-head">
                                    <span>@worldProgressLabel</span>
                                    <strong>@($"{Math.Round(worldProgress * 100d):0}%")</strong>
                                </div>
                                <div class="enigma-progress-shell">
                                    <div class="enigma-progress-bar" style="width: @(Math.Round(worldProgress * 100d, 2))%;"></div>
                                </div>
                            }
                        </div>
                    }
                    @if (CurrentRoomState.Definition.Kind == MazeRoomKind.Reward)
                    {
                        <p class="enigma-helper reward-copy">Reward rooms spawn bonus MN after the puzzle is cleared.</p>
                    }
                    @if (CurrentRoomState.Definition.Kind == MazeRoomKind.Finish)
                    {
                        <p class="enigma-helper reward-copy">Once this puzzle is solved, touch the black hole to finish the expedition.</p>
                    }
                    </div>
                    }
                </div>
            </aside>
            </div>
            }
        </section>
    </div>
}

