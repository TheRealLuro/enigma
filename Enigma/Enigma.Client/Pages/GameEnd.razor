@page "/gameend/{Result?}"
@using Enigma.Client.Models.Gameplay

@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject Enigma.Client.Services.EnigmaApiClient Api

<SeoHead Title="Enigma Run Complete | Maze Cleared"
         Description="Review the completion summary for a finished Enigma maze run."
         Robots="noindex,nofollow"
         OpenGraphType="website"
         SchemaType="WebPage" />

@if (IsLoading)
{
    <div class="content">
        <div class="card enigma-game-message">
            <div class="loader"></div>
            <p>Loading run summary...</p>
        </div>
    </div>
}
else if (!IsWin || Summary is null)
{
    <div class="content">
        <div class="card enigma-game-message">
            <h1>Run Complete</h1>
            <p>@(LoadError ?? "No game summary is available for this run.")</p>
            <div class="enigma-end-actions">
                <button class="btn btn-primary" @onclick="GoHome">Main Menu</button>
                <button class="btn btn-secondary" @onclick="GoPlay">Back to Play</button>
            </div>
        </div>
    </div>
}
else
{
    <div class="content enigma-end-page">
        <div class="card enigma-end-card">
            <span class="enigma-kicker">Escape Logged</span>
            <h1>Maze Cleared</h1>
            <div class="enigma-end-grid">
                <div>
                    <span>Player</span>
                    <strong>@Summary.Username</strong>
                </div>
                <div>
                    <span>@(Summary.IsMultiplayer ? "Total Team MN" : "Total MN")</span>
                    <strong>@Summary.GoldCollected.ToString("N0") MN</strong>
                </div>
                <div>
                    <span>Completion Time</span>
                    <strong>@Summary.CompletionTime</strong>
                </div>
                <div>
                    <span>Difficulty</span>
                    <strong>@Summary.Difficulty</strong>
                </div>
            </div>

            <div class="enigma-end-grid compact">
                <div>
                    <span>Map Source</span>
                    <strong>@(Summary.SeedExisted || Summary.Source == "load" ? "Existing map" : "Generated seed")</strong>
                </div>
                <div>
                    <span>Maze Size</span>
                    <strong>@Summary.Size x @Summary.Size</strong>
                </div>
                <div>
                    <span>Seed</span>
                    <strong class="seed-preview">@Summary.Seed</strong>
                </div>
            </div>

            @if (Summary.IsMultiplayer)
            {
                <div class="enigma-end-grid compact">
                    <div>
                        <span>Your Reward</span>
                        <strong>@Summary.RewardAwarded.ToString("N0") MN</strong>
                    </div>
                    <div>
                        <span>Bank Dividend</span>
                        <strong>@Summary.BankDividend.ToString("N0") MN</strong>
                    </div>
                    <div>
                        <span>Partner</span>
                        <strong>@(string.IsNullOrWhiteSpace(Summary.PartnerUsername) ? "Unknown" : Summary.PartnerUsername)</strong>
                    </div>
                    <div>
                        <span>Ownership</span>
                        <strong>@((Summary.Source != "load" && !Summary.SeedExisted)
                            ? (Summary.IsSessionOwner ? "Host owns the saved maze" : "Host becomes owner when saved")
                            : "Map ownership unchanged")</strong>
                    </div>
                    <div>
                        <span>Discovery</span>
                        <strong>Both explorers are recorded</strong>
                    </div>
                </div>
            }

            <div class="enigma-form-block">
                <label class="form-label">Map Name</label>
                @if (Summary.SeedExisted || Summary.Source == "load")
                {
                    <input class="form-control" value="@MapName" readonly />
                }
                else
                {
                    <input class="form-control" @bind="MapName" maxlength="50" placeholder="Enter a name for this maze" />
                }
            </div>

            <div class="enigma-form-block">
                <label class="form-label">Rating</label>
                <InputNumber class="form-control" @bind-Value="Rating" />
                <small class="enigma-helper">Required by the backend when submitting or updating a map.</small>
            </div>

            @if (!string.IsNullOrWhiteSpace(StatusMessage))
            {
                <div class="alert @(SubmissionSucceeded ? "alert-success" : "alert-warning")">@StatusMessage</div>
            }

            <div class="enigma-end-actions">
                @if (!Summary.IsMultiplayer || Summary.CanSubmitMapRecord)
                {
                    <button class="btn btn-success" disabled="@IsSubmitting" @onclick="SubmitResultAsync">
                        @(IsSubmitting ? "Submitting..." : Summary.HasBeenSubmitted ? "Submitted" : "Submit Result")
                    </button>
                }
                <button class="btn btn-primary" @onclick="RetryMaze">Play Again</button>
                <button class="btn btn-secondary" @onclick="GoHome">Main Menu</button>
            </div>
        </div>
    </div>
}

@code {
    private const string CompletionSummaryStorageKey = "enigma.game.summary";

    [Parameter] public string? Result { get; set; }

    private bool IsLoading { get; set; } = true;
    private bool IsSubmitting { get; set; }
    private bool SubmissionSucceeded { get; set; }
    private string? LoadError { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private GameCompletionSummary? Summary { get; set; }
    private string MapName { get; set; } = string.Empty;
    private int Rating { get; set; } = 8;

    private bool IsWin => string.Equals(Result, "win", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Summary = await JS.InvokeAsync<GameCompletionSummary?>("enigmaGame.sessionGetJson", CompletionSummaryStorageKey);
        if (Summary is null)
        {
            LoadError = "Finish a maze from the Game page before visiting the result screen.";
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        MapName = Summary.Source == "load" || Summary.SeedExisted
            ? Summary.LoadedMapName ?? string.Empty
            : MapName;

        IsLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SubmitResultAsync()
    {
        if (Summary is null || Summary.HasBeenSubmitted)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(Summary.Username) || string.Equals(Summary.Username, "Guest", StringComparison.OrdinalIgnoreCase))
        {
            SubmissionSucceeded = false;
            StatusMessage = "Log in before submitting a completed run.";
            return;
        }

        if (Rating is < 1 or > 10)
        {
            SubmissionSucceeded = false;
            StatusMessage = "Rating must be between 1 and 10.";
            return;
        }

        if (!Summary.SeedExisted && Summary.Source == "new" && string.IsNullOrWhiteSpace(MapName))
        {
            SubmissionSucceeded = false;
            StatusMessage = "Map name is required for a newly generated maze.";
            return;
        }

        IsSubmitting = true;
        StatusMessage = string.Empty;

        try
        {
            var completionTime = ParseCompletionTime(Summary.CompletionTime);
            if (Summary.IsMultiplayer)
            {
                if (Summary.SeedExisted || Summary.Source == "load")
                {
                    await UpdateExistingMapAsync(completionTime);
                }
                else
                {
                    await AddNewMapAsync(completionTime);
                    if (Summary.RequiresOwnerSave && !Summary.DiscoverersSynced)
                    {
                        await SyncSavedMultiplayerMapAsync();
                        Summary.DiscoverersSynced = true;
                    }
                }
            }
            else if (Summary.Source == "load")
            {
                await UpdateExistingMapAsync(completionTime);
                await UpdateUserProgressAsync(seedExisted: true);
            }
            else
            {
                await AddNewMapAsync(completionTime);
                await UpdateUserProgressAsync(seedExisted: false);
            }

            Summary.HasBeenSubmitted = true;
            await JS.InvokeVoidAsync("enigmaGame.sessionSetJson", CompletionSummaryStorageKey, Summary);
            await JS.InvokeVoidAsync("enigmaGame.clearPendingLossSummary");
            await JS.InvokeVoidAsync("enigmaGame.clearRunLoadout");
            SubmissionSucceeded = true;
            StatusMessage = "Run submitted successfully.";
        }
        catch (Exception exception)
        {
            SubmissionSucceeded = false;
            StatusMessage = exception.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task AddNewMapAsync(TimeOnly completionTime)
    {
        if (Summary is null)
        {
            return;
        }

        using var response = await Api.PostJsonAsync("api/auth/addMap", new
        {
            name = MapName,
            seed = Summary.Seed,
            size = Summary.Size,
            difficulty = Summary.Difficulty.ToLowerInvariant(),
            time = completionTime,
            rating = Rating,
        });
        await EnsureSuccessAsync(response, "Unable to save the new map.");
    }

    private async Task UpdateExistingMapAsync(TimeOnly completionTime)
    {
        if (Summary is null)
        {
            return;
        }

        using var response = await Api.PutJsonAsync("api/auth/updateMap", new
        {
            seed = Summary.Seed,
            time = completionTime,
            rating = Rating,
        });
        await EnsureSuccessAsync(response, "Unable to update the existing map.");
    }

    private async Task UpdateUserProgressAsync(bool seedExisted)
    {
        if (Summary is null)
        {
            return;
        }

        using var response = await Api.PutJsonAsync("api/auth/updateStats", new
        {
            seed = Summary.Seed,
            items = Summary.UsedItems.Count == 0 ? "none" : string.Join(",", Summary.UsedItems),
            reward = Summary.GoldCollected,
            seedExisted,
            mapLost = false,
        });
        await EnsureSuccessAsync(response, "Unable to update the player progress.");
    }

    private async Task SyncSavedMultiplayerMapAsync()
    {
        if (Summary is null || string.IsNullOrWhiteSpace(Summary.MultiplayerSessionId))
        {
            return;
        }

        using var response = await Api.PostJsonAsync("api/auth/multiplayer/session/sync-saved-map", new
        {
            sessionId = Summary.MultiplayerSessionId,
            mapName = MapName,
        });
        await EnsureSuccessAsync(response, "Unable to sync co-op discoverers after saving the map.");
    }

    private static async Task EnsureSuccessAsync(HttpResponseMessage response, string prefix)
    {
        if (response.IsSuccessStatusCode)
        {
            return;
        }

        var details = await response.Content.ReadAsStringAsync();
        throw new InvalidOperationException($"{prefix} {details}".Trim());
    }

    private void RetryMaze()
    {
        if (Summary is null)
        {
            NavigationManager.NavigateTo("/play");
            return;
        }

        if (Summary.IsMultiplayer)
        {
            NavigationManager.NavigateTo("/play/coop");
            return;
        }

        var url = $"/game?seed={Uri.EscapeDataString(Summary.Seed)}&source={Uri.EscapeDataString(Summary.Source)}";
        if (!string.IsNullOrWhiteSpace(Summary.LoadedMapName))
        {
            url += $"&mapName={Uri.EscapeDataString(Summary.LoadedMapName)}";
        }

        NavigationManager.NavigateTo(url);
    }

    private async Task GoHome()
    {
        await JS.InvokeVoidAsync("enigmaGame.sessionRemove", CompletionSummaryStorageKey);
        await JS.InvokeVoidAsync("enigmaGame.clearPendingLossSummary");
        await JS.InvokeVoidAsync("enigmaGame.clearRunLoadout");
        NavigationManager.NavigateTo("/home");
    }

    private async Task GoPlay()
    {
        await JS.InvokeVoidAsync("enigmaGame.sessionRemove", CompletionSummaryStorageKey);
        await JS.InvokeVoidAsync("enigmaGame.clearPendingLossSummary");
        await JS.InvokeVoidAsync("enigmaGame.clearRunLoadout");
        NavigationManager.NavigateTo("/play");
    }

    private static TimeOnly ParseCompletionTime(string value)
    {
        if (TimeOnly.TryParse(value, out var parsed))
        {
            return parsed;
        }

        var parts = value.Split(':', StringSplitOptions.TrimEntries);
        if (parts.Length == 4
            && int.TryParse(parts[0], out var hours)
            && int.TryParse(parts[1], out var minutes)
            && int.TryParse(parts[2], out var seconds)
            && int.TryParse(parts[3], out var milliseconds))
        {
            return new TimeOnly(hours, minutes, seconds, milliseconds);
        }

        return new TimeOnly(0, 0, 0);
    }
}
