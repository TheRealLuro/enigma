@page "/home"
@inject Enigma.Client.Services.EnigmaApiClient Api

<SeoHead Title="Enigma Home | Explorer Command"
         Description="Open Explorer Command to enter anomaly sectors, track rankings, manage your explorer profile, and monitor the research economy."
         Robots="noindex,follow"
         OpenGraphType="website"
         SchemaType="WebPage" />

<div class="home-page-shell" data-tour-id="home-hub">
    <div class="hero hero-panel home-hero-panel" data-tour-id="home-banner">
        <div class="home-hero-copy">
            <h1>@($"Welcome To Enigma, {Username}")</h1>
            <p>Choose where you want to go next.</p>
        </div>
    </div>

    <div class="grid grid-auto home-tab-grid">
        <button class="game-card clickable menu-image-card" type="button" data-tour-id="home-play-card" @onclick="OnPlayClick">
            <div class="menu-card-media">
                <img class="menu-card-image" src="/images/mainmenu-tabs/PlayTab.png" alt="Play" />
            </div>
            <div class="game-card-content">
                <div class="game-card-title">Enter Anomaly</div>
                <div class="game-card-meta">Launch or load an expedition sector</div>
            </div>
        </button>

        <button class="game-card clickable menu-image-card" type="button" data-tour-id="home-leaderboard-card" @onclick="OnLeaderboardsClick">
            <div class="menu-card-media">
                <img class="menu-card-image" src="/images/mainmenu-tabs/LeaderboardTab.png" alt="Leaderboard" />
            </div>
            <div class="game-card-content">
                <div class="game-card-title">Explorer Rankings</div>
                <div class="game-card-meta">Track top explorers and mapped sectors</div>
            </div>
        </button>

        <button class="game-card clickable menu-image-card" type="button" data-tour-id="home-profile-card" @onclick="OnProfileClick">
            <div class="menu-card-media">
                <img class="menu-card-image" src="/images/mainmenu-tabs/ProfileTab.png" alt="Profile" />
            </div>
            <div class="game-card-content">
                <div class="game-card-title">Explorer Profile</div>
                <div class="game-card-meta">Inventory, settings, sectors, and stats</div>
            </div>
        </button>

        <button class="game-card clickable menu-image-card" type="button" data-tour-id="home-economy-card" @onclick="OnMarketplaceClick">
            <div class="menu-card-media">
                <img class="menu-card-image" src="/images/mainmenu-tabs/MarketplaceTab.png" alt="Economy" />
            </div>
            <div class="game-card-content">
                <div class="game-card-title">Research Economy</div>
                <div class="game-card-meta">Circulation, marketplace, staking, and council voting</div>
            </div>
        </button>

        <button class="game-card clickable menu-image-card" type="button" data-tour-id="home-players-card" @onclick="OnPlayersClick">
            <div class="menu-card-media">
                <img class="menu-card-image" src="/images/mainmenu-tabs/PlayersTab.png" alt="Players" />
            </div>
            <div class="game-card-content">
                <div class="game-card-title">Explorer Network</div>
                <div class="game-card-meta">Find field agents and view profiles</div>
            </div>
        </button>
    </div>
</div>

<a class="home-energy-pill" href="https://buymeacoffee.com/enigmamaze" target="_blank" rel="noopener noreferrer">
    Buy us an Energy Drink
</a>

@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;

    private string Username { get; set; } = string.Empty;
    private LoginUserSummary? Session { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Session = await Api.GetSessionAsync();
        if (Session is null)
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        Username = Session.Username;
        await InvokeAsync(StateHasChanged);
    }

    private void OnPlayClick() => NavigationManager.NavigateTo("/play");

    private void OnLeaderboardsClick() => NavigationManager.NavigateTo("/leaderboard");

    private void OnProfileClick() => NavigationManager.NavigateTo("/profile");

    private void OnMarketplaceClick() => NavigationManager.NavigateTo("/economy");

    private void OnPlayersClick() => NavigationManager.NavigateTo("/players");
}
