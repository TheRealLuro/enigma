@page "/"
@rendermode InteractiveWebAssembly
@using Enigma.Client.Models.Gameplay

<div class="content" style="max-width: 480px; margin-top: 60px;">
    <div class="card p-4 shadow-sm">

        <h3 class="mb-4 text-center">Sign In</h3>

        <EditForm Model="user" OnValidSubmit="OnLoginClick">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Username</label>
                <InputText class="form-control"
                           @bind-Value="user.Username"
                           placeholder="your_username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <InputText type="password"
                           class="form-control"
                           @bind-Value="password"
                           placeholder="��������" />
            </div>

            <div class="mb-3 d-flex justify-content-between align-items-center">
                <div>
                    <InputCheckbox @bind-Value="rememberMe"
                                   class="form-check-input"
                                   id="remember" />
                    <label for="remember" class="form-check-label ms-1">
                        Remember me
                    </label>
                </div>

                <button type="button"
                        class="btn btn-link p-0"
                        @onclick="OnForgotPasswordClick">
                    Forgot password?
                </button>
            </div>

            <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
                @(IsSubmitting ? "Logging in..." : "Login")
            </button>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert @(HasError ? "alert-warning" : "alert-info") mt-3">@StatusMessage</div>
        }

        <div class="subtext-mt-4">
            Don't have an account?
            <button class="btn btn-link p-0"
                    @onclick="OnRegisterClick">
                Create one
            </button>
        </div>

    </div>
</div>

@code {
    [Inject]
    NavigationManager NavigationManager { get; set; } = default!;

    [Inject]
    HttpClient Http { get; set; } = default!;

    [Inject]
    IJSRuntime JS { get; set; } = default!;

    private User user = new() { Username = string.Empty };
    private string password = string.Empty;
    private bool rememberMe;
    private bool IsSubmitting;
    private bool HasError;
    private string StatusMessage = string.Empty;

    private async Task OnLoginClick()
    {
        IsSubmitting = true;
        HasError = false;
        StatusMessage = string.Empty;

        var url = BuildControllerUrl(
            $"api/auth/login?username={Uri.EscapeDataString(user.Username ?? string.Empty)}&password={Uri.EscapeDataString(password)}");

        try
        {
            using var httpResponse = await Http.PostAsync(url, content: null);
            if (!httpResponse.IsSuccessStatusCode)
            {
                var errorText = await httpResponse.Content.ReadAsStringAsync();
                throw new InvalidOperationException(string.IsNullOrWhiteSpace(errorText) ? "Login failed." : errorText);
            }

            var response = await httpResponse.Content.ReadFromJsonAsync<LoginResponse>();
            if (response is null || response.Status != "success" || string.IsNullOrWhiteSpace(response.User?.Username))
            {
                throw new InvalidOperationException("Login failed.");
            }

            await JS.InvokeVoidAsync(
                "enigmaGame.setPlayerIdentity",
                new PlayerIdentity { Username = response.User.Username },
                rememberMe);

            await JS.InvokeVoidAsync("enigmaGame.setUserSession", response.User, rememberMe);

            StatusMessage = response.DailyRewardGranted
                ? $"Daily reward granted: {response.DailyRewardAmount}"
                : "Login successful.";

            NavigationManager.NavigateTo("/home");
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void OnRegisterClick()
    {
        NavigationManager.NavigateTo("/register");
    }

    private void OnForgotPasswordClick()
    {
        NavigationManager.NavigateTo("/forgot-password");
    }

    private string BuildControllerUrl(string relativePath)
    {
        return new Uri(new Uri(NavigationManager.BaseUri), relativePath).ToString();
    }
}
