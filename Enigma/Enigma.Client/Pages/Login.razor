@page "/"
@rendermode InteractiveWebAssembly
@using Enigma.Client.Models
@using Enigma.Client.Models.Gameplay
@inject Enigma.Client.Services.EnigmaApiClient Api
@inject Enigma.Client.Services.UiNotificationService Notifications
@using Microsoft.JSInterop

<SeoHead Title="Enigma Puzzle Game | Solve Evolving Mazes"
         Description="Enigma is an evolving puzzle maze game with solo runs, co-op expeditions, collectible maps, and a player-driven marketplace."
         OpenGraphType="website"
         SchemaType="VideoGame"
         Keywords="Enigma puzzle game, evolving maze game, co-op puzzle maze, collectible maps"
         SchemaProperties="@(new Dictionary<string, object?> { ["genre"] = "Puzzle", ["applicationCategory"] = "Game", ["operatingSystem"] = "Any", ["publisher"] = "Enigma" })" />

<div class="content auth-shell seo-auth-shell" style="max-width: 960px; margin-top: 60px;">
    <section class="seo-auth-intro panel">
        <span class="profile-kicker">Puzzle Maze Game</span>
        <h1>Enigma</h1>
        <p>Explore evolving mazes, solve room-based puzzles, discover collectible maps, and use the live economy for marketplace trading, map analysis rewards, and council voting.</p>
        <div class="seo-inline-links">
            <a href="/about">About</a>
            <a href="/how-enigma-works">How It Works</a>
            <a href="/enigma-game-mechanics">Game Mechanics</a>
            <a href="/enigma-multiplayer">Multiplayer</a>
        </div>
    </section>

    <div class="card p-4 shadow-sm auth-card">

        <h2 class="mb-4 text-center">Sign In</h2>

        <EditForm Model="user" OnValidSubmit="OnLoginClick">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Username</label>
                <InputText class="form-control"
                           @bind-Value="user.Username"
                           placeholder="your_username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <div class="password-field-wrap">
                    <InputText type="@(ShowPassword ? "text" : "password")"
                               class="form-control"
                               @bind-Value="password"
                               placeholder="Enter your password" />
                    <button type="button" class="password-toggle-button" @onclick="TogglePasswordVisibility">
                        @(ShowPassword ? "Hide" : "Show")
                    </button>
                </div>
            </div>

            <div class="mb-3 d-flex justify-content-between align-items-center">
                <div>
                    <InputCheckbox @bind-Value="rememberMe"
                                   class="form-check-input"
                                   id="remember" />
                    <label for="remember" class="form-check-label ms-1">
                        Remember me
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
                @(IsSubmitting ? "Logging in..." : "Login")
            </button>
        </EditForm>

        @if (HasError && !string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert alert-warning mt-3">@StatusMessage</div>
        }

        <div class="subtext-mt-4">
            Don't have an account?
            <button class="btn btn-link p-0"
                    @onclick="OnRegisterClick">
                Create one
            </button>
        </div>

    </div>
</div>

@code {
    [Inject]
    NavigationManager NavigationManager { get; set; } = default!;

    [Inject]
    IJSRuntime JS { get; set; } = default!;

    private User user = new() { Username = string.Empty };
    private string password = string.Empty;
    private bool rememberMe;
    private bool IsSubmitting;
    private bool HasError;
    private bool ShowPassword;
    private string StatusMessage = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        rememberMe = await GetRememberedSessionStateAsync();
        var rememberedSession = await GetStoredUserSessionSafeAsync();
        if (!string.IsNullOrWhiteSpace(rememberedSession?.Username))
        {
            user.Username = rememberedSession.Username;
            await InvokeAsync(StateHasChanged);
        }

        var session = await Api.GetSessionAsync();
        if (session is not null && !string.IsNullOrWhiteSpace(session.Username))
        {
            await JS.InvokeVoidAsync("enigmaGame.refreshUserSession", session);
            await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new PlayerIdentity { Username = session.Username }, rememberMe);
            NavigationManager.NavigateTo("/home", replace: true);
        }
    }

    private async Task OnLoginClick()
    {
        IsSubmitting = true;
        HasError = false;
        StatusMessage = string.Empty;

        try
        {
            using var httpResponse = await Api.PostJsonAsync("api/auth/session/login", new
            {
                username = user.Username ?? string.Empty,
                password,
                rememberMe,
            });

            if (!httpResponse.IsSuccessStatusCode)
            {
                var errorText = await httpResponse.Content.ReadAsStringAsync();
                throw new InvalidOperationException(string.IsNullOrWhiteSpace(errorText) ? "Login failed." : errorText);
            }

            var response = await Api.ReadJsonAsync<LoginResponse>(httpResponse);
            if (response is null || response.Status != "success" || string.IsNullOrWhiteSpace(response.User?.Username))
            {
                throw new InvalidOperationException("Login failed.");
            }

            await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new PlayerIdentity { Username = response.User.Username }, rememberMe);
            await JS.InvokeVoidAsync("enigmaGame.setUserSession", response.User, rememberMe);

            StatusMessage = response.DailyRewardGranted
                ? $"Daily reward granted: {response.DailyRewardAmount}"
                : "Login successful.";
            if (response.DailyRewardGranted)
            {
                Notifications.Success($"Daily reward granted: {response.DailyRewardAmount:N0} MN.");
            }
            else
            {
                Notifications.Success("Login successful.");
            }

            NavigationManager.NavigateTo("/home");
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
            Notifications.Error(StatusMessage);
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void TogglePasswordVisibility()
    {
        ShowPassword = !ShowPassword;
    }

    private void OnRegisterClick()
    {
        NavigationManager.NavigateTo("/register");
    }

    private async Task<bool> GetRememberedSessionStateAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("enigmaGame.isUserSessionRemembered");
        }
        catch (JSException)
        {
            return false;
        }
    }

    private async Task<LoginUserSummary?> GetStoredUserSessionSafeAsync()
    {
        try
        {
            return await JS.InvokeAsync<LoginUserSummary?>("enigmaGame.getUserSession");
        }
        catch (JSException)
        {
            return null;
        }
    }
}
