@page "/lose"
@using Enigma.Client.Models.Gameplay
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<SeoHead Title="Enigma Expedition Lost | Sector Abandoned"
         Description="Review the loss summary for an abandoned Enigma sector expedition."
         Robots="noindex,nofollow"
         OpenGraphType="website"
         SchemaType="WebPage" />

@if (IsLoading)
{
    <div class="content">
        <div class="card enigma-game-message">
            <div class="loader"></div>
            <p>Loading loss report...</p>
        </div>
    </div>
}
else if (Summary is null)
{
    <div class="content">
        <div class="card enigma-game-message">
            <h1>Expedition Lost</h1>
            <p>No lost expedition summary is available.</p>
            <div class="enigma-end-actions">
                <button class="btn btn-primary" @onclick='@(() => NavigationManager.NavigateTo("/home"))'>Command</button>
                <button class="btn btn-secondary" @onclick='@(() => NavigationManager.NavigateTo("/play"))'>Launch Again</button>
            </div>
        </div>
    </div>
}
else
{
    <div class="content enigma-end-page lose-page-shell">
        <div class="card enigma-end-card lose-card">
            <span class="enigma-kicker">Expedition Lost</span>
            <h1>@(string.IsNullOrWhiteSpace(Summary.MapName) ? "UNKNOWN" : Summary.MapName)</h1>
            <p class="enigma-game-subline">You left the sector. This expedition is gone forever.</p>

            <div class="enigma-end-grid">
                <div>
                    <span>Explorer</span>
                    <strong>@Summary.Username</strong>
                </div>
                @if (Summary.IsMultiplayer)
                {
                    <div>
                        <span>Partner</span>
                        <strong>@(string.IsNullOrWhiteSpace(Summary.PartnerUsername) ? "Unknown" : Summary.PartnerUsername)</strong>
                    </div>
                }
                <div>
                    <span>Difficulty</span>
                    <strong>@Summary.Difficulty</strong>
                </div>
                <div>
                    <span>Theme</span>
                    <strong>@Summary.ThemeLabel</strong>
                </div>
                <div>
                    <span>Left At</span>
                    <strong>@FormatTime(Summary.AbandonedAtUtc)</strong>
                </div>
            </div>

            <div class="enigma-end-grid compact lose-metric-grid">
                <div>
                    <span>Sector Value</span>
                    <strong>@Summary.MapValue.ToString("N0") MN</strong>
                </div>
                <div>
                    <span>Forfeited Expedition Payout</span>
                    <strong>@Summary.ForfeitedRunPayout.ToString("N0") MN</strong>
                </div>
                <div>
                    <span>Projected Completion Payout</span>
                    <strong>@Summary.ProjectedCompletionPayout.ToString("N0") MN</strong>
                </div>
                <div>
                    <span>Reason</span>
                    <strong>@Summary.Reason</strong>
                </div>
            </div>

            <div class="enigma-end-actions">
                <button class="btn btn-primary" @onclick='@(() => NavigationManager.NavigateTo("/home", replace: true))'>Command</button>
                <button class="btn btn-secondary" @onclick='@(() => NavigationManager.NavigateTo("/play", replace: true))'>Launch Again</button>
                @if (!string.IsNullOrWhiteSpace(Summary.MapName) && string.Equals(Summary.Source, "load", StringComparison.OrdinalIgnoreCase))
                {
                    <button class="btn btn-secondary" @onclick="ViewMapProfile">Open Sector in Console</button>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool IsLoading { get; set; } = true;
    private PendingLossSummary? Summary { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Summary = await JS.InvokeAsync<PendingLossSummary?>("enigmaGame.consumePendingLossSummary");
        IsLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void ViewMapProfile()
    {
        NavigationManager.NavigateTo("/profile");
    }

    private static string FormatTime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Unknown";
        }

        return DateTimeOffset.TryParse(value, out var timestamp)
            ? timestamp.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
            : value;
    }
}
