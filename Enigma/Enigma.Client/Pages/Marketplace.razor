    private long GetMissingMnForListing(MarketplaceListing listing)
    {
        if (Session is null || IsOwnListing(listing))
        {
            return 0;
        }

        return Math.Max(0L, (long)listing.Price - Session.MazeNuggets);
    }

    private int GetListingDraftPrice(MarketplaceListing listing)
    {
        var key = listing.MapName;
        if (ListingDraftPrices.TryGetValue(key, out var existing) && existing > 0)
        {
            return existing;
        }

        var defaultValue = Math.Max(1, listing.Price);
        ListingDraftPrices[key] = defaultValue;
        return defaultValue;
    }

    private Task UpdateListingDraftPrice(MarketplaceListing listing, int value)
    {
        ListingDraftPrices[listing.MapName] = Math.Max(1, value);
        return Task.CompletedTask;
    }

    private void ResetListingSection()
    {
        CurrentListingSectionIndex = 0;
    }

    private void ClampListingSectionIndex()
    {
        if (AllFilteredListings.Count == 0)
        {
            CurrentListingSectionIndex = 0;
            return;
        }

        CurrentListingSectionIndex = Math.Clamp(CurrentListingSectionIndex, 0, Math.Max(0, TotalListingSections - 1));
    }

    private IEnumerable<int> GetVisibleListingSectionIndexes()
    {
        if (TotalListingSections <= 0)
        {
            yield break;
        }

        var maxButtons = 5;
        var start = Math.Max(0, CurrentListingSectionIndex - 2);
        var end = Math.Min(TotalListingSections - 1, start + maxButtons - 1);
        start = Math.Max(0, end - (maxButtons - 1));

        for (var index = start; index <= end; index++)
        {
            yield return index;
        }
    }

    private string GetListingSectionButtonClass(int sectionIndex)
    {
        return sectionIndex == CurrentListingSectionIndex ? "btn btn-primary leaderboard-page-button" : "btn btn-secondary leaderboard-page-button";
    }

    private Task GoToPreviousListingSectionAsync() => GoToListingSectionAsync(CurrentListingSectionIndex - 1);

    private Task GoToNextListingSectionAsync() => GoToListingSectionAsync(CurrentListingSectionIndex + 1);

    private Task GoToListingSectionAsync(int sectionIndex)
    {
        if (sectionIndex == CurrentListingSectionIndex || sectionIndex < 0 || sectionIndex >= TotalListingSections)
        {
            return Task.CompletedTask;
        }

        CurrentListingSectionIndex = sectionIndex;
        return InvokeAsync(StateHasChanged);
    }

    private string GetMarketplaceTabClass(string tab)
    {
        return ActiveMarketplaceTab == tab ? "profile-tab active" : "profile-tab";
    }

    private IEnumerable<MarketplaceListing> ApplyMapSort(IEnumerable<MarketplaceListing> listings)
    {
        var descending = string.Equals(MapSortOrder, "desc", StringComparison.OrdinalIgnoreCase);
        return MapSortBy switch
        {
            "price" => OrderByWithDirection(listings, static listing => listing.Price, descending)
                .ThenBy(static listing => listing.MapName, StringComparer.OrdinalIgnoreCase),
            "value" => OrderByWithDirection(listings, static listing => listing.Value, descending)
                .ThenBy(static listing => listing.MapName, StringComparer.OrdinalIgnoreCase),
            "size" => OrderByWithDirection(listings, static listing => listing.Size, descending)
                .ThenBy(static listing => listing.MapName, StringComparer.OrdinalIgnoreCase),
            "name" => descending
                ? listings.OrderByDescending(static listing => listing.MapName, StringComparer.OrdinalIgnoreCase)
                : listings.OrderBy(static listing => listing.MapName, StringComparer.OrdinalIgnoreCase),
            _ => OrderByWithDirection(listings, static listing => listing.ListedAt ?? string.Empty, descending)
                .ThenBy(static listing => listing.MapName, StringComparer.OrdinalIgnoreCase),
        };
    }

    private IEnumerable<ItemCatalogEntry> ApplyItemSort(IEnumerable<ItemCatalogEntry> items)
    {
        var descending = string.Equals(ItemSortOrder, "desc", StringComparison.OrdinalIgnoreCase);
        return ItemSortBy switch
        {
            "price" => OrderByWithDirection(items, static item => item.Price, descending)
                .ThenBy(static item => item.Name, StringComparer.OrdinalIgnoreCase),
            "rarity" => descending
                ? items.OrderByDescending(static item => GetRarityOrder(item.Rarity)).ThenBy(static item => item.Name, StringComparer.OrdinalIgnoreCase)
                : items.OrderBy(static item => GetRarityOrder(item.Rarity)).ThenBy(static item => item.Name, StringComparer.OrdinalIgnoreCase),
            "stock" => OrderByWithDirection(items, static item => item.Stock, descending)
                .ThenBy(static item => item.Name, StringComparer.OrdinalIgnoreCase),
            "owned" => OrderByWithDirection(items, item => GetOwnedCount(item.ItemId), descending)
                .ThenBy(static item => item.Name, StringComparer.OrdinalIgnoreCase),
            _ => descending
                ? items.OrderByDescending(static item => item.Name, StringComparer.OrdinalIgnoreCase)
                : items.OrderBy(static item => item.Name, StringComparer.OrdinalIgnoreCase),
        };
    }

    private static IOrderedEnumerable<T> OrderByWithDirection<T, TKey>(IEnumerable<T> source, Func<T, TKey> selector, bool descending)
    {
        return descending ? source.OrderByDescending(selector) : source.OrderBy(selector);
    }

    private bool MatchesMapSearch(MarketplaceListing listing)
    {
        if (string.IsNullOrWhiteSpace(MapSearchQuery))
        {
            return true;
        }

        var query = MapSearchQuery.Trim();
        return listing.MapName.Contains(query, StringComparison.OrdinalIgnoreCase)
            || listing.Seller.Contains(query, StringComparison.OrdinalIgnoreCase)
            || FormatThemeLabel(listing.Theme).Contains(query, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesItemSearch(ItemCatalogEntry item)
    {
        if (string.IsNullOrWhiteSpace(ItemSearchQuery))
        {
            return true;
        }

        var query = ItemSearchQuery.Trim();
        return item.Name.Contains(query, StringComparison.OrdinalIgnoreCase)
            || item.Description.Contains(query, StringComparison.OrdinalIgnoreCase)
            || item.Kind.Contains(query, StringComparison.OrdinalIgnoreCase)
            || item.Rarity.Contains(query, StringComparison.OrdinalIgnoreCase);
    }

    private static bool MatchesFilter(string? value, string activeFilter)
    {
        return string.IsNullOrWhiteSpace(activeFilter)
            || string.Equals(activeFilter, "all", StringComparison.OrdinalIgnoreCase)
            || string.Equals(value?.Trim(), activeFilter.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private static IReadOnlyList<SelectOption<string>> BuildOptionsWithAll(IEnumerable<string> values, string allLabel, Func<string, string>? labelSelector = null)
    {
        var options = new List<SelectOption<string>> { new("all", allLabel) };
        options.AddRange(values.Select(value => new SelectOption<string>(value, labelSelector?.Invoke(value) ?? value)));
        return options;
    }

    private static int GetRarityOrder(string? rarity)
    {
        return rarity?.Trim().ToLowerInvariant() switch
        {
            "common" => 1,
            "uncommon" => 2,
            "rare" => 3,
            "epic" => 4,
            "legendary" => 5,
            _ => 99,
        };
    }

    private static bool EqualsIgnoreCase(string? left, string? right)
    {
        return string.Equals(left?.Trim(), right?.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private int GetOwnedCount(string itemId)
    {
        if (Session is null)
        {
            return 0;
        }

        if (Session.ItemCounts.TryGetValue(itemId, out var count))
        {
            return count;
        }

        return Session.OwnedCosmetics.Any(ownedItemId => EqualsIgnoreCase(ownedItemId, itemId)) ? 1 : 0;
    }

    private static string GetUsesLabel(ItemCatalogEntry item)
    {
        return item.MaxPerRun <= 0 ? "Permanent" : item.MaxPerRun.ToString();
    }

    private static string? GetOwnershipLimitLabel(ItemCatalogEntry item)
    {
        if (item.PurchaseLimit <= 0)
        {
            return null;
        }

        return item.PurchaseLimit == 1
            ? "1 per person"
            : $"{item.PurchaseLimit} per person";
    }

    private static bool IsFoundersMark(ItemCatalogEntry item)
    {
        return EqualsIgnoreCase(item.ItemId, "founders_mark");
    }

    private static IReadOnlyList<string> GetFoundersMarkBenefits(ItemCatalogEntry item)
    {
        var rewardMultiplier = GetEffectDecimal(item, "reward_multiplier", 1.5m);
        var feeMultiplier = GetEffectDecimal(item, "fee_multiplier", 0.5m);
        var rewardBonusPercent = Math.Max(0m, (rewardMultiplier - 1m) * 100m);
        var feeReductionPercent = Math.Max(0m, (1m - feeMultiplier) * 100m);

        return
        [
            "Permanent account perk. Once claimed, it stays active with no run-use limit.",
            $"+{rewardBonusPercent:0.#}% Maze Nugget rewards on expedition payouts.",
            $"{feeReductionPercent:0.#}% reduction on gameplay dividend fees.",
        ];
    }

    private static decimal GetEffectDecimal(ItemCatalogEntry item, string key, decimal fallback)
    {
        if (!item.EffectConfig.TryGetValue(key, out var value) || value is null)
        {
            return fallback;
        }

        if (value is JsonElement jsonElement)
        {
            if (jsonElement.ValueKind == JsonValueKind.Number && jsonElement.TryGetDecimal(out var decimalValue))
            {
                return decimalValue;
            }

            if (jsonElement.ValueKind == JsonValueKind.String
                && decimal.TryParse(jsonElement.GetString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var parsed))
            {
                return parsed;
            }

            return fallback;
        }

        try
        {
            return Convert.ToDecimal(value, CultureInfo.InvariantCulture);
        }
        catch
        {
            return fallback;
        }
    }

