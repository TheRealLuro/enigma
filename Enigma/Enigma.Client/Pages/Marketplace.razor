@page "/marketplace"
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web
@inject Enigma.Client.Services.EnigmaApiClient Api
@inject Enigma.Client.Services.UiNotificationService Notifications
@implements IAsyncDisposable

@if (!Embedded)
{
    <SeoHead Title="Enigma Sector Exchange | Sector Trading and Item Shop"
             Description="Trade Enigma sectors, review live listings, and buy item-shop inventory from the sector exchange."
             Robots="noindex,follow"
             OpenGraphType="website"
             SchemaType="WebPage" />
}

@if (IsLoading && !HasLoadedOnce)
{
    <div class="@(Embedded ? "economy-embedded-state" : "content")">
        <div class="card enigma-game-message">
            <div class="loader"></div>
            <p>Loading sector exchange...</p>
        </div>
    </div>
}
else if (Session is null)
{
    <div class="@(Embedded ? "economy-embedded-state" : "content")">
        <div class="card enigma-game-message">
            <h1>Sector exchange unavailable</h1>
            <p>Sign in to browse and trade sectors.</p>
            <div class="enigma-end-actions">
                <button class="btn btn-primary" @onclick="GoHome">Command</button>
                <button class="btn btn-secondary" @onclick="GoLogin">Sign In</button>
            </div>
        </div>
    </div>
}
else
{
    <div class="@(Embedded ? "marketplace-shell economy-embedded-shell" : "content marketplace-shell")">
        <section class="marketplace-banner">
            <div>
                <span class="profile-eyebrow">Sector Exchange</span>
                <h1>Sector Exchange</h1>
                <p>Trade certified sector domains and expedition assets through Enigma's live exchange interface.</p>
            </div>

            <div class="marketplace-banner-metrics">
                <div>
                    <span>Live Listings</span>
                    <strong>@Listings.Count</strong>
                </div>
                <div>
                    <span>Shop Items</span>
                    <strong>@ShopItems.Count</strong>
                </div>
                <div>
                    <span>Listing Volume</span>
                    <strong>@TotalListingVolumeMn.ToString("N0") MN</strong>
                </div>
                <div>
                    <span>Avg Price</span>
                    <strong>@AverageListingPriceMn.ToString("N0") MN</strong>
                </div>
            </div>
        </section>

        @if (HasError && !string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert alert-warning">@StatusMessage</div>
        }

        <div class="profile-tabbar marketplace-tabbar" data-tour-id="marketplace-tabs">
            <button class="@(GetMarketplaceTabClass(MapShopTab))" type="button" @onclick='@(() => SetActiveMarketplaceTab(MapShopTab))'>Sector Exchange</button>
            <button class="@(GetMarketplaceTabClass(ItemShopTab))" type="button" @onclick='@(() => SetActiveMarketplaceTab(ItemShopTab))'>Item Shop</button>
        </div>

        @if (ActiveMarketplaceTab == MapShopTab)
        {
            <section class="panel marketplace-protocol-panel">
                <div class="panel-heading maps-heading">
                    <div>
                        <span class="profile-eyebrow">Trade Protocol</span>
                        <h2>Sector Exchange Rules</h2>
                    </div>
                    <button class="btn btn-secondary" type="button" disabled="@IsLoading" @onclick="@(() => LoadMarketplaceAsync())">
                        @(IsLoading ? "Refreshing..." : "Refresh")
                    </button>
                </div>
                <div class="marketplace-protocol-grid">
                    <article class="marketplace-protocol-card">
                        <span class="marketplace-protocol-kicker">Transfer</span>
                        <h3>Ownership Move</h3>
                        <p>Sector ownership transfers immediately after a successful purchase.</p>
                    </article>
                    <article class="marketplace-protocol-card">
                        <span class="marketplace-protocol-kicker">Payout</span>
                        <h3>Seller Share</h3>
                        <p>Sellers receive <strong>90%</strong> of each completed sale.</p>
                    </article>
                    <article class="marketplace-protocol-card">
                        <span class="marketplace-protocol-kicker">Bank Tax</span>
                        <h3>Enigma Reserve</h3>
                        <p>Enigma Bank receives the remaining <strong>10%</strong>.</p>
                    </article>
                    <article class="marketplace-protocol-card">
                        <span class="marketplace-protocol-kicker">Live Signal</span>
                        <h3>Market Depth</h3>
                        <p>@MapLiveSignal</p>
                    </article>
                </div>
            </section>

            <section class="panel marketplace-sell-panel marketplace-sell-panel-priority">
                <div class="panel-heading maps-heading">
                    <div>
                        <span class="profile-eyebrow">Seller Console</span>
                        <h2>Offer a Sector</h2>
                        <p class="marketplace-seller-copy">List eligible sectors directly to the exchange with live pricing control.</p>
                    </div>
                    <span class="section-count">@AvailableOwnedMaps.Count</span>
                </div>

                <div class="marketplace-seller-status-row">
                    <span class="marketplace-filter-pill muted">@AvailableOwnedMaps.Count ready to list</span>
                    <span class="marketplace-filter-pill muted">@StakedOwnedMapCount under analysis</span>
                </div>

                @if (StakedOwnedMapCount > 0)
                {
                    <div class="empty-state-inline marketplace-seller-note">@StakedOwnedMapCount analyzed sector(s) are hidden from listing until unstaked.</div>
                }

                @if (AvailableOwnedMaps.Count == 0)
                {
                    <div class="empty-state-inline marketplace-seller-note">@GetMapListingEmptyStateMessage()</div>
                }
                else
                {
                    <EditForm FormName="MarketplaceSellForm" Model="SellRequest" OnValidSubmit="ListMapAsync" class="marketplace-sell-form">
                        <DataAnnotationsValidator />

                        <div>
                            <label class="form-label">Owned Sector</label>
                            <EnigmaDropdown TValue="string"
                                            Class="form-control"
                                            Options="AvailableOwnedMapOptions"
                                            @bind-Value="SellRequest.MapName" />
                        </div>

                        <div>
                            <label class="form-label">Listing Price</label>
                            <EnigmaIntStepper Class="form-control"
                                              Min="1"
                                              Max="100000000"
                                              @bind-Value="SellRequest.Price" />
                            <ValidationMessage For="() => SellRequest.Price" />
                        </div>

                        <button class="btn btn-primary" type="submit" disabled="@(!CanListSelectedMap || IsActionBusy)" title="@GetMapListingBlockedReason()">
                            @(GetMapListingButtonLabel())
                        </button>
                    </EditForm>
                }
            </section>

            <section class="panel marketplace-browse-panel">
                <div class="panel-heading maps-heading">
                    <div>
                        <span class="profile-eyebrow">Browse Discoveries</span>
                        <h2>Active Listings</h2>
                    </div>
                    <span class="section-count">@AllFilteredListings.Count</span>
                </div>

                <p class="marketplace-results-copy">@MapListingSummary</p>

                <div class="marketplace-filter-grid marketplace-filter-grid-map">
                    <div class="marketplace-filter-search">
                        <label class="form-label">Search</label>
                        <input class="form-control"
                               type="text"
                               placeholder="Search by sector, seller, or theme"
                               @bind="MapSearchQuery"
                               @bind:event="oninput" />
                    </div>

                    <div>
                        <label class="form-label">Difficulty</label>
                        <EnigmaDropdown TValue="string"
                                        Class="form-control"
                                        Options="MapDifficultyOptions"
                                        @bind-Value="MapDifficultyFilter" />
                    </div>

                    <div>
                        <label class="form-label">Theme</label>
                        <EnigmaDropdown TValue="string"
                                        Class="form-control"
                                        Options="MapThemeOptions"
                                        @bind-Value="MapThemeFilter" />
                    </div>

                    <div>
                        <label class="form-label">Sort By</label>
                        <EnigmaDropdown TValue="string"
                                        Class="form-control"
                                        Options="MapSortOptions"
                                        @bind-Value="MapSortBy" />
                    </div>

                    <div>
                        <label class="form-label">Order</label>
                        <EnigmaDropdown TValue="string"
                                        Class="form-control"
                                        Options="SortOrderOptions"
                                        @bind-Value="MapSortOrder" />
                    </div>
                </div>

                @{
                    var mapFilterChips = GetMapFilterChips();
                }
                <div class="marketplace-filter-toolbar">
                    <div class="marketplace-active-filter-chips">
                        @if (mapFilterChips.Count == 0)
                        {
                            <span class="marketplace-filter-pill muted">No active filters.</span>
                        }
                        else
                        {
                            @foreach (var filterChip in mapFilterChips)
                            {
                                <span class="marketplace-filter-pill">@filterChip</span>
                            }
                        }
                    </div>
                    <button class="btn btn-secondary"
                            type="button"
                            disabled="@(!HasActiveMapFilters)"
                            @onclick="ResetMapFilters">
                        Reset Filters
                    </button>
                </div>
            </section>

            @if (IsLoading)
            {
                <div class="card enigma-game-message">
                    <div class="loader"></div>
                    <p>Refreshing listings...</p>
                </div>
            }
            else if (Listings.Count == 0)
            {
                <section class="panel leaderboard-empty-panel">
                    <h2>No active listings</h2>
                    <p>The exchange is clear right now. Check back soon for new anomaly sectors.</p>
                </section>
            }
            else if (AllFilteredListings.Count == 0)
            {
                <section class="panel leaderboard-empty-panel">
                    <h2>No matching listings</h2>
                    <p>Adjust your search or filters to see more results.</p>
                    <button class="btn btn-secondary" type="button" @onclick="ResetMapFilters">Reset Filters</button>
                </section>
            }
            else
            {
                @if (TotalListingSections > 1)
                {
                    <section class="panel leaderboard-pagination-panel">
                        <p class="leaderboard-pagination-summary">@MapListingSectionSummary</p>

                        <div class="leaderboard-pagination">
                            <button class="btn btn-secondary"
                                    type="button"
                                    disabled="@(!CanGoToPreviousListingSection)"
                                    @onclick="GoToPreviousListingSectionAsync">
                                Previous
                            </button>
                            @foreach (var sectionIndex in GetVisibleListingSectionIndexes())
                            {
                                <button class="@GetListingSectionButtonClass(sectionIndex)"
                                        type="button"
                                        disabled="@IsLoading"
                                        @onclick="() => GoToListingSectionAsync(sectionIndex)">
                                    @(sectionIndex + 1)
                                </button>
                            }
                            <button class="btn btn-secondary"
                                    type="button"
                                    disabled="@(!CanGoToNextListingSection)"
                                    @onclick="GoToNextListingSectionAsync">
                                Next
                            </button>
                        </div>
                    </section>
                }

                <section class="@GetMapListingGridClass()">
                    @foreach (var listing in PagedFilteredListings)
                    {
                        var isOwnListing = IsOwnListing(listing);
                        var missingMn = GetMissingMnForListing(listing);
                        <article class="catalog-card marketplace-card @(IsFeaturedListingLayout ? "marketplace-card-featured" : string.Empty)">
                            <MapImageFrame ImageUrl="@listing.MapImage" AltText="@($"{listing.MapName} artwork")" FallbackText="@listing.MapName" Class="poster" />

                            <div class="catalog-card-body">
                                <div class="marketplace-card-heading-row">
                                    <span class="catalog-card-kicker">Listed by @listing.Seller</span>
                                    <span class="marketplace-listed-at-chip">@listing.ListedAtDisplay</span>
                                </div>
                                <h3>@listing.MapName</h3>
                                <div class="marketplace-listing-chip-row">
                                    <span class="catalog-card-meta-pill">Theme @FormatThemeLabel(listing.Theme)</span>
                                    <span class="catalog-card-meta-pill">Size @listing.Size x @listing.Size</span>
                                    <span class="difficulty-badge difficulty-@GetDifficultyClass(listing.Difficulty)">@listing.Difficulty</span>
                                </div>

                                <strong class="catalog-card-price marketplace-price-hero">@listing.Price.ToString("N0") MN</strong>

                                <div class="catalog-card-meta">
                                    <span>Sector value @listing.Value.ToString("N0") MN</span>
                                    <span>Last sale @DisplayLastSale(listing)</span>
                                </div>

                                <div class="marketplace-card-footer">
                                    <button class="inline-link-button" type="button" @onclick="() => OpenProfile(listing.Seller)">
                                        View seller
                                    </button>
                                    <span class="marketplace-last-sale">Seller @listing.Seller</span>
                                </div>

                                @if (isOwnListing)
                                {
                                    <span class="profile-status-pill">Your listing</span>
                                    <div class="marketplace-owner-tools">
                                        <div class="marketplace-owner-stepper">
                                            <label class="form-label">Listing Price</label>
                                            <EnigmaIntStepper Class="form-control"
                                                              Min="1"
                                                              Max="100000000"
                                                              Value="@GetListingDraftPrice(listing)"
                                                              ValueChanged="@(value => UpdateListingDraftPrice(listing, value))" />
                                        </div>
                                        <div class="marketplace-owner-actions">
                                            <button class="btn btn-primary"
                                                    type="button"
                                                    disabled="@IsActionBusy"
                                                    @onclick="() => UpdateListingPriceAsync(listing)">
                                                @(IsActionBusy ? "Updating..." : "Update Price")
                                            </button>
                                            <button class="btn btn-secondary"
                                                    type="button"
                                                    disabled="@IsActionBusy"
                                                    @onclick="() => RemoveListingAsync(listing)">
                                                @(IsActionBusy ? "Removing..." : "Remove Listing")
                                            </button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    @if (missingMn > 0)
                                    {
                                        <div class="marketplace-card-warning">You need @missingMn.ToString("N0") more MN to purchase this sector.</div>
                                    }
                                    <button class="btn btn-primary" disabled="@(!CanBuy(listing) || IsActionBusy)" @onclick="() => BuyListingAsync(listing)">
                                        @GetBuyLabel(listing)
                                    </button>
                                }
                            </div>
                        </article>
                    }
                </section>
            }

        }
        else
        {
            <section class="panel marketplace-shop-panel" data-tour-id="marketplace-shop">
                <div class="panel-heading maps-heading">
                    <div>
                        <span class="profile-eyebrow">Item Shop</span>
                        <h2>Daily Merchant Stock</h2>
                    </div>
                    <span class="section-count">@ShopItems.Count</span>
                </div>

                <div class="marketplace-bullet-list marketplace-item-shop-copy">
                    <details class="marketplace-faq-collapsible">
                        <summary>Marketplace FAQ: item shop basics</summary>
                        <ol class="marketplace-faq-list">
                            @foreach (var faqEntry in ItemMarketplaceFaqEntries)
                            {
                                <li>
                                    <strong>@faqEntry.Question</strong>
                                    <p>@faqEntry.Answer</p>
                                </li>
                            }
                        </ol>
                    </details>
                </div>

                @if (ShopItems.Count == 0)
                {
                    <div class="empty-state-inline">No item shop stock was returned.</div>
                }
                else
                {
                    <section class="panel marketplace-browse-panel marketplace-item-filter-panel">
                        <div class="panel-heading maps-heading">
                            <div>
                                <span class="profile-eyebrow">Browse Items</span>
                                <h2>Find Merchant Stock</h2>
                            </div>
                            <span class="section-count">@ItemListingSummary</span>
                        </div>

                        <div class="marketplace-filter-grid">
                            <div>
                                <label class="form-label">Search</label>
                                <input class="form-control"
                                       type="text"
                                       placeholder="Search by item name"
                                       @bind="ItemSearchQuery"
                                       @bind:event="oninput" />
                            </div>

                            <div>
                                <label class="form-label">Kind</label>
                                <EnigmaDropdown TValue="string"
                                                Class="form-control"
                                                Options="ItemKindOptions"
                                                @bind-Value="ItemKindFilter" />
                            </div>

                            <div>
                                <label class="form-label">Rarity</label>
                                <EnigmaDropdown TValue="string"
                                                Class="form-control"
                                                Options="ItemRarityOptions"
                                                @bind-Value="ItemRarityFilter" />
                            </div>

                            <div>
                                <label class="form-label">Sort By</label>
                                <EnigmaDropdown TValue="string"
                                                Class="form-control"
                                                Options="ItemSortOptions"
                                                @bind-Value="ItemSortBy" />
                            </div>

                            <div>
                                <label class="form-label">Order</label>
                                <EnigmaDropdown TValue="string"
                                                Class="form-control"
                                                Options="SortOrderOptions"
                                                @bind-Value="ItemSortOrder" />
                            </div>
                        </div>
                    </section>

                    @if (FilteredShopItems.Count == 0)
                    {
                        <div class="empty-state-inline">No merchant items match your current search or filters.</div>
                    }
                    else
                    {
                    <div class="catalog-card-grid marketplace-shop-grid">
                        @foreach (var item in FilteredShopItems)
                        {
                            <article class="catalog-card marketplace-item-card"
                                     role="button"
                                     tabindex="0"
                                     @onclick="() => OpenItemDetails(item)"
                                     @onkeydown="(eventArgs) => HandleItemCardKeyDown(eventArgs, item)">
                                <div class="catalog-card-body">
                                    <div class="marketplace-item-topline">
                                        <span class="catalog-card-kicker">@item.Rarity @item.SlotKind</span>
                                        @if (item.AlwaysAvailable && item.NeverRestock)
                                        {
                                            <span class="catalog-card-meta-pill limited">Limited 10</span>
                                        }
                                    </div>
                                    <h3>@item.Name</h3>
                                    <p class="catalog-card-subline">@item.Description</p>
                                    <strong class="catalog-card-price">@item.Price.ToString("N0") MN</strong>
                                    <div class="catalog-card-meta">
                                        <span class="catalog-card-meta-pill marketplace-item-open-hint">Click for details</span>
                                        <span class="catalog-card-meta-pill">Stock @item.Stock</span>
                                        <span class="catalog-card-meta-pill">Owned @GetOwnedCount(item.ItemId)</span>
                                        <span class="catalog-card-meta-pill">@item.Kind</span>
                                        <span class="catalog-card-meta-pill">Uses @GetUsesLabel(item)</span>
                                        @if (!string.IsNullOrWhiteSpace(GetOwnershipLimitLabel(item)))
                                        {
                                            <span class="catalog-card-meta-pill">@GetOwnershipLimitLabel(item)</span>
                                        }
                                    </div>
                                    @if (item.Requirements.Count > 0)
                                    {
                                        <div class="marketplace-item-requirements">
                                            <strong>Beta Tester Checklist</strong>
                                            @foreach (var requirement in item.Requirements)
                                            {
                                                <div class="marketplace-requirement-row @(requirement.Completed ? "complete" : string.Empty)">
                                                    <span>@(requirement.Completed ? "Complete" : "Pending")</span>
                                                    <span>@requirement.Label</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.PurchaseBlockedReason))
                                    {
                                        <div class="marketplace-item-note">@item.PurchaseBlockedReason</div>
                                    }
                                    @if (item.AlwaysAvailable && item.NeverRestock)
                                    {
                                        <div class="marketplace-item-note">This founder item never restocks. Once all ten are claimed, it is gone permanently.</div>
                                    }
                                    <button class="@GetPurchaseButtonClass(item)"
                                            type="button"
                                            disabled="@(!CanPurchase(item) || IsActionBusy)"
                                            @onclick="() => PurchaseItemAsync(item)"
                                            @onclick:stopPropagation="true">
                                        @GetPurchaseLabel(item)
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                    }
                }
            </section>
        }
    </div>

    @if (SelectedItemDetails is not null)
    {
        <div class="enigma-modal-backdrop marketplace-item-overlay-backdrop" @onclick="CloseItemDetails">
            <aside class="enigma-modal-card marketplace-item-overlay-card" @onclick:stopPropagation="true">
                <button type="button" class="enigma-overlay-close" @onclick="CloseItemDetails">Close</button>

                <header class="marketplace-item-overlay-head">
                    <span class="catalog-card-kicker">@SelectedItemDetails.Rarity @SelectedItemDetails.SlotKind</span>
                    <h2>@SelectedItemDetails.Name</h2>
                    <p>@SelectedItemDetails.Description</p>
                </header>

                <div class="catalog-card-meta marketplace-item-overlay-meta">
                    <span class="catalog-card-meta-pill">Price @SelectedItemDetails.Price.ToString("N0") MN</span>
                    <span class="catalog-card-meta-pill">Stock @SelectedItemDetails.Stock</span>
                    <span class="catalog-card-meta-pill">Owned @GetOwnedCount(SelectedItemDetails.ItemId)</span>
                    <span class="catalog-card-meta-pill">Uses @GetUsesLabel(SelectedItemDetails)</span>
                    <span class="catalog-card-meta-pill">@GetItemTypeSummary(SelectedItemDetails)</span>
                    @if (!string.IsNullOrWhiteSpace(GetOwnershipLimitLabel(SelectedItemDetails)))
                    {
                        <span class="catalog-card-meta-pill">@GetOwnershipLimitLabel(SelectedItemDetails)</span>
                    }
                </div>

                <section class="marketplace-item-overlay-section">
                    <h3>How to use it</h3>
                    <ul class="marketplace-item-overlay-list">
                        @foreach (var step in GetUsageGuideSteps(SelectedItemDetails))
                        {
                            <li>@step</li>
                        }
                    </ul>
                </section>

                <section class="marketplace-item-overlay-section">
                    <h3>Effect details</h3>
                    @{
                        var effectRows = GetEffectDetailRows(SelectedItemDetails);
                    }
                    @if (effectRows.Count == 0)
                    {
                        <p class="marketplace-item-note">No additional effect metadata was provided for this item.</p>
                    }
                    else
                    {
                        <div class="marketplace-item-effect-grid">
                            @foreach (var row in effectRows)
                            {
                                <div class="marketplace-item-effect-row">
                                    <span>@row.Label</span>
                                    <strong>@row.Value</strong>
                                </div>
                            }
                        </div>
                    }
                </section>

                @if (IsFoundersMark(SelectedItemDetails))
                {
                    <section class="marketplace-item-overlay-section marketplace-founder-benefits">
                        <h3>Founder Benefits</h3>
                        <ul class="marketplace-item-overlay-list">
                            @foreach (var benefit in GetFoundersMarkBenefits(SelectedItemDetails))
                            {
                                <li>@benefit</li>
                            }
                        </ul>
                    </section>
                }

                @if (SelectedItemDetails.Requirements.Count > 0)
                {
                    <section class="marketplace-item-overlay-section">
                        <h3>Requirements</h3>
                        <div class="marketplace-item-requirements">
                            @foreach (var requirement in SelectedItemDetails.Requirements)
                            {
                                <div class="marketplace-requirement-row @(requirement.Completed ? "complete" : string.Empty)">
                                    <span>@(requirement.Completed ? "Complete" : "Pending")</span>
                                    <span>@requirement.Label</span>
                                </div>
                            }
                        </div>
                    </section>
                }

                @if (!string.IsNullOrWhiteSpace(SelectedItemDetails.PurchaseBlockedReason))
                {
                    <div class="marketplace-item-note">@SelectedItemDetails.PurchaseBlockedReason</div>
                }

                <div class="marketplace-item-overlay-actions">
                    <button class="@GetPurchaseButtonClass(SelectedItemDetails)"
                            type="button"
                            disabled="@(!CanPurchase(SelectedItemDetails) || IsActionBusy)"
                            @onclick="() => PurchaseItemAsync(SelectedItemDetails)">
                        @GetPurchaseLabel(SelectedItemDetails)
                    </button>
                </div>
            </aside>
        </div>
    }

}

@code {
    [Parameter] public bool Embedded { get; set; }

    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private bool IsLoading { get; set; } = true;
    private bool IsActionBusy { get; set; }
    private bool HasLoadedOnce { get; set; }
    private bool HasError { get; set; }
    private bool _loadingMarketplace;
    private string StatusMessage { get; set; } = string.Empty;
    private string ActiveMarketplaceTab { get; set; } = MapShopTab;
    private LoginUserSummary? Session { get; set; }
    private List<MarketplaceListing> Listings { get; set; } = [];
    private List<ItemCatalogEntry> ShopItems { get; set; } = [];
    private MarketplaceSellForm SellRequest { get; set; } = new();
    private const string MapShopTab = "maps";
    private const string ItemShopTab = "items";
    private const int ListingSectionSize = 10;
    private int CurrentListingSectionIndex { get; set; }
    private readonly Dictionary<string, int> ListingDraftPrices = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> StakedOwnedMapIds { get; set; } = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, DateTimeOffset> StakedMapLockById { get; set; } = new(StringComparer.OrdinalIgnoreCase);
    private CancellationTokenSource? _pollCancellation;
    private Task? _pollTask;
    private DateTimeOffset? _lastMarketplaceRefreshAt;
    private string _mapSearchQuery = string.Empty;
    private string _mapDifficultyFilter = "all";
    private string _mapThemeFilter = "all";
    private string _mapSortBy = "listed_at";
    private string _mapSortOrder = "desc";
    private string MapSearchQuery
    {
        get => _mapSearchQuery;
        set
        {
            var next = value ?? string.Empty;
            if (string.Equals(_mapSearchQuery, next, StringComparison.Ordinal))
