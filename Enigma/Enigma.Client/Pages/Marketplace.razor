    {
        return string.IsNullOrWhiteSpace(listing.LastBoughtDisplay) || listing.LastBoughtDisplay == "Unknown"
            ? "No sale history"
            : listing.LastBoughtDisplay;
    }

    private static string FormatShortAge(DateTimeOffset timestampUtc)
    {
        var elapsed = DateTimeOffset.UtcNow - timestampUtc;
        if (elapsed.TotalSeconds < 60)
        {
            return $"{Math.Max(1, (int)elapsed.TotalSeconds)}s ago";
        }

        if (elapsed.TotalMinutes < 60)
        {
            return $"{Math.Max(1, (int)elapsed.TotalMinutes)}m ago";
        }

        if (elapsed.TotalHours < 24)
        {
            return $"{Math.Max(1, (int)elapsed.TotalHours)}h ago";
        }

        return $"{Math.Max(1, (int)elapsed.TotalDays)}d ago";
    }

    private static string FormatThemeLabel(string? theme)
    {
        if (string.IsNullOrWhiteSpace(theme))
        {
            return "Unknown theme";
        }

        return theme.Replace('_', ' ').Trim();
    }

