@page "/marketplace"
@using System.ComponentModel.DataAnnotations
@inject Enigma.Client.Services.EnigmaApiClient Api

<SeoHead Title="Enigma Marketplace | Map Trading and Item Shop"
         Description="Trade Enigma maps, review live listings, and buy item-shop inventory from the marketplace."
         Robots="noindex,follow"
         OpenGraphType="website"
         SchemaType="WebPage" />

@if (IsLoading && !HasLoadedOnce)
{
    <div class="content">
        <div class="card enigma-game-message">
            <div class="loader"></div>
            <p>Loading marketplace...</p>
        </div>
    </div>
}
else if (Session is null)
{
    <div class="content">
        <div class="card enigma-game-message">
            <h1>Marketplace unavailable</h1>
            <p>Sign in to browse and trade maps.</p>
            <div class="enigma-end-actions">
                <button class="btn btn-primary" @onclick="GoHome">Home</button>
                <button class="btn btn-secondary" @onclick="GoLogin">Login</button>
            </div>
        </div>
    </div>
}
else
{
    <div class="content marketplace-shell">
        <section class="marketplace-banner">
            <div>
                <h1>The Market-Plaza</h1>
            </div>

            <div class="marketplace-banner-metrics">
                <div>
                    <span>Live Listings</span>
                    <strong>@Listings.Count</strong>
                </div>
                <div>
                    <span>Shop Items</span>
                    <strong>@ShopItems.Count</strong>
                </div>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert @(HasError ? "alert-warning" : "alert-info")">@StatusMessage</div>
        }

        <div class="profile-tabbar marketplace-tabbar" data-tour-id="marketplace-tabs">
            <button class="@(GetMarketplaceTabClass(MapShopTab))" type="button" @onclick='@(() => SetActiveMarketplaceTab(MapShopTab))'>Map Shop</button>
            <button class="@(GetMarketplaceTabClass(ItemShopTab))" type="button" @onclick='@(() => SetActiveMarketplaceTab(ItemShopTab))'>Item Shop</button>
        </div>

        @if (ActiveMarketplaceTab == MapShopTab)
        {
            <div class="marketplace-top-grid">
                <section class="panel marketplace-sell-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="profile-eyebrow">Map Shop</span>
                            <h2>List a Map</h2>
                        </div>
                        <button class="btn btn-secondary" type="button" disabled="@IsLoading" @onclick="LoadMarketplaceAsync">
                            @(IsLoading ? "Refreshing..." : "Refresh")
                        </button>
                    </div>

                    @if (AvailableOwnedMaps.Count == 0)
                    {
                        <div class="empty-state-inline">You do not have any unlisted owned maps available for sale.</div>
                    }
                    else
                    {
                        <EditForm FormName="MarketplaceSellForm" Model="SellRequest" OnValidSubmit="ListMapAsync" class="marketplace-sell-form">
                            <DataAnnotationsValidator />

                            <div>
                                <label class="form-label">Owned Map</label>
                                <InputSelect class="form-control" @bind-Value="SellRequest.MapName">
                                    @foreach (var map in AvailableOwnedMaps)
                                    {
                                        <option value="@map.MapName">@map.MapName</option>
                                    }
                                </InputSelect>
                            </div>

                            <div>
                                <label class="form-label">Listing Price</label>
                                <InputNumber class="form-control" @bind-Value="SellRequest.Price" />
                                <ValidationMessage For="() => SellRequest.Price" />
                            </div>

                            <button class="btn btn-primary" type="submit" disabled="@IsActionBusy">
                                @(IsActionBusy ? "Listing..." : "List Map")
                            </button>
                        </EditForm>
                    }
                </section>

                <section class="panel marketplace-info-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="profile-eyebrow">Map Shop</span>
                            <h2>How It Works</h2>
                        </div>
                    </div>
                    <div class="marketplace-bullet-list">
                        <div>Listings refresh live from the backend marketplace APIs.</div>
                        <div>Buying transfers ownership, the buyer pays full price, the seller receives 90%, and Enigma Bank receives 10%.</div>
                        <div>Use this section when you want to trade mazes, not items.</div>
                    </div>
                </section>
            </div>

            @if (IsLoading)
            {
                <div class="card enigma-game-message">
                    <div class="loader"></div>
                    <p>Refreshing listings...</p>
                </div>
            }
            else if (Listings.Count == 0)
            {
                <section class="panel leaderboard-empty-panel">
                    <h2>No active listings</h2>
                    <p>The marketplace is empty right now.</p>
                </section>
            }
            else
            {
                <section class="catalog-card-grid marketplace-grid">
                    @foreach (var listing in Listings)
                    {
                        <article class="catalog-card marketplace-card">
                            <MapImageFrame ImageUrl="@listing.MapImage" AltText="@($"{listing.MapName} artwork")" FallbackText="@listing.MapName" Class="poster" />

                            <div class="catalog-card-body">
                                <span class="catalog-card-kicker">Listed by @listing.Seller</span>
                                <h3>@listing.MapName</h3>
                                <p>@FormatThemeLabel(listing.Theme) | Listed @listing.ListedAtDisplay</p>

                                <strong class="catalog-card-price">@listing.Price.ToString("N0") MN</strong>

                                <div class="catalog-card-meta">
                                    <span>Value @listing.Value.ToString("N0")</span>
                                    <span>Size @listing.Size x @listing.Size</span>
                                    <span class="difficulty-badge difficulty-@GetDifficultyClass(listing.Difficulty)">@listing.Difficulty</span>
                                </div>

                                <div class="marketplace-card-footer">
                                    <button class="inline-link-button" type="button" @onclick="() => OpenProfile(listing.Seller)">
                                        View seller
                                    </button>
                                    <span class="marketplace-last-sale">Last sale @DisplayLastSale(listing)</span>
                                </div>

                                @if (IsOwnListing(listing))
                                {
                                    <span class="profile-status-pill">Your listing</span>
                                }
                                else
                                {
                                    <button class="btn btn-primary" disabled="@(!CanBuy(listing) || IsActionBusy)" @onclick="() => BuyListingAsync(listing)">
                                        @GetBuyLabel(listing)
                                    </button>
                                }
                            </div>
                        </article>
                    }
                </section>
            }
        }
        else
        {
            <section class="panel marketplace-shop-panel" data-tour-id="marketplace-shop">
                <div class="panel-heading maps-heading">
                    <div>
                        <span class="profile-eyebrow">Item Shop</span>
                        <h2>Daily Merchant Stock</h2>
                    </div>
                    <span class="section-count">@ShopItems.Count</span>
                </div>

                <div class="marketplace-bullet-list marketplace-item-shop-copy">
                    <div>Item purchases update your inventory immediately.</div>
                    <div>Use the Play page to select items for your next run.</div>
                    <div>Item shop payments go 100% to Enigma Bank.</div>
                </div>

                @if (ShopItems.Count == 0)
                {
                    <div class="empty-state-inline">No item shop stock was returned.</div>
                }
                else
                {
                    <div class="catalog-card-grid marketplace-shop-grid">
                        @foreach (var item in ShopItems.OrderBy(static item => item.Name, StringComparer.OrdinalIgnoreCase))
                        {
                            <article class="catalog-card marketplace-item-card">
                                <div class="catalog-card-body">
                                    <div class="marketplace-item-topline">
                                        <span class="catalog-card-kicker">@item.Rarity @item.SlotKind</span>
                                        @if (item.AlwaysAvailable && item.NeverRestock)
                                        {
                                            <span class="catalog-card-meta-pill limited">Limited 10</span>
                                        }
                                    </div>
                                    <h3>@item.Name</h3>
                                    <p class="catalog-card-subline">@item.Description</p>
                                    <strong class="catalog-card-price">@item.Price.ToString("N0") MN</strong>
                                    <div class="catalog-card-meta">
                                        <span class="catalog-card-meta-pill">Stock @item.Stock</span>
                                        <span class="catalog-card-meta-pill">Owned @GetOwnedCount(item.ItemId)</span>
                                        <span class="catalog-card-meta-pill">@item.Kind</span>
                                        <span class="catalog-card-meta-pill">Max @item.MaxPerRun</span>
                                    </div>
                                    @if (item.Requirements.Count > 0)
                                    {
                                        <div class="marketplace-item-requirements">
                                            <strong>Beta Tester Checklist</strong>
                                            @foreach (var requirement in item.Requirements)
                                            {
                                                <div class="marketplace-requirement-row @(requirement.Completed ? "complete" : string.Empty)">
                                                    <span>@(requirement.Completed ? "Complete" : "Pending")</span>
                                                    <span>@requirement.Label</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.PurchaseBlockedReason))
                                    {
                                        <div class="marketplace-item-note">@item.PurchaseBlockedReason</div>
                                    }
                                    @if (item.AlwaysAvailable && item.NeverRestock)
                                    {
                                        <div class="marketplace-item-note">This founder item never restocks. Once all ten are claimed, it is gone permanently.</div>
                                    }
                                    <button class="btn btn-primary" type="button" disabled="@(!CanPurchase(item) || IsActionBusy)" @onclick="() => PurchaseItemAsync(item)">
                                        @GetPurchaseLabel(item)
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        }
    </div>
}

@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private bool IsLoading { get; set; } = true;
    private bool IsActionBusy { get; set; }
    private bool HasLoadedOnce { get; set; }
    private bool HasError { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ActiveMarketplaceTab { get; set; } = MapShopTab;
    private LoginUserSummary? Session { get; set; }
    private List<MarketplaceListing> Listings { get; set; } = [];
    private List<ItemCatalogEntry> ShopItems { get; set; } = [];
    private MarketplaceSellForm SellRequest { get; set; } = new();
    private const string MapShopTab = "maps";
    private const string ItemShopTab = "items";

    private List<MapSummary> AvailableOwnedMaps =>
        Session?.MapsOwned
            .Where(map => !string.IsNullOrWhiteSpace(map.MapName))
            .GroupBy(map => map.MapName, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .Where(map => !Listings.Any(listing => EqualsIgnoreCase(listing.MapName, map.MapName)))
            .OrderBy(map => map.MapName, StringComparer.OrdinalIgnoreCase)
            .ToList()
        ?? [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Session = await Api.GetSessionAsync();
        if (Session is null || string.IsNullOrWhiteSpace(Session.Username))
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        await LoadMarketplaceAsync();
    }

    private async Task LoadMarketplaceAsync()
    {
        IsLoading = true;
        HasError = false;
        StatusMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var response = await Api.GetAsync("api/auth/marketplace");
            if (!response.IsSuccessStatusCode)
            {
                HasError = true;
                StatusMessage = await response.Content.ReadAsStringAsync();
                Listings = [];
                ShopItems = [];
                return;
            }

            var payload = await Api.ReadJsonAsync<MarketplaceResponse>(response);
            Listings = payload?.Listings ?? [];
            ShopItems = (await Api.GetFromJsonAsync<ItemShopResponse>("api/auth/items/shop"))?.Items ?? [];

            if (AvailableOwnedMaps.Count > 0 && string.IsNullOrWhiteSpace(SellRequest.MapName))
            {
                SellRequest.MapName = AvailableOwnedMaps[0].MapName;
            }
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
            Listings = [];
            ShopItems = [];
        }
        finally
        {
            IsLoading = false;
            HasLoadedOnce = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ListMapAsync()
    {
        if (Session is null)
        {
            return;
        }

        await PerformMarketplaceActionAsync(
            () => Api.PostJsonAsync("api/auth/marketplace/add", new
            {
                mapName = SellRequest.MapName,
                price = SellRequest.Price,
            }),
            successFallback: "Map listed.");

        await LoadMarketplaceAsync();
    }

    private async Task BuyListingAsync(MarketplaceListing listing)
    {
        if (Session is null)
        {
            return;
        }

        await PerformMarketplaceActionAsync(
            () => Api.PostJsonAsync("api/auth/marketplace/buy", new
            {
                mapName = listing.MapName,
            }),
            successFallback: "Purchase completed.",
            asyncOnSuccess: async () =>
            {
                await RefreshSessionAsync();
                await LoadMarketplaceAsync();
            });
    }

    private async Task PurchaseItemAsync(ItemCatalogEntry item)
    {
        await PerformMarketplaceActionAsync(
            () => Api.PostJsonAsync("api/auth/items/purchase", new
            {
                itemId = item.ItemId,
                quantity = 1,
            }),
            successFallback: $"{item.Name} purchased.",
            asyncOnSuccess: async () =>
            {
                await RefreshSessionAsync();
                await LoadMarketplaceAsync();
            });
    }

    private async Task PerformMarketplaceActionAsync(Func<Task<HttpResponseMessage>> requestFactory, string successFallback, Func<Task>? asyncOnSuccess = null)
    {
        IsActionBusy = true;
        HasError = false;
        StatusMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var response = await requestFactory();
            var payload = await Api.ReadJsonAsync<ApiStatusResponse>(response);

            if (!response.IsSuccessStatusCode)
            {
                HasError = true;
                StatusMessage = payload?.ToDisplayMessage() ?? string.Empty;
                if (string.IsNullOrWhiteSpace(StatusMessage))
                {
                    StatusMessage = await response.Content.ReadAsStringAsync();
                }

                return;
            }

            if (asyncOnSuccess is not null)
            {
                await asyncOnSuccess();
            }

            StatusMessage = payload?.ToDisplayMessage() ?? successFallback;
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsActionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool CanBuy(MarketplaceListing listing)
    {
        return Session is not null
            && !IsOwnListing(listing)
            && Session.MazeNuggets >= listing.Price;
    }

    private bool CanPurchase(ItemCatalogEntry item)
    {
        return Session is not null
            && item.Stock > 0
            && item.CanPurchase
            && !item.IsOwned
            && Session.MazeNuggets >= item.Price;
    }

    private bool IsOwnListing(MarketplaceListing listing)
    {
        return Session is not null && EqualsIgnoreCase(Session.Username, listing.Seller);
    }

    private void SetActiveMarketplaceTab(string tab)
    {
        ActiveMarketplaceTab = string.Equals(tab, ItemShopTab, StringComparison.OrdinalIgnoreCase)
            ? ItemShopTab
            : MapShopTab;
    }

    private string GetMarketplaceTabClass(string tab)
    {
        return ActiveMarketplaceTab == tab ? "profile-tab active" : "profile-tab";
    }

    private static bool EqualsIgnoreCase(string? left, string? right)
    {
        return string.Equals(left?.Trim(), right?.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private int GetOwnedCount(string itemId)
    {
        return Session?.ItemCounts.TryGetValue(itemId, out var count) == true ? count : 0;
    }

    private string GetBuyLabel(MarketplaceListing listing)
    {
        if (IsActionBusy)
        {
            return "Processing...";
        }

        if (Session is null)
        {
            return "Sign in";
        }

        if (Session.MazeNuggets < listing.Price)
        {
            return "Not enough MN";
        }

        return $"Buy for {listing.Price:N0} MN";
    }

    private string GetPurchaseLabel(ItemCatalogEntry item)
    {
        if (IsActionBusy)
        {
            return "Processing...";
        }

        if (Session is null)
        {
            return "Sign in";
        }

        if (item.Stock <= 0)
        {
            return "Out of stock";
        }

        if (item.IsOwned)
        {
            return "Claimed";
        }

        if (!item.CanPurchase)
        {
            return "Locked";
        }

        if (Session.MazeNuggets < item.Price)
        {
            return "Not enough MN";
        }

        return $"Buy for {item.Price:N0} MN";
    }

    private static string DisplayLastSale(MarketplaceListing listing)
    {
        return string.IsNullOrWhiteSpace(listing.LastBoughtDisplay) || listing.LastBoughtDisplay == "Unknown"
            ? "none"
            : listing.LastBoughtDisplay;
    }

    private static string FormatThemeLabel(string? theme)
    {
        if (string.IsNullOrWhiteSpace(theme))
        {
            return "Unknown theme";
        }

        return theme.Replace('_', ' ').Trim();
    }

    private void OpenProfile(string username)
    {
        if (string.IsNullOrWhiteSpace(username))
        {
            return;
        }

        NavigationManager.NavigateTo($"/profile/{Uri.EscapeDataString(username)}");
    }

    private static string GetDifficultyClass(string difficulty)
    {
        return difficulty?.Trim().ToLowerInvariant() switch
        {
            "easy" => "easy",
            "medium" => "medium",
            "hard" => "hard",
            _ => "default",
        };
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/home");
    }

    private void GoLogin()
    {
        NavigationManager.NavigateTo("/");
    }

    private async Task RefreshSessionAsync()
    {
        var session = await Api.GetSessionAsync();
        if (session is null)
        {
            return;
        }

        Session = session;
        await JS.InvokeVoidAsync("enigmaGame.refreshUserSession", session);
    }

    private sealed class MarketplaceSellForm
    {
        [Required]
        public string MapName { get; set; } = string.Empty;

        [Range(1, int.MaxValue, ErrorMessage = "Price must be at least 1 Maze Nugget.")]
        public int Price { get; set; } = 100;
    }
}
