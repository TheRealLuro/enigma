    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Session = await Api.GetSessionAsync();
        if (Session is null || string.IsNullOrWhiteSpace(Session.Username))
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        await LoadMarketplaceAsync();
        StartPolling();
    }

    private void StartPolling()
    {
        if (_pollTask is not null)
        {
            return;
        }

        _pollCancellation = new CancellationTokenSource();
        _pollTask = PollLoopAsync(_pollCancellation.Token);
    }

    private async Task PollLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (cancellationToken.IsCancellationRequested || IsActionBusy)
                {
                    continue;
                }

                await LoadMarketplaceAsync(silent: true);
            }
        }
        catch (OperationCanceledException)
        {
            // ignored
        }
    }

    private async Task LoadMarketplaceAsync(bool silent = false)
    {
        if (_loadingMarketplace)
        {
            return;
        }

        _loadingMarketplace = true;
        if (!silent)
        {
            IsLoading = true;
            HasError = false;
            StatusMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
        }

        try
        {
            using var response = await Api.GetAsync("api/auth/marketplace");
            if (!response.IsSuccessStatusCode)
            {
                if (!silent)
                {
                    HasError = true;
                    StatusMessage = await response.Content.ReadAsStringAsync();
                    Notifications.Warning(StatusMessage);
                    Listings = [];
                    ShopItems = [];
                    StakedOwnedMapIds.Clear();
                    StakedMapLockById.Clear();
                }
                return;
            }

            var payload = await Api.ReadJsonAsync<MarketplaceResponse>(response);
            Listings = payload?.Listings ?? [];
            ListingDraftPrices.Clear();
            ShopItems = (await Api.GetFromJsonAsync<ItemShopResponse>("api/auth/items/shop"))?.Items ?? [];
            await LoadStakingGateStateAsync();
            ClampListingSectionIndex();
            _lastMarketplaceRefreshAt = DateTimeOffset.UtcNow;

            if (AvailableOwnedMaps.Count > 0)
            {
                if (string.IsNullOrWhiteSpace(SellRequest.MapName) || !CanListSelectedMap)
                {
                    SellRequest.MapName = AvailableOwnedMaps[0].MapName;
                }
            }
            else
            {
                SellRequest.MapName = string.Empty;
            }
        }
        catch (Exception ex)
        {
            if (!silent)
            {
                HasError = true;
                StatusMessage = ex.Message;
                Notifications.Error(StatusMessage);
                Listings = [];
                ShopItems = [];
                StakedOwnedMapIds.Clear();
                StakedMapLockById.Clear();
            }
        }
        finally
        {
            IsLoading = false;
            HasLoadedOnce = true;
            _loadingMarketplace = false;
            if (!silent)
            {
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task ListMapAsync()
    {
        if (Session is null)
        {
            return;
        }
        if (!CanListSelectedMap)
        {
            HasError = true;
            StatusMessage = GetMapListingBlockedReason();
            Notifications.Warning(StatusMessage);
            return;
        }

        await PerformMarketplaceActionAsync(
            () => Api.PostJsonAsync("api/auth/marketplace/add", new
            {
                mapName = SellRequest.MapName,
                price = SellRequest.Price,
            }),
            successFallback: "Sector listed.");

        await LoadMarketplaceAsync();
    }

    private async Task LoadStakingGateStateAsync()
    {
        var stakingPayload = await Api.GetFromJsonAsync<StakingOverviewResponse>("api/auth/staking");
        var stakedMaps = stakingPayload?.Overview?.StakedMaps ?? [];
        var mapIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var lockLookup = new Dictionary<string, DateTimeOffset>(StringComparer.OrdinalIgnoreCase);

        foreach (var stakedMap in stakedMaps)
        {
            var mapId = (stakedMap.MapId ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(mapId))
            {
                continue;
            }

            mapIds.Add(mapId);
            if (DateTimeOffset.TryParse(stakedMap.LockedUntil, out var lockUntil))
            {
                lockLookup[mapId] = lockUntil.ToUniversalTime();
            }
        }

        StakedOwnedMapIds = mapIds;
        StakedMapLockById = lockLookup;
        if (stakingPayload?.User is not null)
        {
            Session = stakingPayload.User;
        }
    }

    private async Task BuyListingAsync(MarketplaceListing listing)
    {
        if (Session is null)
        {
            return;
        }

        await PerformMarketplaceActionAsync(
            () => Api.PostJsonAsync("api/auth/marketplace/buy", new
            {
                mapName = listing.MapName,
            }),
            successFallback: "Purchase completed.",
            asyncOnSuccess: async () =>
            {
                await RefreshSessionAsync();
                await LoadMarketplaceAsync();
            });
    }

    private async Task UpdateListingPriceAsync(MarketplaceListing listing)
    {
        if (Session is null || !IsOwnListing(listing))
        {
            return;
        }

        var nextPrice = GetListingDraftPrice(listing);
        if (nextPrice <= 0)
        {
            HasError = true;
            StatusMessage = "Listing price must be greater than zero.";
            return;
        }

        await PerformMarketplaceActionAsync(
            () => Api.PutJsonAsync("api/auth/marketplace/listing/price", new
            {
                mapName = listing.MapName,
                price = nextPrice,
            }),
            successFallback: "Listing price updated.",
            asyncOnSuccess: () => LoadMarketplaceAsync());
    }

    private async Task RemoveListingAsync(MarketplaceListing listing)
    {
        if (Session is null || !IsOwnListing(listing))
        {
            return;
        }

        await PerformMarketplaceActionAsync(
            () => Api.DeleteJsonAsync("api/auth/marketplace/listing", new
            {
                mapName = listing.MapName,
            }),
            successFallback: "Listing removed.",
            asyncOnSuccess: () => LoadMarketplaceAsync());
    }

    private async Task PurchaseItemAsync(ItemCatalogEntry item)
    {
        await PerformMarketplaceActionAsync(
            () => Api.PostJsonAsync("api/auth/items/purchase", new
            {
                itemId = item.ItemId,
                quantity = 1,
            }),
            successFallback: $"{item.Name} purchased.",
            asyncOnSuccess: async () =>
            {
                await RefreshSessionAsync();
                await LoadMarketplaceAsync();
            });
    }

    private async Task PerformMarketplaceActionAsync(Func<Task<HttpResponseMessage>> requestFactory, string successFallback, Func<Task>? asyncOnSuccess = null)
    {
        IsActionBusy = true;
        HasError = false;
        StatusMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var response = await requestFactory();
            var payload = await Api.ReadJsonAsync<ApiStatusResponse>(response);

            if (!response.IsSuccessStatusCode)
            {
                HasError = true;
                StatusMessage = payload?.ToDisplayMessage() ?? string.Empty;
                if (string.IsNullOrWhiteSpace(StatusMessage))
                {
                    StatusMessage = await response.Content.ReadAsStringAsync();
                }
                Notifications.Warning(StatusMessage);

                return;
            }

            if (asyncOnSuccess is not null)
            {
                await asyncOnSuccess();
            }

            StatusMessage = payload?.ToDisplayMessage() ?? successFallback;
            Notifications.Success(StatusMessage);
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
            Notifications.Error(StatusMessage);
        }
        finally
        {
            IsActionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool CanBuy(MarketplaceListing listing)
    {
        return Session is not null
            && !IsOwnListing(listing)
            && Session.MazeNuggets >= listing.Price;
    }

    private bool IsOwnedMapStaked(MapSummary map)
    {
        var mapId = (map.Id ?? string.Empty).Trim();
        return !string.IsNullOrWhiteSpace(mapId) && StakedOwnedMapIds.Contains(mapId);
    }

    private bool TryGetOwnedMapByName(string? mapName, out MapSummary? map)
    {
        map = Session?.MapsOwned.FirstOrDefault(candidate => EqualsIgnoreCase(candidate.MapName, mapName));
        return map is not null;
    }

    private string GetMapListingButtonLabel()
    {
        if (IsActionBusy)
        {
            return "Listing...";
        }

        return CanListSelectedMap ? "List Sector" : "Unavailable";
    }

    private string GetMapListingBlockedReason()
    {
        if (CanListSelectedMap)
        {
            return "List this sector on the anomaly exchange.";
        }

        if (!TryGetOwnedMapByName(SellRequest.MapName, out var selectedMap) || selectedMap is null)
        {
            return "Select an eligible owned sector to list.";
        }

        if (IsOwnedMapStaked(selectedMap))
        {
            var mapId = (selectedMap.Id ?? string.Empty).Trim();
            if (!string.IsNullOrWhiteSpace(mapId)
                && StakedMapLockById.TryGetValue(mapId, out var lockUntil)
                && lockUntil > DateTimeOffset.UtcNow)
            {
                var remaining = lockUntil - DateTimeOffset.UtcNow;
                if (remaining.TotalDays >= 1)
                {
                    return $"This sector is under analysis and locked for {(int)remaining.TotalDays}d {remaining.Hours}h.";
                }

                if (remaining.TotalHours >= 1)
                {
                    return $"This sector is under analysis and locked for {(int)remaining.TotalHours}h {remaining.Minutes}m.";
                }

                return $"This sector is under analysis and locked for {Math.Max(0, remaining.Minutes)}m {Math.Max(0, remaining.Seconds)}s.";
            }

            return "This sector is currently under analysis. Unstake it before listing.";
        }

        if (Listings.Any(listing => EqualsIgnoreCase(listing.MapName, selectedMap.MapName)))
        {
            return "This sector is already listed.";
        }

        return "This sector cannot be listed right now.";
    }

    private string GetMapListingEmptyStateMessage()
    {
        if ((Session?.MapsOwned.Count ?? 0) == 0)
        {
            return "You do not own any sectors yet.";
        }

        if (StakedOwnedMapCount > 0)
        {
            return "All unlisted owned sectors are currently under analysis.";
        }

        return "You do not have any unlisted owned sectors available for sale.";
    }

