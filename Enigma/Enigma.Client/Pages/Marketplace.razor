@page "/marketplace"
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web
@inject Enigma.Client.Services.EnigmaApiClient Api

<SeoHead Title="Enigma Marketplace | Map Trading and Item Shop"
         Description="Trade Enigma maps, review live listings, and buy item-shop inventory from the marketplace."
         Robots="noindex,follow"
         OpenGraphType="website"
         SchemaType="WebPage" />

@if (IsLoading && !HasLoadedOnce)
{
    <div class="content">
        <div class="card enigma-game-message">
            <div class="loader"></div>
            <p>Loading marketplace...</p>
        </div>
    </div>
}
else if (Session is null)
{
    <div class="content">
        <div class="card enigma-game-message">
            <h1>Marketplace unavailable</h1>
            <p>Sign in to browse and trade maps.</p>
            <div class="enigma-end-actions">
                <button class="btn btn-primary" @onclick="GoHome">Home</button>
                <button class="btn btn-secondary" @onclick="GoLogin">Login</button>
            </div>
        </div>
    </div>
}
else
{
    <div class="content marketplace-shell">
        <section class="marketplace-banner">
            <div>
                <h1>Marketplace</h1>
            </div>

            <div class="marketplace-banner-metrics">
                <div>
                    <span>Live Listings</span>
                    <strong>@Listings.Count</strong>
                </div>
                <div>
                    <span>Shop Items</span>
                    <strong>@ShopItems.Count</strong>
                </div>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert @(HasError ? "alert-warning" : "alert-info")">@StatusMessage</div>
        }

        <div class="profile-tabbar marketplace-tabbar" data-tour-id="marketplace-tabs">
            <button class="@(GetMarketplaceTabClass(MapShopTab))" type="button" @onclick='@(() => SetActiveMarketplaceTab(MapShopTab))'>Map Shop</button>
            <button class="@(GetMarketplaceTabClass(ItemShopTab))" type="button" @onclick='@(() => SetActiveMarketplaceTab(ItemShopTab))'>Item Shop</button>
        </div>

        @if (ActiveMarketplaceTab == MapShopTab)
        {
            <div class="marketplace-top-grid">
                <section class="panel marketplace-sell-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="profile-eyebrow">Map Shop</span>
                            <h2>List a Map</h2>
                        </div>
                        <button class="btn btn-secondary" type="button" disabled="@IsLoading" @onclick="LoadMarketplaceAsync">
                            @(IsLoading ? "Refreshing..." : "Refresh")
                        </button>
                    </div>

                    @if (AvailableOwnedMaps.Count == 0)
                    {
                        <div class="empty-state-inline">You do not have any unlisted owned maps available for sale.</div>
                    }
                    else
                    {
                        <EditForm FormName="MarketplaceSellForm" Model="SellRequest" OnValidSubmit="ListMapAsync" class="marketplace-sell-form">
                            <DataAnnotationsValidator />

                            <div>
                                <label class="form-label">Owned Map</label>
                                <EnigmaDropdown TValue="string"
                                                Class="form-control"
                                                Options="AvailableOwnedMapOptions"
                                                @bind-Value="SellRequest.MapName" />
                            </div>

                            <div>
                                <label class="form-label">Listing Price</label>
                                <EnigmaIntStepper Class="form-control"
                                                  Min="1"
                                                  Max="100000000"
                                                  @bind-Value="SellRequest.Price" />
                                <ValidationMessage For="() => SellRequest.Price" />
                            </div>

                            <button class="btn btn-primary" type="submit" disabled="@IsActionBusy">
                                @(IsActionBusy ? "Listing..." : "List Map")
                            </button>
                        </EditForm>
                    }
                </section>

                <section class="panel marketplace-info-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="profile-eyebrow">Map Shop</span>
                            <h2>How It Works</h2>
                        </div>
                    </div>
                    <div class="marketplace-bullet-list">
                        <div>Listings refresh live from the backend marketplace APIs.</div>
                        <div>Buying transfers ownership, the buyer pays full price, the seller receives 90%, and Enigma Bank receives 10%.</div>
                        <div>Use this section when you want to trade mazes, not items.</div>
                    </div>
                </section>
            </div>

            @if (IsLoading)
            {
                <div class="card enigma-game-message">
                    <div class="loader"></div>
                    <p>Refreshing listings...</p>
                </div>
            }
            else if (Listings.Count == 0)
            {
                <section class="panel leaderboard-empty-panel">
                    <h2>No active listings</h2>
                    <p>The marketplace is empty right now.</p>
                </section>
            }
            else
            {
                <section class="panel marketplace-browse-panel">
                    <div class="panel-heading maps-heading">
                        <div>
                            <span class="profile-eyebrow">Browse Maps</span>
                            <h2>Find a Listing</h2>
                        </div>
                        <span class="section-count">@MapListingSummary</span>
                    </div>

                    <div class="marketplace-filter-grid">
                        <div>
                            <label class="form-label">Search</label>
                            <input class="form-control"
                                   type="text"
                                   placeholder="Search by map or seller"
                                   @bind="MapSearchQuery"
                                   @bind:event="oninput" />
                        </div>

                        <div>
                            <label class="form-label">Difficulty</label>
                            <EnigmaDropdown TValue="string"
                                            Class="form-control"
                                            Options="MapDifficultyOptions"
                                            @bind-Value="MapDifficultyFilter" />
                        </div>

                        <div>
                            <label class="form-label">Theme</label>
                            <EnigmaDropdown TValue="string"
                                            Class="form-control"
                                            Options="MapThemeOptions"
                                            @bind-Value="MapThemeFilter" />
                        </div>

                        <div>
                            <label class="form-label">Sort By</label>
                            <EnigmaDropdown TValue="string"
                                            Class="form-control"
                                            Options="MapSortOptions"
                                            @bind-Value="MapSortBy" />
                        </div>

                        <div>
                            <label class="form-label">Order</label>
                            <EnigmaDropdown TValue="string"
                                            Class="form-control"
                                            Options="SortOrderOptions"
                                            @bind-Value="MapSortOrder" />
                        </div>
                    </div>
                </section>

                @if (FilteredListings.Count == 0)
                {
                    <section class="panel leaderboard-empty-panel">
                        <h2>No matching listings</h2>
                        <p>Adjust the current map search or filter settings.</p>
                    </section>
                }
                else
                {
                <section class="catalog-card-grid marketplace-grid">
                    @foreach (var listing in FilteredListings)
                    {
                        <article class="catalog-card marketplace-card">
                            <MapImageFrame ImageUrl="@listing.MapImage" AltText="@($"{listing.MapName} artwork")" FallbackText="@listing.MapName" Class="poster" />

                            <div class="catalog-card-body">
                                <span class="catalog-card-kicker">Listed by @listing.Seller</span>
                                <h3>@listing.MapName</h3>
                                <p>@FormatThemeLabel(listing.Theme) | Listed @listing.ListedAtDisplay</p>

                                <strong class="catalog-card-price">@listing.Price.ToString("N0") MN</strong>

                                <div class="catalog-card-meta">
                                    <span>Value @listing.Value.ToString("N0")</span>
                                    <span>Size @listing.Size x @listing.Size</span>
                                    <span class="difficulty-badge difficulty-@GetDifficultyClass(listing.Difficulty)">@listing.Difficulty</span>
                                </div>

                                <div class="marketplace-card-footer">
                                    <button class="inline-link-button" type="button" @onclick="() => OpenProfile(listing.Seller)">
                                        View seller
                                    </button>
                                    <span class="marketplace-last-sale">Last sale @DisplayLastSale(listing)</span>
                                </div>

                                @if (IsOwnListing(listing))
                                {
                                    <span class="profile-status-pill">Your listing</span>
                                }
                                else
                                {
                                    <button class="btn btn-primary" disabled="@(!CanBuy(listing) || IsActionBusy)" @onclick="() => BuyListingAsync(listing)">
                                        @GetBuyLabel(listing)
                                    </button>
                                }
                            </div>
                        </article>
                    }
                </section>
                }
            }
        }
        else
        {
            <section class="panel marketplace-shop-panel" data-tour-id="marketplace-shop">
                <div class="panel-heading maps-heading">
                    <div>
                        <span class="profile-eyebrow">Item Shop</span>
                        <h2>Daily Merchant Stock</h2>
                    </div>
                    <span class="section-count">@ShopItems.Count</span>
                </div>

                <div class="marketplace-bullet-list marketplace-item-shop-copy">
                    <article class="marketplace-faq-card"
                             role="button"
                             tabindex="0"
                             @onclick="OpenMarketplaceFaq"
                             @onkeydown="HandleMarketplaceFaqKeyDown">
                        <div>
                            <span class="profile-eyebrow">Marketplace FAQ</span>
                            <h3>How item shop purchases work</h3>
                            <p>Open the FAQ overlay for a quick numbered guide.</p>
                        </div>
                        <button type="button"
                                class="btn btn-secondary marketplace-faq-open-button"
                                @onclick="OpenMarketplaceFaq"
                                @onclick:stopPropagation="true">
                            View FAQ
                        </button>
                    </article>
                </div>

                @if (ShopItems.Count == 0)
                {
                    <div class="empty-state-inline">No item shop stock was returned.</div>
                }
                else
                {
                    <section class="panel marketplace-browse-panel marketplace-item-filter-panel">
                        <div class="panel-heading maps-heading">
                            <div>
                                <span class="profile-eyebrow">Browse Items</span>
                                <h2>Find Merchant Stock</h2>
                            </div>
                            <span class="section-count">@ItemListingSummary</span>
                        </div>

                        <div class="marketplace-filter-grid">
                            <div>
                                <label class="form-label">Search</label>
                                <input class="form-control"
                                       type="text"
                                       placeholder="Search by item name"
                                       @bind="ItemSearchQuery"
                                       @bind:event="oninput" />
                            </div>

                            <div>
                                <label class="form-label">Kind</label>
                                <EnigmaDropdown TValue="string"
                                                Class="form-control"
                                                Options="ItemKindOptions"
                                                @bind-Value="ItemKindFilter" />
                            </div>

                            <div>
                                <label class="form-label">Rarity</label>
                                <EnigmaDropdown TValue="string"
                                                Class="form-control"
                                                Options="ItemRarityOptions"
                                                @bind-Value="ItemRarityFilter" />
                            </div>

                            <div>
                                <label class="form-label">Sort By</label>
                                <EnigmaDropdown TValue="string"
                                                Class="form-control"
                                                Options="ItemSortOptions"
                                                @bind-Value="ItemSortBy" />
                            </div>

                            <div>
                                <label class="form-label">Order</label>
                                <EnigmaDropdown TValue="string"
                                                Class="form-control"
                                                Options="SortOrderOptions"
                                                @bind-Value="ItemSortOrder" />
                            </div>
                        </div>
                    </section>

                    @if (FilteredShopItems.Count == 0)
                    {
                        <div class="empty-state-inline">No merchant items match your current search or filters.</div>
                    }
                    else
                    {
                    <div class="catalog-card-grid marketplace-shop-grid">
                        @foreach (var item in FilteredShopItems)
                        {
                            <article class="catalog-card marketplace-item-card"
                                     role="button"
                                     tabindex="0"
                                     @onclick="() => OpenItemDetails(item)"
                                     @onkeydown="(eventArgs) => HandleItemCardKeyDown(eventArgs, item)">
                                <div class="catalog-card-body">
                                    <div class="marketplace-item-topline">
                                        <span class="catalog-card-kicker">@item.Rarity @item.SlotKind</span>
                                        @if (item.AlwaysAvailable && item.NeverRestock)
                                        {
                                            <span class="catalog-card-meta-pill limited">Limited 10</span>
                                        }
                                    </div>
                                    <h3>@item.Name</h3>
                                    <p class="catalog-card-subline">@item.Description</p>
                                    <strong class="catalog-card-price">@item.Price.ToString("N0") MN</strong>
                                    <div class="catalog-card-meta">
                                        <span class="catalog-card-meta-pill marketplace-item-open-hint">Click for details</span>
                                        <span class="catalog-card-meta-pill">Stock @item.Stock</span>
                                        <span class="catalog-card-meta-pill">Owned @GetOwnedCount(item.ItemId)</span>
                                        <span class="catalog-card-meta-pill">@item.Kind</span>
                                        <span class="catalog-card-meta-pill">Uses @GetUsesLabel(item)</span>
                                        @if (!string.IsNullOrWhiteSpace(GetOwnershipLimitLabel(item)))
                                        {
                                            <span class="catalog-card-meta-pill">@GetOwnershipLimitLabel(item)</span>
                                        }
                                    </div>
                                    @if (item.Requirements.Count > 0)
                                    {
                                        <div class="marketplace-item-requirements">
                                            <strong>Beta Tester Checklist</strong>
                                            @foreach (var requirement in item.Requirements)
                                            {
                                                <div class="marketplace-requirement-row @(requirement.Completed ? "complete" : string.Empty)">
                                                    <span>@(requirement.Completed ? "Complete" : "Pending")</span>
                                                    <span>@requirement.Label</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.PurchaseBlockedReason))
                                    {
                                        <div class="marketplace-item-note">@item.PurchaseBlockedReason</div>
                                    }
                                    @if (item.AlwaysAvailable && item.NeverRestock)
                                    {
                                        <div class="marketplace-item-note">This founder item never restocks. Once all ten are claimed, it is gone permanently.</div>
                                    }
                                    <button class="@GetPurchaseButtonClass(item)"
                                            type="button"
                                            disabled="@(!CanPurchase(item) || IsActionBusy)"
                                            @onclick="() => PurchaseItemAsync(item)"
                                            @onclick:stopPropagation="true">
                                        @GetPurchaseLabel(item)
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                    }
                }
            </section>
        }
    </div>

    @if (SelectedItemDetails is not null)
    {
        <div class="enigma-modal-backdrop marketplace-item-overlay-backdrop" @onclick="CloseItemDetails">
            <aside class="enigma-modal-card marketplace-item-overlay-card" @onclick:stopPropagation="true">
                <button type="button" class="enigma-overlay-close" @onclick="CloseItemDetails">Close</button>

                <header class="marketplace-item-overlay-head">
                    <span class="catalog-card-kicker">@SelectedItemDetails.Rarity @SelectedItemDetails.SlotKind</span>
                    <h2>@SelectedItemDetails.Name</h2>
                    <p>@SelectedItemDetails.Description</p>
                </header>

                <div class="catalog-card-meta marketplace-item-overlay-meta">
                    <span class="catalog-card-meta-pill">Price @SelectedItemDetails.Price.ToString("N0") MN</span>
                    <span class="catalog-card-meta-pill">Stock @SelectedItemDetails.Stock</span>
                    <span class="catalog-card-meta-pill">Owned @GetOwnedCount(SelectedItemDetails.ItemId)</span>
                    <span class="catalog-card-meta-pill">Uses @GetUsesLabel(SelectedItemDetails)</span>
                    <span class="catalog-card-meta-pill">@GetItemTypeSummary(SelectedItemDetails)</span>
                    @if (!string.IsNullOrWhiteSpace(GetOwnershipLimitLabel(SelectedItemDetails)))
                    {
                        <span class="catalog-card-meta-pill">@GetOwnershipLimitLabel(SelectedItemDetails)</span>
                    }
                </div>

                <section class="marketplace-item-overlay-section">
                    <h3>How to use it</h3>
                    <ul class="marketplace-item-overlay-list">
                        @foreach (var step in GetUsageGuideSteps(SelectedItemDetails))
                        {
                            <li>@step</li>
                        }
                    </ul>
                </section>

                <section class="marketplace-item-overlay-section">
                    <h3>Effect details</h3>
                    @{
                        var effectRows = GetEffectDetailRows(SelectedItemDetails);
                    }
                    @if (effectRows.Count == 0)
                    {
                        <p class="marketplace-item-note">No additional effect metadata was provided for this item.</p>
                    }
                    else
                    {
                        <div class="marketplace-item-effect-grid">
                            @foreach (var row in effectRows)
                            {
                                <div class="marketplace-item-effect-row">
                                    <span>@row.Label</span>
                                    <strong>@row.Value</strong>
                                </div>
                            }
                        </div>
                    }
                </section>

                @if (SelectedItemDetails.Requirements.Count > 0)
                {
                    <section class="marketplace-item-overlay-section">
                        <h3>Requirements</h3>
                        <div class="marketplace-item-requirements">
                            @foreach (var requirement in SelectedItemDetails.Requirements)
                            {
                                <div class="marketplace-requirement-row @(requirement.Completed ? "complete" : string.Empty)">
                                    <span>@(requirement.Completed ? "Complete" : "Pending")</span>
                                    <span>@requirement.Label</span>
                                </div>
                            }
                        </div>
                    </section>
                }

                @if (!string.IsNullOrWhiteSpace(SelectedItemDetails.PurchaseBlockedReason))
                {
                    <div class="marketplace-item-note">@SelectedItemDetails.PurchaseBlockedReason</div>
                }

                <div class="marketplace-item-overlay-actions">
                    <button class="@GetPurchaseButtonClass(SelectedItemDetails)"
                            type="button"
                            disabled="@(!CanPurchase(SelectedItemDetails) || IsActionBusy)"
                            @onclick="() => PurchaseItemAsync(SelectedItemDetails)">
                        @GetPurchaseLabel(SelectedItemDetails)
                    </button>
                </div>
            </aside>
        </div>
    }

    @if (IsMarketplaceFaqOpen)
    {
        <div class="enigma-modal-backdrop marketplace-faq-overlay-backdrop" @onclick="CloseMarketplaceFaq">
            <aside class="enigma-modal-card marketplace-faq-overlay-card" @onclick:stopPropagation="true">
                <button type="button" class="enigma-overlay-close" @onclick="CloseMarketplaceFaq">Close</button>
                <header class="marketplace-item-overlay-head">
                    <span class="catalog-card-kicker">Marketplace FAQ</span>
                    <h2>Item Shop Guide</h2>
                    <p>Use this quick reference to understand item purchases and run usage.</p>
                </header>
                <ol class="marketplace-faq-list">
                    @foreach (var faqEntry in MarketplaceFaqEntries)
                    {
                        <li>@faqEntry</li>
                    }
                </ol>
            </aside>
        </div>
    }
}

@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private bool IsLoading { get; set; } = true;
    private bool IsActionBusy { get; set; }
    private bool HasLoadedOnce { get; set; }
    private bool HasError { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ActiveMarketplaceTab { get; set; } = MapShopTab;
    private LoginUserSummary? Session { get; set; }
    private List<MarketplaceListing> Listings { get; set; } = [];
    private List<ItemCatalogEntry> ShopItems { get; set; } = [];
    private MarketplaceSellForm SellRequest { get; set; } = new();
    private const string MapShopTab = "maps";
    private const string ItemShopTab = "items";
    private string MapSearchQuery { get; set; } = string.Empty;
    private string MapDifficultyFilter { get; set; } = "all";
    private string MapThemeFilter { get; set; } = "all";
    private string MapSortBy { get; set; } = "listed_at";
    private string MapSortOrder { get; set; } = "desc";
    private string ItemSearchQuery { get; set; } = string.Empty;
    private string ItemKindFilter { get; set; } = "all";
    private string ItemRarityFilter { get; set; } = "all";
    private string ItemSortBy { get; set; } = "name";
    private string ItemSortOrder { get; set; } = "asc";
    private ItemCatalogEntry? SelectedItemDetails { get; set; }
    private bool IsMarketplaceFaqOpen { get; set; }

    private static readonly IReadOnlyList<string> MarketplaceFaqEntries =
    [
        "Item purchases update your inventory immediately.",
        "Use the Play page to select items for your next run.",
        "Item shop payments go 100% to Enigma Bank.",
    ];

    private static readonly IReadOnlyList<SelectOption<string>> SortOrderOptions =
    [
        new("asc", "Ascending"),
        new("desc", "Descending"),
    ];

    private static readonly IReadOnlyList<SelectOption<string>> MapSortOptions =
    [
        new("listed_at", "Recently Listed"),
        new("price", "Price"),
        new("value", "Map Value"),
        new("size", "Size"),
        new("name", "Map Name"),
    ];

    private static readonly IReadOnlyList<SelectOption<string>> ItemSortOptions =
    [
        new("name", "Item Name"),
        new("price", "Price"),
        new("rarity", "Rarity"),
        new("stock", "Stock"),
        new("owned", "Owned Count"),
    ];

    private List<MapSummary> AvailableOwnedMaps =>
        Session?.MapsOwned
            .Where(map => !string.IsNullOrWhiteSpace(map.MapName))
            .GroupBy(map => map.MapName, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .Where(map => !Listings.Any(listing => EqualsIgnoreCase(listing.MapName, map.MapName)))
            .OrderBy(map => map.MapName, StringComparer.OrdinalIgnoreCase)
            .ToList()
        ?? [];
    private IReadOnlyList<SelectOption<string>> AvailableOwnedMapOptions =>
        AvailableOwnedMaps.Select(static map => new SelectOption<string>(map.MapName, map.MapName)).ToArray();
    private IReadOnlyList<SelectOption<string>> MapDifficultyOptions =>
        BuildOptionsWithAll(
            Listings.Select(static listing => listing.Difficulty)
                .Where(static difficulty => !string.IsNullOrWhiteSpace(difficulty))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(static difficulty => difficulty, StringComparer.OrdinalIgnoreCase),
            "All difficulties");
    private IReadOnlyList<SelectOption<string>> MapThemeOptions =>
        BuildOptionsWithAll(
            Listings.Select(static listing => listing.Theme)
                .Where(static theme => !string.IsNullOrWhiteSpace(theme))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(static theme => theme, StringComparer.OrdinalIgnoreCase),
            "All themes",
            FormatThemeLabel);
    private IReadOnlyList<SelectOption<string>> ItemKindOptions =>
        BuildOptionsWithAll(
            ShopItems.Select(static item => item.Kind)
                .Where(static kind => !string.IsNullOrWhiteSpace(kind))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(static kind => kind, StringComparer.OrdinalIgnoreCase),
            "All kinds");
    private IReadOnlyList<SelectOption<string>> ItemRarityOptions =>
        BuildOptionsWithAll(
            ShopItems.Select(static item => item.Rarity)
                .Where(static rarity => !string.IsNullOrWhiteSpace(rarity))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(static rarity => GetRarityOrder(rarity))
                .ThenBy(static rarity => rarity, StringComparer.OrdinalIgnoreCase),
            "All rarities");

    private List<MarketplaceListing> FilteredListings =>
        ApplyMapSort(
            Listings.Where(listing =>
                    MatchesMapSearch(listing)
                    && MatchesFilter(listing.Difficulty, MapDifficultyFilter)
                    && MatchesFilter(listing.Theme, MapThemeFilter))
                .ToList())
        .ToList();
    private List<ItemCatalogEntry> FilteredShopItems =>
        ApplyItemSort(
            ShopItems.Where(item =>
                    MatchesItemSearch(item)
                    && MatchesFilter(item.Kind, ItemKindFilter)
                    && MatchesFilter(item.Rarity, ItemRarityFilter))
                .ToList())
        .ToList();
    private string MapListingSummary => $"Showing {FilteredListings.Count} of {Listings.Count}";
    private string ItemListingSummary => $"Showing {FilteredShopItems.Count} of {ShopItems.Count}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Session = await Api.GetSessionAsync();
        if (Session is null || string.IsNullOrWhiteSpace(Session.Username))
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        await LoadMarketplaceAsync();
    }

    private async Task LoadMarketplaceAsync()
    {
        IsLoading = true;
        HasError = false;
        StatusMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var response = await Api.GetAsync("api/auth/marketplace");
            if (!response.IsSuccessStatusCode)
            {
                HasError = true;
                StatusMessage = await response.Content.ReadAsStringAsync();
                Listings = [];
                ShopItems = [];
                return;
            }

            var payload = await Api.ReadJsonAsync<MarketplaceResponse>(response);
            Listings = payload?.Listings ?? [];
            ShopItems = (await Api.GetFromJsonAsync<ItemShopResponse>("api/auth/items/shop"))?.Items ?? [];

            if (AvailableOwnedMaps.Count > 0 && string.IsNullOrWhiteSpace(SellRequest.MapName))
            {
                SellRequest.MapName = AvailableOwnedMaps[0].MapName;
            }
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
            Listings = [];
            ShopItems = [];
        }
        finally
        {
            IsLoading = false;
            HasLoadedOnce = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ListMapAsync()
    {
        if (Session is null)
        {
            return;
        }

        await PerformMarketplaceActionAsync(
            () => Api.PostJsonAsync("api/auth/marketplace/add", new
            {
                mapName = SellRequest.MapName,
                price = SellRequest.Price,
            }),
            successFallback: "Map listed.");

        await LoadMarketplaceAsync();
    }

    private async Task BuyListingAsync(MarketplaceListing listing)
    {
        if (Session is null)
        {
            return;
        }

        await PerformMarketplaceActionAsync(
            () => Api.PostJsonAsync("api/auth/marketplace/buy", new
            {
                mapName = listing.MapName,
            }),
            successFallback: "Purchase completed.",
            asyncOnSuccess: async () =>
            {
                await RefreshSessionAsync();
                await LoadMarketplaceAsync();
            });
    }

    private async Task PurchaseItemAsync(ItemCatalogEntry item)
    {
        await PerformMarketplaceActionAsync(
            () => Api.PostJsonAsync("api/auth/items/purchase", new
            {
                itemId = item.ItemId,
                quantity = 1,
            }),
            successFallback: $"{item.Name} purchased.",
            asyncOnSuccess: async () =>
            {
                await RefreshSessionAsync();
                await LoadMarketplaceAsync();
            });
    }

    private async Task PerformMarketplaceActionAsync(Func<Task<HttpResponseMessage>> requestFactory, string successFallback, Func<Task>? asyncOnSuccess = null)
    {
        IsActionBusy = true;
        HasError = false;
        StatusMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var response = await requestFactory();
            var payload = await Api.ReadJsonAsync<ApiStatusResponse>(response);

            if (!response.IsSuccessStatusCode)
            {
                HasError = true;
                StatusMessage = payload?.ToDisplayMessage() ?? string.Empty;
                if (string.IsNullOrWhiteSpace(StatusMessage))
                {
                    StatusMessage = await response.Content.ReadAsStringAsync();
                }

                return;
            }

            if (asyncOnSuccess is not null)
            {
                await asyncOnSuccess();
            }

            StatusMessage = payload?.ToDisplayMessage() ?? successFallback;
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsActionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool CanBuy(MarketplaceListing listing)
    {
        return Session is not null
            && !IsOwnListing(listing)
            && Session.MazeNuggets >= listing.Price;
