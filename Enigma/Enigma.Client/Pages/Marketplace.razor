    private static string GetItemTypeSummary(ItemCatalogEntry item)
    {
        var labels = new List<string>();
        if (!string.IsNullOrWhiteSpace(item.Category))
        {
            labels.Add(ToDisplayLabel(item.Category));
        }

        if (!string.IsNullOrWhiteSpace(item.Kind) && !EqualsIgnoreCase(item.Kind, item.Category))
        {
            labels.Add(ToDisplayLabel(item.Kind));
        }

        if (!string.IsNullOrWhiteSpace(item.SlotKind))
        {
            labels.Add($"{ToDisplayLabel(item.SlotKind)} slot");
        }

        if (labels.Count == 0)
        {
            return "Utility item";
        }

        return string.Join(" | ", labels.Distinct(StringComparer.OrdinalIgnoreCase));
    }

    private static IReadOnlyList<string> GetUsageGuideSteps(ItemCatalogEntry item)
    {
        var steps = new List<string>
        {
            "Buy this item in the marketplace and equip it from the Play screen before you start a run.",
        };

        if (item.MaxPerRun <= 0)
        {
            steps.Add("This is a permanent perk. It stays active after purchase and does not consume run uses.");
        }
        else
        {
            var usesText = item.MaxPerRun == 1 ? "1 use" : $"{item.MaxPerRun} uses";
            steps.Add($"Run limit: {usesText} per maze run.");
        }

        steps.Add(item.SlotKind.Trim().ToLowerInvariant() switch
        {
            "passive" => "Passive items auto-apply during the run.",
            "high_power" => "High-power items are best saved for high-pressure moments.",
            "perk" => "Perk effects are always active and do not need manual activation.",
            _ => "Support items can be triggered when you need puzzle or traversal help.",
        });

        return steps;
    }

    private static IReadOnlyList<ItemDetailRow> GetEffectDetailRows(ItemCatalogEntry item)
    {
        if (item.EffectConfig.Count == 0)
        {
            return [];
        }

        var details = new List<ItemDetailRow>();
        foreach (var detail in item.EffectConfig.OrderBy(entry => entry.Key, StringComparer.OrdinalIgnoreCase))
        {
            details.Add(new ItemDetailRow(
                Label: ToDisplayLabel(detail.Key),
                Value: FormatEffectValue(detail.Key, detail.Value)));
        }

        return details;
    }

    private static string ToDisplayLabel(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Detail";
        }

        var tokens = value
            .Replace('_', ' ')
            .Replace('-', ' ')
            .Split(' ', StringSplitOptions.RemoveEmptyEntries);

        return string.Join(" ", tokens.Select(token => token.Length <= 1
            ? token.ToUpperInvariant()
            : char.ToUpperInvariant(token[0]) + token[1..].ToLowerInvariant()));
    }

    private static string FormatEffectValue(string key, object? value)
    {
        if (value is null)
        {
            return "None";
        }

        if (value is JsonElement jsonElement)
        {
            return FormatJsonElement(key, jsonElement);
        }

        return FormatScalarValue(key, value);
    }

    private static string FormatJsonElement(string key, JsonElement value)
    {
        return value.ValueKind switch
        {
            JsonValueKind.String => FormatScalarValue(key, value.GetString() ?? string.Empty),
            JsonValueKind.Number when value.TryGetInt64(out var integer) => FormatNumericValue(key, integer),
            JsonValueKind.Number when value.TryGetDouble(out var number) => FormatNumericValue(key, (decimal)number),
            JsonValueKind.True => "Yes",
            JsonValueKind.False => "No",
            JsonValueKind.Array => string.Join(", ", value.EnumerateArray().Select(entry => FormatJsonElement(key, entry))),
            JsonValueKind.Object => string.Join(
                ", ",
                value.EnumerateObject().Select(property => $"{ToDisplayLabel(property.Name)}: {FormatJsonElement(property.Name, property.Value)}")),
            _ => value.ToString(),
        };
    }

    private static string FormatScalarValue(string key, object value)
    {
        return value switch
        {
            bool boolValue => boolValue ? "Yes" : "No",
            byte number => FormatNumericValue(key, number),
            sbyte number => FormatNumericValue(key, number),
            short number => FormatNumericValue(key, number),
            ushort number => FormatNumericValue(key, number),
            int number => FormatNumericValue(key, number),
            uint number => FormatNumericValue(key, number),
            long number => FormatNumericValue(key, number),
            ulong number => FormatNumericValue(key, number),
            float number => FormatNumericValue(key, (decimal)number),
            double number => FormatNumericValue(key, (decimal)number),
            decimal number => FormatNumericValue(key, number),
            string text => text,
            _ => value.ToString() ?? string.Empty,
        };
    }

    private static string FormatNumericValue(string key, decimal value)
    {
        var normalizedKey = key.Trim().ToLowerInvariant();
        if (normalizedKey.Contains("multiplier", StringComparison.Ordinal))
        {
            return $"{value:0.##}x";
        }

        if (normalizedKey.Contains("seconds", StringComparison.Ordinal)
            || normalizedKey.Contains("duration", StringComparison.Ordinal))
        {
            return $"{value:0.##}s";
        }

        if (normalizedKey.Contains("percent", StringComparison.Ordinal))
        {
            return $"{value:0.##}%";
        }

        if (decimal.Truncate(value) == value)
        {
            return value.ToString("0", CultureInfo.InvariantCulture);
        }

        return value.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private string GetBuyLabel(MarketplaceListing listing)
    {
        if (IsActionBusy)
        {
            return "Processing...";
        }

        if (Session is null)
        {
            return "Sign in";
        }

        if (Session.MazeNuggets < listing.Price)
        {
            return "Not enough MN";
        }

        return $"Buy for {listing.Price:N0} MN";
    }

    private string GetPurchaseLabel(ItemCatalogEntry item)
    {
        if (IsActionBusy)
        {
            return "Processing...";
        }

        if (Session is null)
        {
            return "Sign in";
        }

        if (item.Stock <= 0)
        {
            return "Out of stock";
        }

        if (IsOnePerPersonOwned(item))
        {
            return "You already own this";
        }

        if (!item.CanPurchase)
        {
            return "Locked";
        }

        if (Session.MazeNuggets < item.Price)
        {
            return "Not enough MN";
        }

        return $"Buy for {item.Price:N0} MN";
    }

