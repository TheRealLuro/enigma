@page "/play"
@using System.ComponentModel.DataAnnotations
@using Enigma.Client.Models.Gameplay
@inject Enigma.Client.Services.EnigmaApiClient Api

<PageTitle>Play Game</PageTitle>

<div class="container mt-5 play-page-shell">

    <section class="play-page-header play-page-banner">
        <div class="play-page-header-copy">
            <span class="profile-kicker">Run Setup</span>
            <h1 class="mb-2">Start a Maze Run</h1>
            <p>Choose a maze, equip up to three items, and confirm fullscreen before you enter.</p>
        </div>
        <div class="play-header-actions">
            <button class="btn btn-secondary" type="button" @onclick="OpenCoopLobby">Co-op Lobby</button>
        </div>
    </section>

    <div class="play-setup-grid">
        <div class="play-forms-column">
            <div class="card shadow-sm p-4 mb-4 play-card">
                <h4 class="mb-3">Generate New Maze</h4>

                <EditForm FormName="NewForm" OnValidSubmit="OnNewClick" Model="newMazeRequest">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Difficulty</label>
                        <InputSelect class="form-select" @bind-Value="newMazeRequest.Difficulty">
                            @foreach (var difficulty in Enum.GetValues<Difficulty>())
                            {
                                <option value="@difficulty">@difficulty</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Size</label>
                        <InputNumber @bind-Value="newMazeRequest.Size" class="form-control" />
                        <ValidationMessage For="() => newMazeRequest.Size" />
                    </div>

                    <button class="btn btn-success w-100" disabled="@IsBusy">
                        @(IsBusy ? "Generating..." : "Generate Maze")
                    </button>
                </EditForm>
            </div>

            <div class="card shadow-sm p-4 mb-4 play-card">
                <h4 class="mb-3">Load Maze by Name</h4>

                <EditForm FormName="FromNameForm" OnValidSubmit="OnSeedClick" Model="loadMazeRequest">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Map Name</label>
                        <InputText @bind-Value="loadMazeRequest.MapName" class="form-control" />
                        <ValidationMessage For="() => loadMazeRequest.MapName" />
                    </div>

                    <button class="btn btn-primary w-100" disabled="@IsBusy">
                        @(IsBusy ? "Loading..." : "Load Maze")
                    </button>
                </EditForm>
            </div>
        </div>

        <div class="card shadow-sm p-4 play-card play-loadout-card">
            <div class="play-loadout-heading">
                <div>
                    <span class="profile-kicker">Inventory</span>
                    <h4 class="mb-1">Select Your Loadout</h4>
                </div>
                <span class="section-count">@SelectedItems.Count / 3</span>
            </div>
            <p class="play-loadout-copy">Pick up to three items. Passive items count toward the same cap.</p>

            @if (Inventory.Count == 0)
            {
                <div class="empty-state-inline">No owned items yet. Buy items from the marketplace item shop.</div>
            }
            else
            {
                <div class="play-loadout-grid">
                    @foreach (var item in Inventory)
                    {
                        var isSelected = SelectedItems.TryGetValue(item.ItemId, out var selectedQty) && selectedQty > 0;
                        <article class="play-item-card @(isSelected ? "selected" : string.Empty)">
                            <div>
                                <strong>@item.Name</strong>
                                <p>@item.Description</p>
                            </div>
                            <div class="play-item-meta">
                                <span>@item.Rarity</span>
                                <span>@item.Count owned</span>
                            </div>
                            <div class="play-item-actions">
                                <button class="btn btn-secondary" type="button" @onclick="(() => ChangeItemSelection(item, -1))" disabled="@(!isSelected)">-</button>
                                <span class="mono-numeric">@(isSelected ? selectedQty : 0)</span>
                                <button class="btn btn-secondary" type="button" @onclick="(() => ChangeItemSelection(item, 1))" disabled="@(!CanIncreaseItem(item))">+</button>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="alert @(HasError ? "alert-warning" : "alert-info")">@StatusMessage</div>
    }

    @if (IsFullscreenPromptOpen)
    {
        <div class="enigma-modal-backdrop">
            <div class="enigma-modal-card fullscreen-modal-card">
                <span class="profile-kicker">Before You Enter</span>
                <h2>Go Fullscreen?</h2>
                <p>The maze plays better fullscreen. You can keep playing windowed if you want.</p>
                <label class="fullscreen-optout-toggle">
                    <input type="checkbox" @bind="DoNotAskFullscreenAgain" />
                    <span>Don't ask me again</span>
                </label>
                <div class="enigma-end-actions">
                    <button class="btn btn-primary" @onclick="EnterFullscreenAndStartAsync">Enter Fullscreen</button>
                    <button class="btn btn-secondary" @onclick="StartWindowedAsync">Continue Windowed</button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;
    [Inject] IJSRuntime JS { get; set; } = default!;

    private NewMazeRequest newMazeRequest = new();
    private LoadMazeRequest loadMazeRequest = new();
    private bool IsBusy { get; set; }
    private bool HasError { get; set; }
    private bool IsFullscreenPromptOpen { get; set; }
    private bool DoNotAskFullscreenAgain { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string? PendingGameNavigationUrl { get; set; }
    private LoginUserSummary? Session { get; set; }
    private List<ItemCatalogEntry> Inventory { get; set; } = [];
    private Dictionary<string, int> SelectedItems { get; set; } = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Session = await Api.GetSessionAsync();
        if (Session is null)
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        DoNotAskFullscreenAgain = await JS.InvokeAsync<bool>("enigmaGame.getFullscreenOptOut");
        await LoadInventoryAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadInventoryAsync()
    {
        try
        {
            var inventory = await Api.GetFromJsonAsync<InventoryResponse>("api/auth/items/inventory");
            Inventory = (inventory?.Items ?? [])
                .Where(item => !string.Equals(item.SlotKind, "perk", StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        catch
        {
            Inventory = [];
        }
    }

    private void OpenCoopLobby() => NavigationManager.NavigateTo("/play/coop");

    private async Task OnNewClick()
    {
        IsBusy = true;
        HasError = false;
        StatusMessage = string.Empty;

        try
        {
            using var response = await Api.GetAsync(
                $"api/auth/newMap?difficulty={Uri.EscapeDataString(newMazeRequest.Difficulty.ToString().ToLowerInvariant())}&size={newMazeRequest.Size}");
            var payload = await Api.ReadJsonAsync<SeedApiResponse>(response);

            if (!response.IsSuccessStatusCode || string.IsNullOrWhiteSpace(payload?.Seed))
            {
                throw new InvalidOperationException(await ExtractErrorDetailAsync(response, "Unable to generate a maze right now."));
            }

            await BeginRunAsync($"/game?seed={Uri.EscapeDataString(payload.Seed)}&source=new");
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task OnSeedClick()
    {
        IsBusy = true;
        HasError = false;
        StatusMessage = string.Empty;

        try
        {
            using var response = await Api.GetAsync(
                $"api/auth/loadMap?name={Uri.EscapeDataString(loadMazeRequest.MapName)}");
            var payload = await Api.ReadJsonAsync<SeedApiResponse>(response);

            if (!response.IsSuccessStatusCode || string.IsNullOrWhiteSpace(payload?.Seed))
            {
                throw new InvalidOperationException(await ExtractErrorDetailAsync(response, "Unable to load that saved maze."));
            }

            await BeginRunAsync($"/game?seed={Uri.EscapeDataString(payload.Seed)}&source=load&mapName={Uri.EscapeDataString(loadMazeRequest.MapName)}");
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task BeginRunAsync(string navigationUrl)
    {
        var validationError = ValidateSelection();
        if (!string.IsNullOrWhiteSpace(validationError))
        {
            HasError = true;
            StatusMessage = validationError;
            return;
        }

        PendingGameNavigationUrl = navigationUrl;
        var loadout = Inventory
            .Where(item => SelectedItems.TryGetValue(item.ItemId, out var count) && count > 0)
            .Select(item => new RunLoadoutSelection
            {
                ItemId = item.ItemId,
                Name = item.Name,
                Quantity = SelectedItems[item.ItemId],
                Kind = item.Kind,
                SlotKind = item.SlotKind,
            })
            .ToList();

        await JS.InvokeVoidAsync("enigmaGame.setRunLoadout", loadout);

        if (DoNotAskFullscreenAgain)
        {
            NavigationManager.NavigateTo(PendingGameNavigationUrl);
            return;
        }

        IsFullscreenPromptOpen = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task EnterFullscreenAndStartAsync()
    {
        if (DoNotAskFullscreenAgain)
        {
            await JS.InvokeVoidAsync("enigmaGame.setFullscreenOptOut", true);
        }

        await JS.InvokeVoidAsync("enigmaGame.requestFullscreen", string.Empty);
        await StartRunNavigationAsync();
    }

    private async Task StartWindowedAsync()
    {
        if (DoNotAskFullscreenAgain)
        {
            await JS.InvokeVoidAsync("enigmaGame.setFullscreenOptOut", true);
        }

        await StartRunNavigationAsync();
    }

    private Task StartRunNavigationAsync()
    {
        IsFullscreenPromptOpen = false;
        if (!string.IsNullOrWhiteSpace(PendingGameNavigationUrl))
        {
            NavigationManager.NavigateTo(PendingGameNavigationUrl);
        }

        return Task.CompletedTask;
    }

    private bool CanIncreaseItem(ItemCatalogEntry item)
    {
        if (!SelectedItems.TryGetValue(item.ItemId, out var quantity))
        {
            quantity = 0;
        }

        return quantity < Math.Min(item.Count, Math.Max(1, item.MaxPerRun));
    }

    private void ChangeItemSelection(ItemCatalogEntry item, int delta)
    {
        var next = (SelectedItems.TryGetValue(item.ItemId, out var current) ? current : 0) + delta;
        if (next <= 0)
        {
            SelectedItems.Remove(item.ItemId);
            return;
        }

        if (!CanIncreaseItem(item) && delta > 0)
        {
            return;
        }

        SelectedItems[item.ItemId] = next;
    }

    private string ValidateSelection()
    {
        if (SelectedItems.Count > 3)
        {
            return "You can only equip three item types per run.";
        }

        var selectedCatalog = Inventory.Where(item => SelectedItems.ContainsKey(item.ItemId)).ToList();
        if (selectedCatalog.Count(item => string.Equals(item.SlotKind, "passive", StringComparison.OrdinalIgnoreCase)) > 1)
        {
            return "Only one passive item can be equipped per run.";
        }

        if (selectedCatalog.Count(item => string.Equals(item.SlotKind, "high_power", StringComparison.OrdinalIgnoreCase)) > 1)
        {
            return "Only one high-power item can be equipped per run.";
        }

        return string.Empty;
    }

    private static async Task<string> ExtractErrorDetailAsync(HttpResponseMessage response, string fallback)
    {
        var raw = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(raw))
        {
            return response.StatusCode == System.Net.HttpStatusCode.TooManyRequests
                ? "Maze generation is temporarily rate-limited. Wait a moment, then try again."
                : fallback;
        }

        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(raw);
            if (document.RootElement.TryGetProperty("detail", out var detailElement))
            {
                var detail = detailElement.ValueKind == System.Text.Json.JsonValueKind.String
                    ? detailElement.GetString()
                    : detailElement.ToString();

                if (!string.IsNullOrWhiteSpace(detail))
                {
                    return detail;
                }
            }
        }
        catch (System.Text.Json.JsonException)
        {
        }

        return raw;
    }

    private sealed class SeedApiResponse
    {
        public string Seed { get; set; } = string.Empty;
    }

    private sealed class NewMazeRequest
    {
        [Required]
        public Difficulty Difficulty { get; set; } = Difficulty.Easy;

        [Range(2, int.MaxValue, ErrorMessage = "A map's dimensions must be at least a 2x2")]
        public int Size { get; set; } = 4;
    }

    private sealed class LoadMazeRequest
    {
        [Required(ErrorMessage = "Cannot be empty.")]
        public string MapName { get; set; } = string.Empty;
    }
}
