@page "/play"

<PageTitle>Play Game</PageTitle>

<div class="container mt-5" style="max-width: 700px;">

    <h1 class="text-center mb-4">🎮 Start Your Maze</h1>

    <div class="card shadow-sm p-4 mb-4">
        <h4 class="mb-3">Generate New Maze</h4>

        <EditForm FormName="NewForm" OnValidSubmit="OnNewClick" Model="mapEnter">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Difficulty</label>
                <InputSelect class="form-select" @bind-Value="mapEnter.MapDifficulty">
                    @foreach (var difficulty in Enum.GetValues<Difficulty>())
                    {
                        <option value="@difficulty">@difficulty</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Size</label>
                <InputNumber @bind-Value="mapEnter.MapSize" class="form-control" />
                <ValidationMessage For="() => mapEnter.MapSize" />
            </div>

            <button class="btn btn-success w-100">
                Generate Maze
            </button>
        </EditForm>
    </div>

    <div class="card shadow-sm p-4 mb-4">
        <h4 class="mb-3">Load Maze by Name</h4>

        <EditForm FormName="FromNameForm" OnValidSubmit="OnSeedClick" Model="mapEnter">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Map Name</label>
                <InputText @bind-Value="mapEnter.MapName" class="form-control" />
                <ValidationMessage For="() => mapEnter.MapName" />
            </div>

            <button class="btn btn-primary w-100">
                Load Maze
            </button>
        </EditForm>
    </div>

    <div class="text-center">
        <button class="btn btn-secondary" @onclick="OnBackClick">
            ← Back to Menu
        </button>
    </div>

</div>

@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;
    [Inject] HttpClient Http { get; set; }

    private Map mapEnter = new Map();
    private string Seed = string.Empty;

    async Task OnNewClick()
    {
        await GetSeedNew(mapEnter.MapDifficulty.ToString().ToLower(), mapEnter.MapSize);
    }

    async Task OnSeedClick()
    {
        await GetSeedFromName(mapEnter.MapName);
    }

    private async Task GetSeedFromName(string name)
    {
        Seed = await Http.GetStringAsync($"/api/auth/loadMap?name={Uri.EscapeDataString(name)}");
    }

    private async Task GetSeedNew(string difficulty, int size)
    {
        Seed = await Http.GetStringAsync(
            $"/api/auth/newMap?difficulty={Uri.EscapeDataString(difficulty)}&size={size}"
        );
    }

    private void OnBackClick()
    {
        NavigationManager.NavigateTo("/home");
    }
}
