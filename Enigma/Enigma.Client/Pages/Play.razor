@page "/play"
@using System.ComponentModel.DataAnnotations
@using Enigma.Client.Models.Gameplay
@inject Enigma.Client.Services.EnigmaApiClient Api
@using Microsoft.JSInterop

<SeoHead Title="Enigma Expeditions | Enter Anomaly Sector"
         Description="Initialize a new anomaly sector, load a mapped sector, assign field tools, and begin your expedition."
         Robots="noindex,follow"
         OpenGraphType="website"
         SchemaType="WebPage" />

<div class="container mt-5 play-page-shell" data-tour-id="play-shell">

    <section class="play-page-header play-page-banner" data-tour-id="play-banner">
        <div class="play-page-header-copy">
            <h1 class="mb-2">Start an Expedition</h1>
        </div>
        <div class="play-header-actions">
            <button class="btn btn-secondary" type="button" data-tour-id="play-open-coop" @onclick="OpenCoopLobby">Co-op Operation</button>
        </div>
    </section>

    <div class="play-setup-grid" data-tour-id="play-setup-grid">
        <div class="play-forms-column">
            <div class="card shadow-sm p-4 mb-4 play-card">
                <h4 class="mb-3">Request an Expedition</h4>

                <EditForm FormName="NewForm" OnValidSubmit="OnNewClick" Model="newMazeRequest">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Difficulty</label>
                        <EnigmaDropdown TValue="Difficulty"
                                        Class="form-control"
                                        Options="DifficultyOptions"
                                        @bind-Value="newMazeRequest.Difficulty" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Anomaly Size</label>
                        <EnigmaIntStepper Class="form-control"
                                          Min="2"
                                          Max="250"
                                          @bind-Value="newMazeRequest.Size" />
                        <ValidationMessage For="() => newMazeRequest.Size" />
                    </div>

                    <button class="btn btn-success w-100" disabled="@IsBusy">
                        @(IsBusy ? "Initializing..." : "Send Expedition Request")
                    </button>
                </EditForm>
            </div>

            <div class="card shadow-sm p-4 mb-4 play-card">
                <h4 class="mb-3">Load Sector by Name</h4>

                <EditForm FormName="FromNameForm" OnValidSubmit="OnSeedClick" Model="loadMazeRequest">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <MapSearchBox Label="Sector Name"
                                      InputId="play-map-search"
                                      Placeholder="type a mapped sector name"
                                      Value="@loadMazeRequest.MapName"
                                      ValueChanged="OnPlayMapNameChanged" />
                        <ValidationMessage For="() => loadMazeRequest.MapName" />
                    </div>

                    <button class="btn btn-primary w-100" disabled="@IsBusy">
                        @(IsBusy ? "Loading..." : "Load Sector")
                    </button>
                </EditForm>
            </div>
        </div>

        <div class="card shadow-sm p-4 play-card play-loadout-card">
            <div class="play-loadout-heading">
                <div>
                    <span class="profile-kicker">Field Gear</span>
                    <h4 class="mb-1">Select Your Field Kit</h4>
                </div>
                <span class="section-count">@SelectedItems.Count / 3</span>
            </div>
            <p class="play-loadout-copy">Assign up to three items. Passive items count toward the same cap.</p>

            @if (Inventory.Count == 0)
            {
                <div class="empty-state-inline">No owned items yet. Buy items from the exchange item shop.</div>
            }
            else
            {
                <div class="play-loadout-grid">
                    @foreach (var item in Inventory)
                    {
                        var isSelected = SelectedItems.TryGetValue(item.ItemId, out var selectedQty) && selectedQty > 0;
                        <article class="play-item-card @(isSelected ? "selected" : string.Empty)">
                            <div>
                                <strong>@item.Name</strong>
                                <p>@item.Description</p>
                            </div>
                            <div class="play-item-meta">
                                <span>@item.Rarity</span>
                                <span>@item.Count owned</span>
                            </div>
                            <div class="play-item-actions">
                                <button class="btn btn-secondary" type="button" @onclick="(() => ChangeItemSelection(item, -1))" disabled="@(!isSelected)">-</button>
                                <span class="mono-numeric">@(isSelected ? selectedQty : 0)</span>
                                <button class="btn btn-secondary" type="button" @onclick="(() => ChangeItemSelection(item, 1))" disabled="@(!CanIncreaseItem(item))">+</button>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </div>

    @if (HasError && !string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="alert alert-warning">@StatusMessage</div>
    }

    @if (IsAudioPromptOpen)
    {
        <div class="enigma-modal-backdrop">
            <div class="enigma-modal-card fullscreen-modal-card">
                <span class="profile-kicker">Before You Enter</span>
                <h2>Enable Audio?</h2>
                <p>Allow game ambiance and radar audio for this run. Best experienced with headphones, but you can continue muted if you prefer.</p>
                <label class="fullscreen-optout-toggle">
                    <input type="checkbox" @bind="DoNotAskAudioAgain" />
                    <span>Don't ask me again</span>
                </label>
                <div class="enigma-end-actions">
                    <button class="btn btn-primary" @onclick="EnableAudioAndContinueAsync">Enable Audio</button>
                    <button class="btn btn-secondary" @onclick="StartMutedAndContinueAsync">Continue Muted</button>
                </div>
            </div>
        </div>
    }

    @if (IsFullscreenPromptOpen)
    {
        <div class="enigma-modal-backdrop">
            <div class="enigma-modal-card fullscreen-modal-card">
                <span class="profile-kicker">Before You Enter</span>
                <h2>Go Fullscreen?</h2>
                <p>The anomaly interface plays better fullscreen. You can keep playing windowed if you want.</p>
                <label class="fullscreen-optout-toggle">
                    <input type="checkbox" @bind="DoNotAskFullscreenAgain" />
                    <span>Don't ask me again</span>
                </label>
                <div class="enigma-end-actions">
                    <button class="btn btn-primary" @onclick="EnterFullscreenAndStartAsync">Enter Fullscreen</button>
                    <button class="btn btn-secondary" @onclick="StartWindowedAsync">Continue Windowed</button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;
    [Inject] IJSRuntime JS { get; set; } = default!;

    private NewMazeRequest newMazeRequest = new();
    private LoadMazeRequest loadMazeRequest = new();
    private bool IsBusy { get; set; }
    private bool HasError { get; set; }
    private bool IsAudioPromptOpen { get; set; }
    private bool IsFullscreenPromptOpen { get; set; }
    private bool DoNotAskAudioAgain { get; set; }
    private bool DoNotAskFullscreenAgain { get; set; }
    private string AudioPreference { get; set; } = string.Empty;
    private string FullscreenPreference { get; set; } = string.Empty;
    private string StatusMessage { get; set; } = string.Empty;
    private string? PendingGameNavigationUrl { get; set; }
    private LoginUserSummary? Session { get; set; }
    private List<ItemCatalogEntry> Inventory { get; set; } = [];
    private Dictionary<string, int> SelectedItems { get; set; } = [];
    private bool _playTutorialInteractionReported;
    private static readonly IReadOnlyList<SelectOption<Difficulty>> DifficultyOptions =
        Enum.GetValues<Difficulty>()
            .Select(static difficulty => new SelectOption<Difficulty>(difficulty, difficulty.ToString()))
            .ToArray();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Session = await Api.GetSessionAsync();
        if (Session is null)
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        AudioPreference = await GetAudioPreferenceSafeAsync();
        DoNotAskAudioAgain = !string.IsNullOrWhiteSpace(AudioPreference);
        FullscreenPreference = await GetFullscreenPreferenceSafeAsync();
        DoNotAskFullscreenAgain = !string.IsNullOrWhiteSpace(FullscreenPreference);
        await LoadInventoryAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadInventoryAsync()
    {
        try
        {
            var inventory = await Api.GetFromJsonAsync<InventoryResponse>("api/auth/items/inventory");
            Inventory = (inventory?.Items ?? [])
                .Where(item => !string.Equals(item.SlotKind, "perk", StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        catch
        {
            Inventory = [];
        }
    }

    private void OpenCoopLobby() => NavigationManager.NavigateTo("/play/coop");

    private async Task OnNewClick()
    {
        await ReportPlayTutorialInteractionAsync();
        IsBusy = true;
        HasError = false;
        StatusMessage = string.Empty;

        try
        {
            await TryApplyStoredFullscreenAsync();
            using var response = await Api.GetAsync(
                $"api/auth/newMap?difficulty={Uri.EscapeDataString(newMazeRequest.Difficulty.ToString().ToLowerInvariant())}&size={newMazeRequest.Size}");
            var payload = await Api.ReadJsonAsync<SeedApiResponse>(response);

            if (!response.IsSuccessStatusCode || string.IsNullOrWhiteSpace(payload?.Seed))
            {
                throw new InvalidOperationException(await ExtractErrorDetailAsync(response, "Unable to initialize a sector right now."));
            }

            await BeginRunAsync($"/game?seed={Uri.EscapeDataString(payload.Seed)}&source=new");
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task OnSeedClick()
    {
        await ReportPlayTutorialInteractionAsync();
        IsBusy = true;
        HasError = false;
        StatusMessage = string.Empty;

        try
        {
            await TryApplyStoredFullscreenAsync();
            using var response = await Api.GetAsync(
                $"api/auth/loadMap?name={Uri.EscapeDataString(loadMazeRequest.MapName)}");
            var payload = await Api.ReadJsonAsync<SeedApiResponse>(response);

            if (!response.IsSuccessStatusCode || string.IsNullOrWhiteSpace(payload?.Seed))
            {
                throw new InvalidOperationException(await ExtractErrorDetailAsync(response, "Unable to load that mapped sector."));
            }

            await BeginRunAsync($"/game?seed={Uri.EscapeDataString(payload.Seed)}&source=load&mapName={Uri.EscapeDataString(loadMazeRequest.MapName)}");
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task BeginRunAsync(string navigationUrl)
    {
        var validationError = ValidateSelection();
        if (!string.IsNullOrWhiteSpace(validationError))
        {
            HasError = true;
            StatusMessage = validationError;
            return;
        }

        PendingGameNavigationUrl = navigationUrl;
        var loadout = Inventory
            .Where(item => SelectedItems.TryGetValue(item.ItemId, out var count) && count > 0)
            .Select(item => new RunLoadoutSelection
            {
                ItemId = item.ItemId,
                Name = item.Name,
                Quantity = SelectedItems[item.ItemId],
                Kind = item.Kind,
                SlotKind = item.SlotKind,
                EffectConfig = item.EffectConfig,
            })
            .ToList();

        await JS.InvokeVoidAsync("enigmaGame.setRunLoadout", loadout);

        await ContinueRunAfterAudioGateAsync();
    }

    private async Task EnterFullscreenAndStartAsync()
    {
        if (DoNotAskFullscreenAgain)
        {
            FullscreenPreference = "fullscreen";
            await PersistFullscreenPreferenceAsync(FullscreenPreference);
        }
        else
        {
            FullscreenPreference = string.Empty;
            await PersistFullscreenPreferenceAsync(string.Empty);
        }

        await JS.InvokeAsync<bool>("enigmaGame.requestFullscreen", string.Empty);
        await StartRunNavigationAsync();
    }

    private async Task StartWindowedAsync()
    {
        if (DoNotAskFullscreenAgain)
        {
            FullscreenPreference = "windowed";
            await PersistFullscreenPreferenceAsync(FullscreenPreference);
        }
        else
        {
            FullscreenPreference = string.Empty;
            await PersistFullscreenPreferenceAsync(string.Empty);
        }

        await StartRunNavigationAsync();
    }

    private async Task EnableAudioAndContinueAsync()
    {
        if (DoNotAskAudioAgain)
        {
            AudioPreference = "enabled";
            await PersistAudioPreferenceAsync(AudioPreference);
        }
        else
        {
            AudioPreference = string.Empty;
            await PersistAudioPreferenceAsync(string.Empty);
        }

        try
        {
            await JS.InvokeVoidAsync("enigmaGame.approveAudioForCurrentRun", true);
        }
        catch (JSException)
        {
        }

        IsAudioPromptOpen = false;
        await ContinueRunAfterFullscreenGateAsync();
    }

    private async Task StartMutedAndContinueAsync()
    {
        if (DoNotAskAudioAgain)
        {
            AudioPreference = "disabled";
            await PersistAudioPreferenceAsync(AudioPreference);
        }
        else
        {
            AudioPreference = string.Empty;
            await PersistAudioPreferenceAsync(string.Empty);
        }

        try
        {
            await JS.InvokeVoidAsync("enigmaGame.approveAudioForCurrentRun", false);
        }
        catch (JSException)
        {
        }

        IsAudioPromptOpen = false;
        await ContinueRunAfterFullscreenGateAsync();
    }

    private async Task ContinueRunAfterAudioGateAsync()
    {
        AudioPreference = await GetAudioPreferenceSafeAsync();
        if (string.IsNullOrWhiteSpace(AudioPreference))
        {
            DoNotAskAudioAgain = false;
            IsAudioPromptOpen = true;
            IsFullscreenPromptOpen = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.Equals(AudioPreference, "enabled", StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                await JS.InvokeVoidAsync("enigmaGame.approveAudioForCurrentRun", true);
            }
            catch (JSException)
            {
            }
        }
        else
        {
            try
            {
                await JS.InvokeVoidAsync("enigmaGame.approveAudioForCurrentRun", false);
            }
            catch (JSException)
            {
            }
        }

        await ContinueRunAfterFullscreenGateAsync();
    }

    private async Task ContinueRunAfterFullscreenGateAsync()
    {
        FullscreenPreference = await GetFullscreenPreferenceSafeAsync();
        if (string.Equals(FullscreenPreference, "fullscreen", StringComparison.OrdinalIgnoreCase))
        {
            await JS.InvokeAsync<bool>("enigmaGame.requestFullscreen", string.Empty);
            await StartRunNavigationAsync();
            return;
        }

        if (string.Equals(FullscreenPreference, "windowed", StringComparison.OrdinalIgnoreCase))
        {
            await StartRunNavigationAsync();
            return;
        }

        DoNotAskFullscreenAgain = false;
        IsFullscreenPromptOpen = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task<string> GetAudioPreferenceSafeAsync()
    {
        try
        {
            return await JS.InvokeAsync<string>("enigmaGame.getAudioPreference");
        }
        catch (JSException)
        {
            try
            {
                return await JS.InvokeAsync<bool>("enigmaGame.getAudioOptOut")
                    ? "disabled"
                    : string.Empty;
            }
            catch (JSException)
            {
                return string.Empty;
            }
        }
    }

    private async Task<string> GetFullscreenPreferenceSafeAsync()
    {
        try
        {
            return await JS.InvokeAsync<string>("enigmaGame.getFullscreenPreference");
        }
        catch (JSException)
        {
            try
            {
                return await JS.InvokeAsync<bool>("enigmaGame.getFullscreenOptOut")
                    ? "windowed"
                    : string.Empty;
            }
            catch (JSException)
            {
                return string.Empty;
            }
        }
    }

    private Task OnPlayMapNameChanged(string mapName)
    {
        loadMazeRequest.MapName = mapName;
        _ = ReportPlayTutorialInteractionAsync();
        return InvokeAsync(StateHasChanged);
    }

    private async Task PersistFullscreenPreferenceAsync(string mode)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(mode))
            {
                await JS.InvokeVoidAsync("enigmaGame.clearFullscreenPreference");
                return;
            }

            await JS.InvokeVoidAsync("enigmaGame.setFullscreenPreference", mode);
        }
        catch (JSException)
        {
            try
            {
                await JS.InvokeVoidAsync("enigmaGame.setFullscreenOptOut", !string.IsNullOrWhiteSpace(mode));
            }
            catch (JSException)
            {
            }
        }
    }

    private async Task PersistAudioPreferenceAsync(string mode)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(mode))
            {
                await JS.InvokeVoidAsync("enigmaGame.clearAudioPreference");
                return;
            }

            await JS.InvokeVoidAsync("enigmaGame.setAudioPreference", mode);
        }
        catch (JSException)
        {
            try
            {
                await JS.InvokeVoidAsync(
                    "enigmaGame.setAudioOptOut",
                    string.Equals(mode, "disabled", StringComparison.OrdinalIgnoreCase));
            }
            catch (JSException)
            {
            }
        }
    }

    private async Task TryApplyStoredFullscreenAsync()
    {
        AudioPreference = await GetAudioPreferenceSafeAsync();
        if (string.IsNullOrWhiteSpace(AudioPreference))
        {
            return;
        }

        FullscreenPreference = await GetFullscreenPreferenceSafeAsync();
        if (!string.Equals(FullscreenPreference, "fullscreen", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        try
        {
            await JS.InvokeAsync<bool>("enigmaGame.requestFullscreen", string.Empty);
        }
        catch (JSException)
        {
        }
    }

    private Task StartRunNavigationAsync()
    {
        IsAudioPromptOpen = false;
        IsFullscreenPromptOpen = false;
        if (!string.IsNullOrWhiteSpace(PendingGameNavigationUrl))
        {
            NavigationManager.NavigateTo(PendingGameNavigationUrl);
        }

        return Task.CompletedTask;
    }

    private bool CanIncreaseItem(ItemCatalogEntry item)
    {
        if (!SelectedItems.TryGetValue(item.ItemId, out var quantity))
        {
            quantity = 0;
        }

        return quantity < Math.Min(item.Count, Math.Max(1, item.MaxPerRun));
    }

    private void ChangeItemSelection(ItemCatalogEntry item, int delta)
    {
        _ = ReportPlayTutorialInteractionAsync();
        var next = (SelectedItems.TryGetValue(item.ItemId, out var current) ? current : 0) + delta;
        if (next <= 0)
        {
            SelectedItems.Remove(item.ItemId);
            return;
        }

        if (!CanIncreaseItem(item) && delta > 0)
        {
            return;
        }

        SelectedItems[item.ItemId] = next;
    }

    private async Task ReportPlayTutorialInteractionAsync()
    {
        if (_playTutorialInteractionReported)
        {
            return;
        }

        _playTutorialInteractionReported = true;
        try
        {
            await JS.InvokeVoidAsync("enigmaGame.reportTutorialObjective", "tutorial-play-interacted");
        }
        catch (JSException)
        {
        }
    }

    private string ValidateSelection()
    {
        if (SelectedItems.Count > 3)
        {
            return "You can only equip three item types per run.";
        }

        var selectedCatalog = Inventory.Where(item => SelectedItems.ContainsKey(item.ItemId)).ToList();
        if (selectedCatalog.Count(item => string.Equals(item.SlotKind, "passive", StringComparison.OrdinalIgnoreCase)) > 1)
        {
            return "Only one passive item can be equipped per run.";
        }

        if (selectedCatalog.Count(item => string.Equals(item.SlotKind, "high_power", StringComparison.OrdinalIgnoreCase)) > 1)
        {
            return "Only one high-power item can be equipped per run.";
        }

        return string.Empty;
    }

    private static async Task<string> ExtractErrorDetailAsync(HttpResponseMessage response, string fallback)
    {
        var raw = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(raw))
        {
            return response.StatusCode == System.Net.HttpStatusCode.TooManyRequests
                ? "Sector initialization is temporarily rate-limited. Wait a moment, then try again."
                : fallback;
        }

        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(raw);
            if (document.RootElement.TryGetProperty("detail", out var detailElement))
            {
                var detail = detailElement.ValueKind == System.Text.Json.JsonValueKind.String
                    ? detailElement.GetString()
                    : detailElement.ToString();

                if (!string.IsNullOrWhiteSpace(detail))
                {
                    return detail;
                }
            }
        }
        catch (System.Text.Json.JsonException)
        {
        }

        return raw;
    }

    private sealed class SeedApiResponse
    {
        public string Seed { get; set; } = string.Empty;
    }

    private sealed class NewMazeRequest
    {
        [Required]
        public Difficulty Difficulty { get; set; } = Difficulty.Easy;

        [Range(2, 250, ErrorMessage = "A sector's dimensions must be between 2 and 250.")]
        public int Size { get; set; } = 4;
    }

    private sealed class LoadMazeRequest
    {
        [Required(ErrorMessage = "Cannot be empty.")]
        public string MapName { get; set; } = string.Empty;
    }
}
