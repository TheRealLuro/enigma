@page "/profile"

<div class="app-header">
    <h1>Player Profile</h1>
    <h2>ColtonClark</h2>
</div>

<div class="content">

    <div class="card">
        <div style="display:flex; align-items:center; gap:24px;">
            <div class="friend-avatar" style="width:80px; height:80px; font-size:2rem;">
                CC
                <div class="friend-status online"></div>
            </div>

            <div>
                <h2 style="margin-bottom:6px;">Colton Clark</h2>
                <div class="badge badge-primary">Pro Solver</div>
                <div style="color: var(--epic-text-secondary); margin-top:6px;">
                    Member since 2026
                </div>
            </div>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-box">
            <div class="stat-value">128</div>
            <div class="stat-label">Solved</div>
        </div>
        <div class="stat-box">
            <div class="stat-value">12h</div>
            <div class="stat-label">Play Time</div>
        </div>
        <div class="stat-box">
            <div class="stat-value">87%</div>
            <div class="stat-label">Accuracy</div>
        </div>
        <div class="stat-box">
            <div class="stat-value">#3</div>
            <div class="stat-label">Global Rank</div>
        </div>
    </div>
</div>

@code {

}
