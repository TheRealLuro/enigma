@page "/register"
@using Enigma.Client.Models
@using Enigma.Client.Models.Gameplay
@inject Enigma.Client.Services.EnigmaApiClient Api
@using Microsoft.JSInterop

<SeoHead Title="Create Enigma Account | Join the Puzzle Maze Game"
         Description="Create an Enigma account to play evolving puzzle mazes, collect discovered maps, and join co-op expeditions."
         Robots="noindex,follow"
         OpenGraphType="website"
         SchemaType="WebPage"
         Keywords="create Enigma account, Enigma signup, puzzle maze game register" />

<div class="content auth-shell seo-auth-shell" style="max-width: 960px; margin-top: 60px;">
    <section class="seo-auth-intro panel">
        <span class="profile-kicker">Join Enigma</span>
        <h1>Create Your Explorer Account</h1>
        <p>Register to generate mazes, discover collectible maps, join co-op runs, and use the Enigma marketplace and leaderboard systems.</p>
        <div class="seo-inline-links">
            <a href="/about">About</a>
            <a href="/how-enigma-works">How It Works</a>
            <a href="/enigma-game-mechanics">Game Mechanics</a>
            <a href="/enigma-multiplayer">Multiplayer</a>
        </div>
    </section>

    <div class="card p-4 shadow-sm auth-card">

        <h2 class="mb-4 text-center">Create Account</h2>

        <EditForm Model="newUser" OnValidSubmit="OnRegisterClick">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Display Name</label>
                <InputText class="form-control"
                           @bind-Value="newUser.DisplayName"
                           placeholder="MazeMaster42" />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <InputText class="form-control"
                           @bind-Value="newUser.Email"
                           placeholder="you@example.com" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <div class="password-field-wrap">
                    <InputText type="@(ShowPassword ? "text" : "password")"
                               class="form-control"
                               @bind-Value="password"
                               placeholder="Choose a password" />
                    <button type="button" class="password-toggle-button" @onclick="TogglePasswordVisibility">
                        @(ShowPassword ? "Hide" : "Show")
                    </button>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Confirm Password</label>
                <div class="password-field-wrap">
                    <InputText type="@(ShowPassword ? "text" : "password")"
                               class="form-control"
                               @bind-Value="confirmPassword"
                               placeholder="Repeat your password" />
                </div>
            </div>

            <div class="mb-3">
                <InputCheckbox @bind-Value="rememberMe" class="form-check-input" id="remember-signup" />
                <label for="remember-signup" class="form-check-label ms-1">Keep me signed in</label>
            </div>

            <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
                @(IsSubmitting ? "Signing up..." : "Sign Up")
            </button>
        </EditForm>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">
                @errorMessage
            </div>
        }

        <div class="subtext-mt-4">
            Already have an account?
            <button class="btn btn-link p-0"
                    @onclick="OnLoginClick">
                Sign In
            </button>
        </div>

    </div>
</div>

@code {
    [Inject]
    NavigationManager NavigationManager { get; set; } = default!;

    [Inject]
    IJSRuntime JS { get; set; } = default!;

    RegisterUser newUser = new();
    string password = string.Empty;
    string confirmPassword = string.Empty;
    bool rememberMe;
    bool IsSubmitting;
    bool ShowPassword;

    string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        rememberMe = await GetRememberedSessionStateAsync();
        var session = await Api.GetSessionAsync();
        if (session is not null && !string.IsNullOrWhiteSpace(session.Username))
        {
            await JS.InvokeVoidAsync("enigmaGame.refreshUserSession", session);
            await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new PlayerIdentity { Username = session.Username }, rememberMe);
            NavigationManager.NavigateTo("/home", replace: true);
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    async Task OnRegisterClick()
    {
        errorMessage = null;

        if (password != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        IsSubmitting = true;

        try
        {
            using var httpResponse = await Api.PostJsonAsync("api/auth/session/signup", new
            {
                username = newUser.DisplayName ?? string.Empty,
                email = newUser.Email ?? string.Empty,
                password,
                rememberMe,
            });

            if (!httpResponse.IsSuccessStatusCode)
            {
                errorMessage = await httpResponse.Content.ReadAsStringAsync();
                return;
            }

            var response = await Api.ReadJsonAsync<LoginResponse>(httpResponse);
            if (response is null || response.Status != "success" || string.IsNullOrWhiteSpace(response.User?.Username))
            {
                errorMessage = "Sign up failed.";
                return;
            }

            await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new PlayerIdentity { Username = response.User.Username }, rememberMe);
            await JS.InvokeVoidAsync("enigmaGame.setUserSession", response.User, rememberMe);
            NavigationManager.NavigateTo("/home");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    void OnLoginClick()
    {
        NavigationManager.NavigateTo("/");
    }

    void TogglePasswordVisibility()
    {
        ShowPassword = !ShowPassword;
    }

    private async Task<bool> GetRememberedSessionStateAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("enigmaGame.isUserSessionRemembered");
        }
        catch (JSException)
        {
            return false;
        }
    }

    public class RegisterUser
    {
        public string DisplayName { get; set; } = "";
        public string Email { get; set; } = "";
    }
}
