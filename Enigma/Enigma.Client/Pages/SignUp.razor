@page "/register"
@using Enigma.Client.Models.Gameplay
@inject Enigma.Client.Services.EnigmaApiClient Api

<div class="content auth-shell" style="max-width: 520px; margin-top: 60px;">
    <div class="card p-4 shadow-sm auth-card">

        <h3 class="mb-4 text-center">Create Account</h3>

        <EditForm Model="newUser" OnValidSubmit="OnRegisterClick">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Display Name</label>
                <InputText class="form-control"
                           @bind-Value="newUser.DisplayName"
                           placeholder="MazeMaster42" />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <InputText class="form-control"
                           @bind-Value="newUser.Email"
                           placeholder="you@example.com" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <div class="password-field-wrap">
                    <InputText type="@(ShowPassword ? "text" : "password")"
                               class="form-control"
                               @bind-Value="password"
                               placeholder="Choose a password" />
                    <button type="button" class="password-toggle-button" @onclick="TogglePasswordVisibility">
                        @(ShowPassword ? "Hide" : "Show")
                    </button>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Confirm Password</label>
                <div class="password-field-wrap">
                    <InputText type="@(ShowPassword ? "text" : "password")"
                               class="form-control"
                               @bind-Value="confirmPassword"
                               placeholder="Repeat your password" />
                </div>
            </div>

            <div class="mb-3">
                <InputCheckbox @bind-Value="rememberMe" class="form-check-input" id="remember-signup" />
                <label for="remember-signup" class="form-check-label ms-1">Keep me signed in</label>
            </div>

            <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
                @(IsSubmitting ? "Signing up..." : "Sign Up")
            </button>
        </EditForm>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">
                @errorMessage
            </div>
        }

        <div class="subtext-mt-4">
            Already have an account?
            <button class="btn btn-link p-0"
                    @onclick="OnLoginClick">
                Sign In
            </button>
        </div>

    </div>
</div>

@code {
    [Inject]
    NavigationManager NavigationManager { get; set; } = default!;

    [Inject]
    IJSRuntime JS { get; set; } = default!;

    RegisterUser newUser = new();
    string password = string.Empty;
    string confirmPassword = string.Empty;
    bool rememberMe;
    bool IsSubmitting;
    bool ShowPassword;

    string? errorMessage;

    async Task OnRegisterClick()
    {
        errorMessage = null;

        if (password != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        IsSubmitting = true;

        try
        {
            using var httpResponse = await Api.PostJsonAsync("api/auth/session/signup", new
            {
                username = newUser.DisplayName ?? string.Empty,
                email = newUser.Email ?? string.Empty,
                password,
                rememberMe,
            });

            if (!httpResponse.IsSuccessStatusCode)
            {
                errorMessage = await httpResponse.Content.ReadAsStringAsync();
                return;
            }

            var response = await httpResponse.Content.ReadFromJsonAsync<LoginResponse>();
            if (response is null || response.Status != "success" || string.IsNullOrWhiteSpace(response.User?.Username))
            {
                errorMessage = "Sign up failed.";
                return;
            }

            await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new PlayerIdentity { Username = response.User.Username }, rememberMe);
            await JS.InvokeVoidAsync("enigmaGame.setUserSession", response.User, rememberMe);
            NavigationManager.NavigateTo("/home");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    void OnLoginClick()
    {
        NavigationManager.NavigateTo("/");
    }

    void TogglePasswordVisibility()
    {
        ShowPassword = !ShowPassword;
    }

    public class RegisterUser
    {
        public string DisplayName { get; set; } = "";
        public string Email { get; set; } = "";
    }
}
