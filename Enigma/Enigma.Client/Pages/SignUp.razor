@page "/register"
@using Enigma.Client.Models
@using Enigma.Client.Models.Gameplay
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@inject Enigma.Client.Services.EnigmaApiClient Api
@inject Enigma.Client.Services.UiNotificationService Notifications
@using Microsoft.JSInterop

<SeoHead Title="Create Explorer Account | Join Enigma Command"
         Description="Create an Enigma account to run anomaly expeditions, collect mapped sectors, and join co-op operations."
         Robots="noindex,follow"
         OpenGraphType="website"
         SchemaType="WebPage"
         Keywords="create explorer account, Enigma command signup, anomaly sector program, A-R-D" />

<div class="content auth-shell seo-auth-shell" style="max-width: 960px; margin-top: 60px;">
    <section class="seo-auth-intro panel">
        <span class="profile-kicker">Enigma Corporation</span>
        <h1>Join Anomaly Research Division (A.R.D)</h1>
        <p>Register to generate sectors, recover anomaly sector records, join co-op operations, and use the Enigma exchange and ranking systems.</p>
        <div class="seo-inline-links">
            <a href="/about">Program Brief</a>
            <a href="/how-enigma-works">Operations Guide</a>
            <a href="/enigma-game-mechanics">System Mechanics</a>
            <a href="/enigma-multiplayer">Co-op Operations</a>
        </div>
    </section>

    <div class="card p-4 shadow-sm auth-card">
        @if (!IsAwaitingVerification)
        {
            <h2 class="mb-4 text-center">Create Explorer Account</h2>

            <EditForm EditContext="RegisterEditContext" OnValidSubmit="OnRegisterClick" OnInvalidSubmit="OnInvalidRegisterAttempt">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label">Display Name</label>
                    <InputText class="form-control"
                               @bind-Value="newUser.DisplayName"
                               placeholder="Explorer42" />
                    <ValidationMessage For="() => newUser.DisplayName" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input class="form-control"
                           type="email"
                           value="@newUser.Email"
                           @oninput="OnEmailInput"
                           placeholder="you@example.com"
                           autocomplete="email" />
                    <ValidationMessage For="() => newUser.Email" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <div class="password-field-wrap">
                        <input type="@(ShowPassword ? "text" : "password")"
                               class="form-control"
                               @bind="newUser.Password"
                               @bind:event="oninput"
                               placeholder="Choose a password" />
                        <button type="button" class="password-toggle-button" @onclick="TogglePasswordVisibility">
                            @(ShowPassword ? "Hide" : "Show")
                        </button>
                    </div>
                    @if (ShouldShowPasswordIssues)
                    {
                        <div class="password-issue-list" aria-live="polite">
                            @foreach (var issue in PasswordIssues)
                            {
                                <div class="password-issue-item">
                                    <span class="password-issue-icon" aria-hidden="true">!</span>
                                    <span>@issue</span>
                                </div>
                            }
                        </div>
                    }
                    <ValidationMessage For="() => newUser.Password" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirm Password</label>
                    <div class="password-field-wrap">
                        <input type="@(ShowPassword ? "text" : "password")"
                               class="form-control"
                               @bind="newUser.ConfirmPassword"
                               @bind:event="oninput"
                               placeholder="Repeat your password" />
                    </div>
                    <ValidationMessage For="() => newUser.ConfirmPassword" />
                </div>

                <div class="mb-3">
                    <InputCheckbox @bind-Value="rememberMe" class="form-check-input" id="remember-signup" />
                    <label for="remember-signup" class="form-check-label ms-1">Keep me signed in after verification</label>
                </div>

                <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
                    @(IsSubmitting ? "Sending code..." : "Send Verification Code")
                </button>
            </EditForm>
        }
        else
        {
            <div class="signup-verification-step">
                <span class="profile-kicker">Email Verification</span>
                <h2 class="mb-3 text-center">Verify Explorer Access</h2>
                <p class="signup-verification-copy">
                    Enter the 6-digit verification code sent to <strong>@VerificationEmailHint</strong>.
                    @if (!string.IsNullOrWhiteSpace(VerificationExpiryDisplay))
                    {
                        <span> Code expires @VerificationExpiryDisplay.</span>
                    }
                </p>

                <EditForm EditContext="VerifyEditContext" OnValidSubmit="OnVerifyCodeAsync" OnInvalidSubmit="OnInvalidVerifyAttempt">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Verification Code</label>
                        <InputText class="form-control signup-code-input"
                                   @bind-Value="verification.Code"
                                   autocomplete="one-time-code"
                                   inputmode="numeric"
                                   maxlength="6"
                                   placeholder="000000" />
                        <ValidationMessage For="() => verification.Code" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
                        @(IsSubmitting ? "Verifying..." : "Verify and Create Account")
                    </button>
                </EditForm>

                <div class="signup-verification-actions">
                    <button type="button" class="btn btn-secondary" @onclick="OnResendCodeAsync" disabled="@IsSubmitting">Resend Code</button>
                    <button type="button" class="btn btn-secondary" @onclick="ReturnToRegistrationForm" disabled="@IsSubmitting">Change Email</button>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">
                @errorMessage
            </div>
        }

        <div class="subtext-mt-4">
            Already have an account?
            <button class="btn btn-link p-0"
                    @onclick="OnLoginClick">
                Sign In
            </button>
        </div>
    </div>
</div>

@code {
    [Inject]
    NavigationManager NavigationManager { get; set; } = default!;

    [Inject]
    IJSRuntime JS { get; set; } = default!;

    RegisterUser newUser = new();
    EditContext RegisterEditContext = default!;
    VerifyCodeForm verification = new();
    EditContext VerifyEditContext = default!;
    bool rememberMe;
    bool IsSubmitting;
    bool ShowPassword;
    bool IsAwaitingVerification;
    string VerificationRequestId = string.Empty;
    string VerificationEmailHint = string.Empty;
    DateTimeOffset? VerificationExpiresAtUtc;

    string? errorMessage;

    protected override void OnInitialized()
    {
        RegisterEditContext = new EditContext(newUser);
        VerifyEditContext = new EditContext(verification);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        rememberMe = await GetRememberedSessionStateAsync();
        var session = await Api.GetSessionAsync();
        if (session is not null && !string.IsNullOrWhiteSpace(session.Username))
        {
            await JS.InvokeVoidAsync("enigmaGame.refreshUserSession", session);
            await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new PlayerIdentity { Username = session.Username }, rememberMe);
            NavigationManager.NavigateTo("/home", replace: true);
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    async Task OnRegisterClick()
    {
        errorMessage = null;
        IsSubmitting = true;

        try
        {
            using var httpResponse = await Api.PostJsonAsync("api/auth/session/signup", new
            {
                username = newUser.DisplayName ?? string.Empty,
                email = newUser.Email ?? string.Empty,
                password = newUser.Password ?? string.Empty,
                rememberMe,
            });

            if (!httpResponse.IsSuccessStatusCode)
            {
                errorMessage = await ExtractErrorDetailAsync(httpResponse, "Sign up failed.");
                if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    Notifications.Warning(errorMessage);
                }
                return;
            }

            var response = await Api.ReadJsonAsync<SignUpVerificationChallengeResponse>(httpResponse);
            if (response is null || !string.Equals(response.Status, "verification_required", StringComparison.OrdinalIgnoreCase) || string.IsNullOrWhiteSpace(response.VerificationRequestId))
            {
                errorMessage = "Verification could not be started.";
                Notifications.Error(errorMessage);
                return;
            }

            ApplyVerificationChallenge(response);
            Notifications.Success(response.Detail ?? "Verification code sent.");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            Notifications.Error(errorMessage);
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void OnInvalidRegisterAttempt(EditContext _)
    {
        errorMessage = "Please fix the highlighted signup fields before requesting a verification code.";
        Notifications.Warning(errorMessage);
    }

    private async Task OnVerifyCodeAsync()
    {
        errorMessage = null;
        IsSubmitting = true;

        try
        {
            using var httpResponse = await Api.PostJsonAsync("api/auth/session/signup/verify", new SignUpVerificationRequest
            {
                VerificationRequestId = VerificationRequestId,
                Code = verification.Code,
                RememberMe = rememberMe,
            });

            if (!httpResponse.IsSuccessStatusCode)
            {
                errorMessage = await ExtractErrorDetailAsync(httpResponse, "Verification failed.");
                if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    Notifications.Warning(errorMessage);
                }
                return;
            }

            var response = await Api.ReadJsonAsync<LoginResponse>(httpResponse);
            if (response is null || response.Status != "success" || string.IsNullOrWhiteSpace(response.User?.Username))
            {
                errorMessage = "Verification failed.";
                Notifications.Error(errorMessage);
                return;
            }

            await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new PlayerIdentity { Username = response.User.Username }, rememberMe);
            await JS.InvokeVoidAsync("enigmaGame.setUserSession", response.User, rememberMe);
            if (response.DailyRewardGranted)
            {
                Notifications.Success($"Account created. Daily reward granted: {response.DailyRewardAmount:N0} MN.");
            }
            else
            {
                Notifications.Success("Account created. Welcome to Enigma.");
            }

            NavigationManager.NavigateTo("/home");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            Notifications.Error(errorMessage);
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task OnResendCodeAsync()
    {
        errorMessage = null;
        IsSubmitting = true;

        try
        {
            using var httpResponse = await Api.PostJsonAsync("api/auth/session/signup/resend", new ResendSignUpVerificationRequest
            {
                VerificationRequestId = VerificationRequestId,
            });

            if (!httpResponse.IsSuccessStatusCode)
            {
                errorMessage = await ExtractErrorDetailAsync(httpResponse, "Could not resend the verification code.");
                if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    Notifications.Warning(errorMessage);
                }
                return;
            }

            var response = await Api.ReadJsonAsync<SignUpVerificationChallengeResponse>(httpResponse);
            if (response is null || string.IsNullOrWhiteSpace(response.VerificationRequestId))
            {
                errorMessage = "Could not resend the verification code.";
                Notifications.Error(errorMessage);
                return;
            }

            ApplyVerificationChallenge(response);
            verification.Code = string.Empty;
            VerifyEditContext = new EditContext(verification);
            Notifications.Success(response.Detail ?? "Verification code resent.");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            Notifications.Error(errorMessage);
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void OnInvalidVerifyAttempt(EditContext _)
    {
        errorMessage = "Enter a valid 6-digit verification code before continuing.";
        Notifications.Warning(errorMessage);
    }

    private void ReturnToRegistrationForm()
    {
        IsAwaitingVerification = false;
        VerificationRequestId = string.Empty;
        VerificationEmailHint = string.Empty;
        VerificationExpiresAtUtc = null;
        verification = new VerifyCodeForm();
        VerifyEditContext = new EditContext(verification);
        errorMessage = null;
    }

    void OnLoginClick()
    {
        NavigationManager.NavigateTo("/");
    }

    void TogglePasswordVisibility()
    {
        ShowPassword = !ShowPassword;
    }

    private void OnEmailInput(ChangeEventArgs args)
    {
        newUser.Email = args.Value?.ToString() ?? string.Empty;
        RegisterEditContext.NotifyFieldChanged(FieldIdentifier.Create(() => newUser.Email));
    }

    private void ApplyVerificationChallenge(SignUpVerificationChallengeResponse response)
    {
        VerificationRequestId = response.VerificationRequestId;
        VerificationEmailHint = response.EmailHint;
        VerificationExpiresAtUtc = DateTimeOffset.TryParse(response.ExpiresAtUtc, out var expiresAtUtc)
            ? expiresAtUtc
            : null;
        verification = new VerifyCodeForm();
        VerifyEditContext = new EditContext(verification);
        IsAwaitingVerification = true;
        errorMessage = null;
    }

    private string VerificationExpiryDisplay =>
        VerificationExpiresAtUtc?.ToLocalTime().ToString("MMM dd, yyyy h:mm tt") ?? string.Empty;

    private bool IsPasswordLengthValid => CurrentPassword.Length >= 10 && CurrentPassword.Length <= 128;
    private bool IsPasswordUpperValid => CurrentPassword.Any(char.IsUpper);
    private bool IsPasswordLowerValid => CurrentPassword.Any(char.IsLower);
    private bool IsPasswordDigitValid => CurrentPassword.Any(char.IsDigit);
    private bool IsPasswordSpecialValid => CurrentPassword.Any(static ch => !char.IsLetterOrDigit(ch));
    private string CurrentPassword => newUser.Password ?? string.Empty;
    private bool ShouldShowPasswordIssues => !string.IsNullOrWhiteSpace(CurrentPassword) && PasswordIssues.Count > 0;
    private IReadOnlyList<string> PasswordIssues
    {
        get
        {
            var issues = new List<string>();
            if (!IsPasswordLengthValid)
            {
                issues.Add("Use 10 to 128 characters.");
            }
            if (!IsPasswordUpperValid)
            {
                issues.Add("Add at least one uppercase letter.");
            }
            if (!IsPasswordLowerValid)
            {
                issues.Add("Add at least one lowercase letter.");
            }
            if (!IsPasswordDigitValid)
            {
                issues.Add("Add at least one number.");
            }
            if (!IsPasswordSpecialValid)
            {
                issues.Add("Add at least one special character.");
            }
            return issues;
        }
    }

    private static async Task<string> ExtractErrorDetailAsync(HttpResponseMessage response, string fallback)
    {
        var raw = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(raw))
        {
            return fallback;
        }

        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(raw);
            if (document.RootElement.TryGetProperty("detail", out var detailElement))
            {
                var detail = detailElement.ValueKind == System.Text.Json.JsonValueKind.String
                    ? detailElement.GetString()
                    : detailElement.ToString();
                if (!string.IsNullOrWhiteSpace(detail))
                {
                    return detail;
                }
            }

            if (document.RootElement.TryGetProperty("errors", out var errorsElement) &&
                errorsElement.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                var lines = new List<string>();
                foreach (var error in errorsElement.EnumerateArray())
                {
                    var field = error.TryGetProperty("field", out var fieldElement) ? fieldElement.GetString() : null;
                    var message = error.TryGetProperty("message", out var messageElement) ? messageElement.GetString() : null;
                    if (!string.IsNullOrWhiteSpace(field) && !string.IsNullOrWhiteSpace(message))
                    {
                        lines.Add($"{field}: {message}");
                    }
                    else if (!string.IsNullOrWhiteSpace(message))
                    {
                        lines.Add(message);
                    }
                }

                if (lines.Count > 0)
                {
                    return string.Join(" | ", lines);
                }
            }
        }
        catch
        {
        }

        return raw;
    }

    private async Task<bool> GetRememberedSessionStateAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("enigmaGame.isUserSessionRemembered");
        }
        catch (JSException)
        {
            return false;
        }
    }

    public class RegisterUser : IValidatableObject
    {
        [Required(ErrorMessage = "Display name is required.")]
        [StringLength(32, MinimumLength = 3, ErrorMessage = "Display name must be 3-32 characters.")]
        [RegularExpression(@"^[A-Za-z0-9][A-Za-z0-9_.-]{2,31}$", ErrorMessage = "Display name can use letters, numbers, ., _, - and must start with a letter/number.")]
        public string DisplayName { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [StringLength(254, ErrorMessage = "Email must be 254 characters or less.")]
        [RegularExpression(@"^[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,63}$", ErrorMessage = "Enter a valid email in the format name@example.com.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [StringLength(128, MinimumLength = 10, ErrorMessage = "Password must be 10-128 characters.")]
        [RegularExpression(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).+$", ErrorMessage = "Password must include uppercase, lowercase, number, and special character.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords must match.")]
        public string ConfirmPassword { get; set; } = "";

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            var email = (Email ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(email))
            {
                yield break;
            }

            if (!System.Text.RegularExpressions.Regex.IsMatch(email, @"^[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,63}$"))
            {
                yield break;
            }

            if (email.Contains("..", StringComparison.Ordinal))
            {
                yield return new ValidationResult("Email cannot contain consecutive dots.", [nameof(Email)]);
                yield break;
            }

            var atIndex = email.IndexOf('@');
            if (atIndex <= 0 || atIndex != email.LastIndexOf('@') || atIndex == email.Length - 1)
            {
                yield return new ValidationResult("Email must include one @ and a valid domain.", [nameof(Email)]);
                yield break;
            }

            var local = email[..atIndex];
            var domain = email[(atIndex + 1)..];
            if (local.StartsWith(".", StringComparison.Ordinal) || local.EndsWith(".", StringComparison.Ordinal))
            {
                yield return new ValidationResult("Email local part cannot start or end with a dot.", [nameof(Email)]);
                yield break;
            }

            var labels = domain.Split('.', StringSplitOptions.RemoveEmptyEntries);
            if (labels.Length < 2)
            {
                yield return new ValidationResult("Email domain must include a top-level domain (for example, .com).", [nameof(Email)]);
                yield break;
            }

            foreach (var label in labels)
            {
                if (label.StartsWith("-", StringComparison.Ordinal) || label.EndsWith("-", StringComparison.Ordinal))
                {
                    yield return new ValidationResult("Email domain labels cannot start or end with a dash.", [nameof(Email)]);
                    yield break;
                }
            }
        }
    }

    public sealed class VerifyCodeForm
    {
        [Required(ErrorMessage = "Verification code is required.")]
        [RegularExpression(@"^\d{6}$", ErrorMessage = "Verification code must be 6 digits.")]
        public string Code { get; set; } = string.Empty;
    }
}
