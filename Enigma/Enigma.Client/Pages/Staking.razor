@page "/staking"
@using System.Globalization
@using Enigma.Client.Models
@inject Enigma.Client.Services.EnigmaApiClient Api
@inject Enigma.Client.Services.UiNotificationService Notifications
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (!Embedded)
{
    <SeoHead Title="Enigma Research | Anomaly Map Analysis"
             Description="Submit recovered maps for anomaly research, containment, and long-form analysis while earning daily MN credits."
             Robots="noindex,follow"
             OpenGraphType="website"
             SchemaType="WebPage" />
}

@if (IsLoading)
{
    <div class="@(Embedded ? "economy-embedded-state" : "content")"><div class="card enigma-game-message"><div class="loader"></div><p>Loading anomaly research console...</p></div></div>
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="@(Embedded ? "economy-embedded-state" : "content")">
        <div class="card enigma-game-message">
            <h1>Research console unavailable</h1>
            <p>@ErrorMessage</p>
            <button class="btn btn-primary" type="button" @onclick="ReloadAsync">Retry</button>
        </div>
    </div>
}
else if (Overview is null)
{
    <div class="@(Embedded ? "economy-embedded-state" : "content")"><div class="card enigma-game-message"><p>Research telemetry is unavailable right now.</p></div></div>
}
else
{
    <div class="@(Embedded ? "staking-shell economy-embedded-shell" : "content staking-shell")" data-tour-id="staking-shell">
        <section class="staking-banner" data-tour-id="staking-banner">
            <div>
                <span class="profile-eyebrow">Anomaly Research Assignment</span>
                <h1>Map Analysis Console</h1>
                <p>Submit recovered maps for containment, then continuous research. Research output generates daily MN and council influence.</p>
            </div>
            <div class="staking-banner-meta">
                @if (!string.IsNullOrWhiteSpace(Overview.NextClaimAt) && !Overview.CanClaimToday)
                {
                    <span class="profile-chip">Next payout @FormatTimestamp(Overview.NextClaimAt)</span>
                }
                <button class="btn btn-secondary" type="button" disabled="@IsLoading" @onclick="ReloadAsync">
                    @(IsLoading ? "Refreshing..." : "Refresh")
                </button>
            </div>
        </section>

        @if (HasError && !string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="alert alert-warning">@StatusMessage</div>
        }

        <section class="staking-kpi-grid">
            <article class="staking-kpi-card">
                <span class="staking-kpi-label">Maps Under Analysis</span>
                <strong class="staking-kpi-value" @key="Overview.StakedMapsCount">@Overview.StakedMapsCount</strong>
            </article>
            <article class="staking-kpi-card">
                <span class="staking-kpi-label">Daily Research Credits</span>
                <strong class="staking-kpi-value" @key="Overview.TotalDailyReward">@Overview.TotalDailyReward.ToString("N0") MN/day</strong>
            </article>
            <article class="staking-kpi-card">
                <span class="staking-kpi-label">Reserve Balance</span>
                <strong class="staking-kpi-value" @key="Session?.MazeNuggets">@(Session?.MazeNuggets.ToString("N0") ?? "0") MN</strong>
            </article>
        </section>

        <section class="staking-forecast-grid">
            <article class="staking-forecast-card">
                <span>Daily Credits</span>
                <strong>@DailyYield.ToString("N0") MN</strong>
            </article>
            <article class="staking-forecast-card">
                <span>Monthly Credits</span>
                <strong>~@EstimatedMonthlyYield.ToString("N0") MN</strong>
            </article>
            <article class="staking-forecast-card">
                <span>Yearly Credits</span>
                <strong>~@EstimatedYearlyYield.ToString("N0") MN</strong>
            </article>
            <article class="staking-forecast-card">
                <span>Research Efficiency</span>
                <strong>@YieldEfficiencyPercent.ToString("0.#")%</strong>
                <em>@YieldEfficiencyLabel</em>
            </article>
        </section>

        <section class="staking-research-grid">
            <article class="panel profile-release-panel staking-research-card">
                <span class="profile-eyebrow">Global Research Objective</span>
                <h2>@(Overview.CollectiveResearch?.Title ?? "Decode Labyrinth Type IV")</h2>
                <p>@(Overview.CollectiveResearch?.Description ?? "Contribute maps to expand Enigma anomaly knowledge.")</p>
                <div class="staking-map-rows">
                    <div><span>Progress</span><strong>@CollectiveKnowledgePercent.ToString("0.##")%</strong></div>
                    <div><span>Contributors</span><strong>@(Overview.CollectiveResearch?.ContributorCount ?? 0)</strong></div>
                    <div><span>Submitted maps</span><strong>@(Overview.CollectiveResearch?.ContributedMaps ?? 0) / @(Overview.CollectiveResearch?.TargetMaps ?? 500)</strong></div>
                </div>
                <div class="economy-progress-bar">
                    <span style="@GetLinearProgressStyle(CollectiveKnowledgePercent)"></span>
                </div>
            </article>
            <article class="panel profile-release-panel staking-research-card">
                <span class="profile-eyebrow">Containment + Influence</span>
                <h2>Research System Status</h2>
                <div class="staking-map-rows">
                    <div><span>Anomaly Stability</span><strong>@AnomalyStabilityPercent.ToString("0.##")% (@AnomalyStabilityStatus)</strong></div>
                    <div><span>Research Influence</span><strong>@($"x{ResearchInfluenceMultiplier:0.00}")</strong></div>
                    <div><span>Stake Component</span><strong>@($"x{ResearchStakeComponent:0.00}")</strong></div>
                </div>
                <div class="economy-progress-bar">
                    <span style="@GetLinearProgressStyle(AnomalyStabilityPercent)"></span>
                </div>
            </article>
        </section>

        <section class="staking-claim-card @(ClaimBurstActive ? "claim-success" : string.Empty)">
            <div class="staking-claim-copy">
                <strong>Daily Research Credit Claim</strong>
                <p>
                    @if (Overview.CanClaimToday)
                    {
                        <span>Claim is ready for @Overview.TotalDailyReward.ToString("N0") MN in recovered research credits.</span>
                    }
                    else if (!string.IsNullOrWhiteSpace(Overview.NextClaimAt))
                    {
                        <span>Your next research payout window is processing now.</span>
                    }
                    else
                    {
                        <span>Submit maps for analysis to unlock daily payouts.</span>
                    }
                </p>
            </div>

            <div class="staking-claim-ring-wrap">
                <div class="staking-claim-ring" style="@GetClaimRingStyle()">
                    <div class="staking-claim-ring-core">
                        <strong>@GetClaimProgressPercent().ToString("0")%</strong>
                        <span>@(Overview.CanClaimToday ? "Ready" : "Progress")</span>
                    </div>
                </div>
                <div class="staking-claim-countdown">
                    <strong>Next Claim</strong>
                    <span>@GetClaimCountdownLabel()</span>
                </div>
            </div>

            <button class="btn btn-primary" type="button" disabled="@(!Overview.CanClaimToday || IsBusy)" @onclick="ClaimDailyAsync">
                @(IsBusy ? "Processing..." : "Claim Daily Credits")
            </button>

            @if (ClaimBurstActive && LastClaimReward > 0)
            {
                <span class="staking-claim-burst">+@LastClaimReward.ToString("N0") MN</span>
            }
        </section>

        @if (Overview.StakedMaps.Count > 0)
        {
            <section class="panel profile-release-panel staking-breakdown-panel">
                <div class="panel-heading">
                    <div>
                        <span class="profile-eyebrow">Analysis Yield Sources</span>
                        <h2>Research Credit Breakdown</h2>
                    </div>
                </div>
                <div class="staking-breakdown-layout">
                    <div class="staking-breakdown-donut" style="@GetYieldDonutStyle()">
                        <div class="staking-breakdown-donut-core">
                            <span>Total Credits</span>
                            <strong>@Overview.TotalDailyReward.ToString("N0") MN</strong>
                        </div>
                    </div>
                    <div class="staking-breakdown-legend">
                        @foreach (var slice in GetYieldSlices())
                        {
                            <div class="staking-breakdown-row">
                                <span class="staking-breakdown-dot" style="@($"background:{slice.Color};")"></span>
                                <span class="staking-breakdown-map">@slice.Label</span>
                                <strong>@slice.Value.ToString("N0") MN (@slice.Share.ToString("0.#")%)</strong>
                            </div>
                        }
                    </div>
                </div>
            </section>
        }

        <div class="staking-grid">
            <section class="staking-column panel profile-release-panel">
                <div class="panel-heading">
                    <div>
                        <span class="profile-eyebrow">Active Analysis</span>
                        <h2>Maps Under Analysis</h2>
                    </div>
                    <span class="section-count">@Overview.StakedMapsCount</span>
                </div>
                @if (Overview.StakedMaps.Count == 0)
                {
                    <div class="empty-state-inline">No maps are currently assigned to research.</div>
                }
                else
                {
                    <div class="staking-map-stack">
                        @foreach (var map in Overview.StakedMaps.OrderBy(static item => item.MapName, StringComparer.OrdinalIgnoreCase))
                        {
                            <article class="staking-map-card">
                                <div class="staking-map-card-head">
                                    <h3>@map.MapName</h3>
                                    <span class="difficulty-badge difficulty-@GetDifficultyClass(map.Difficulty)">@FormatDifficultyLabel(map.Difficulty)</span>
                                </div>
                                <div class="staking-map-rows">
                                    <div><span>Difficulty</span><strong>@FormatDifficultyLabel(map.Difficulty)</strong></div>
                                    <div><span>Size</span><strong>@map.Size x @map.Size</strong></div>
                                    <div><span>Classification</span><strong>@map.AnomalyClassification</strong></div>
                                    <div><span>Containment</span><strong>@GetContainmentLabel(map)</strong></div>
                                    <div><span>Research Phase</span><strong>@GetResearchPhaseLabel(map)</strong></div>
                                    <div><span>Research Depth</span><strong>@GetResearchDepthLabel(map)</strong></div>
                                    <div><span>Data Collected</span><strong>@GetResearchDataPercent(map).ToString("0.##")%</strong></div>
                                    <div><span>Puzzle Structures</span><strong>@map.PuzzleStructuresIdentified</strong></div>
                                    <div><span>Spatial Layers</span><strong>@map.SpatialLayersDetected</strong></div>
                                </div>
                                <p class="staking-ai-note">@map.AnalysisAiMessage</p>
                                <div class="economy-progress-bar">
                                    <span style="@GetLinearProgressStyle(GetResearchDataPercent(map))"></span>
                                </div>
                                <div class="staking-map-footer">
                                    <div>
                                        <span class="staking-yield-label">Daily Credits</span>
                                        <strong class="staking-yield-value">@map.DailyReward.ToString("N0") MN/day</strong>
                                    </div>
                                    <button class="btn btn-secondary"
                                            type="button"
                                            title="@GetStakeLockTooltip(map)"
                                            disabled="@(IsBusy || IsStakeLocked(map))"
                                            @onclick="() => UnstakeMapAsync(map.MapId)">
                                        @(IsStakeLocked(map) ? "Containment Lock" : "Withdraw")
                                    </button>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(GetNextMilestoneLabel(map)))
                                {
                                    <div class="staking-milestone-note">@GetNextMilestoneLabel(map)</div>
                                }
                                @if (map.AnalysisReport is not null)
                                {
                                    <details class="staking-report-card">
                                        <summary>Expedition Analysis Report @map.AnalysisReport.ReportId</summary>
                                        <div class="staking-map-rows">
                                            <div><span>Anomaly Type</span><strong>@map.AnalysisReport.AnomalyType</strong></div>
                                            <div><span>Puzzle Structure</span><strong>@map.AnalysisReport.PuzzleStructure</strong></div>
                                            <div><span>Stability Rating</span><strong>@map.AnalysisReport.StabilityRating%</strong></div>
                                            <div><span>Status</span><strong>@map.AnalysisReport.Status</strong></div>
                                        </div>
                                        <p class="staking-ai-note">@map.AnalysisReport.Conclusion</p>
                                    </details>
                                }
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="staking-column staking-available-column panel profile-release-panel">
                <div class="panel-heading">
                    <div>
                        <span class="profile-eyebrow">Recovered Sectors</span>
                        <h2>Ready for Analysis</h2>
                    </div>
                    <span class="section-count">@Overview.AvailableMapsCount</span>
                </div>
                @if (Overview.AvailableMaps.Count == 0)
                {
                    <div class="staking-empty-state">
                        <div class="staking-empty-header">
                            <span class="staking-empty-icon" aria-hidden="true">ALL ASSIGNED</span>
                            <strong>No maps available for new research assignments.</strong>
                        </div>
                        <p>All owned maps are already in containment or research. Withdraw one after lock expiry, or recover more sectors.</p>
                    </div>
                }
                else
                {
                    <div class="staking-map-stack staking-map-stack-available">
                        @foreach (var map in Overview.AvailableMaps.OrderBy(static item => item.MapName, StringComparer.OrdinalIgnoreCase))
                        {
                            <article class="staking-map-card muted staking-map-card-available">
                                <div class="staking-map-card-head">
                                    <h3>@map.MapName</h3>
                                    <span class="difficulty-badge difficulty-@GetDifficultyClass(map.Difficulty)">@FormatDifficultyLabel(map.Difficulty)</span>
                                </div>
                                <div class="staking-map-rows">
                                    <div><span>Difficulty</span><strong>@FormatDifficultyLabel(map.Difficulty)</strong></div>
                                    <div><span>Size</span><strong>@map.Size x @map.Size</strong></div>
                                    <div><span>Classification</span><strong>@map.AnomalyClassification</strong></div>
                                    <div><span>Containment Lock</span><strong>@Math.Max(0, Overview.StakeLockHours)h</strong></div>
                                </div>
                                <div class="staking-map-footer">
                                    <div>
                                        <span class="staking-yield-label">Projected Credits</span>
                                        <strong class="staking-yield-value">@map.DailyReward.ToString("N0") MN/day</strong>
                                    </div>
                                    <button class="btn btn-primary" type="button" disabled="@IsBusy" @onclick="() => StakeMapAsync(map.MapId)">Submit for Analysis</button>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </div>

        <section class="panel profile-release-panel staking-faq-card">
            <div class="panel-heading">
                <div>
                    <span class="profile-eyebrow">FAQ</span>
                    <h2>Anomaly Research Protocol</h2>
                </div>
            </div>
            <details class="staking-faq-collapsible">
                <summary>Map Analysis Rules</summary>
                <ol class="staking-faq-list">
                    <li>Submitting a map starts the Initial Containment Phase for @Math.Max(0, Overview?.StakeLockHours ?? 48) hours.</li>
                    <li>Containment lock is enforced in both UI and API. Maps cannot be withdrawn during this window.</li>
                    <li>After containment, maps enter Continuous Research and progress through deeper Research Depth levels over time.</li>
                    <li>Base daily credits by difficulty remain: Easy = 5 MN, Medium = 15 MN, Hard = 25 MN.</li>
                    <li>Size multiplier formula: <code>0.7 + (size / 20)</code>, capped at <code>2.0x</code>. Example: 2x2 = 0.8x, 4x4 = 0.9x.</li>
                    <li>Daily reward per map is <code>ceil(base * sizeMultiplier)</code>. Example: Easy 2x2 = <code>ceil(5 * 0.8) = 4 MN/day</code>.</li>
                    <li>Submitted maps cannot be listed, sold, or recycled until they are withdrawn after lock expiry.</li>
                    <li>Withdrawing early (after lock) ends research early and may reduce long-form discovery depth.</li>
                    <li>Longer assignments unlock deeper analysis, stronger reports, and better council influence context.</li>
                </ol>
            </details>
        </section>
    </div>
}

@code {
    [Parameter] public bool Embedded { get; set; }

    private static readonly string[] YieldColors =
    [
        "#5ba8ff",
        "#8f74ff",
        "#54c8a3",
        "#f8ba68",
        "#ff7a9d",
        "#7dd3fc",
        "#b8f47a",
        "#fca5a5",
    ];

    private sealed record YieldSlice(string Label, int Value, double Share, string Color);

    private bool IsLoading { get; set; } = true;
    private bool IsBusy { get; set; }
    private bool HasError { get; set; }
    private bool ClaimBurstActive { get; set; }
    private int LastClaimReward { get; set; }
    private string? ErrorMessage { get; set; }
    private string? StatusMessage { get; set; }
    private LoginUserSummary? Session { get; set; }
    private StakingOverviewData? Overview { get; set; }
    private DateTimeOffset CurrentClientTime { get; set; } = DateTimeOffset.UtcNow;
    private CancellationTokenSource? _clockCancellation;
    private Task? _clockTask;
    private CancellationTokenSource? _claimBurstCancellation;
    private CancellationTokenSource? _refreshCancellation;
    private Task? _refreshTask;
    private bool _loadingOverview;

    private int DailyYield => Math.Max(0, Overview?.TotalDailyReward ?? 0);
    private int EstimatedMonthlyYield => DailyYield * 30;
    private int EstimatedYearlyYield => DailyYield * 365;
    private double CollectiveKnowledgePercent => Math.Clamp(Overview?.CollectiveResearch?.ProgressPercent ?? 0, 0, 100);
    private double AnomalyStabilityPercent => Math.Clamp(Overview?.AnomalyStability?.Percent ?? 0, 0, 100);
    private string AnomalyStabilityStatus => string.IsNullOrWhiteSpace(Overview?.AnomalyStability?.Status) ? "Unknown" : Overview!.AnomalyStability!.Status;
    private double ResearchInfluenceMultiplier => Math.Max(1.0, Overview?.ResearchInfluence?.Multiplier ?? 1.0);
    private double ResearchStakeComponent => Math.Max(1.0, Overview?.ResearchInfluence?.StakeComponent ?? 1.0);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        StartClockLoop();
        StartRefreshLoop();
    }

    private void StartClockLoop()
    {
        if (_clockTask is not null)
        {
            return;
        }

        _clockCancellation = new CancellationTokenSource();
        _clockTask = ClockLoopAsync(_clockCancellation.Token);
    }

    private async Task ClockLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                CurrentClientTime = DateTimeOffset.UtcNow;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(TimeSpan.FromSeconds(1), cancellationToken);
            }
        }
        catch (OperationCanceledException)
        {
            // ignored
        }
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private void StartRefreshLoop()
    {
        if (_refreshTask is not null)
        {
            return;
        }

        _refreshCancellation = new CancellationTokenSource();
        _refreshTask = RefreshLoopAsync(_refreshCancellation.Token);
    }

    private async Task RefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (cancellationToken.IsCancellationRequested || IsBusy)
                {
                    continue;
                }

                await LoadAsync(silent: true);
            }
        }
        catch (OperationCanceledException)
        {
            // ignored
        }
    }

    private async Task LoadAsync(bool silent = false)
    {
        if (_loadingOverview)
        {
            return;
        }

        _loadingOverview = true;
        if (!silent)
        {
            IsLoading = true;
            HasError = false;
            ErrorMessage = null;
            StatusMessage = null;
            await InvokeAsync(StateHasChanged);
        }

        CurrentClientTime = DateTimeOffset.UtcNow;

        try
        {
            var payload = await Api.GetFromJsonAsync<StakingOverviewResponse>("api/auth/staking");
            if (payload is null)
            {
                throw new InvalidOperationException("Unable to load staking overview.");
            }

            Overview = payload.Overview;
            Session = payload.User ?? await Api.GetSessionAsync();
            await SyncClientSessionAsync(payload.User);
            if (!silent)
            {
                HasError = false;
                ErrorMessage = null;
            }
            else
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            if (!silent)
            {
                HasError = true;
                ErrorMessage = ex.Message;
                Notifications.Warning(ErrorMessage);
            }
        }
        finally
        {
            _loadingOverview = false;
            if (!silent)
            {
                IsLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task StakeMapAsync(string mapId)
    {
        await ExecuteActionAsync(
            async () => await Api.PostJsonAsync("api/auth/staking/stake", new { mapId }),
            "Map submitted for anomaly research.");
    }

    private async Task UnstakeMapAsync(string mapId)
    {
        var selectedMap = Overview?.StakedMaps.FirstOrDefault(entry => string.Equals(entry.MapId, mapId, StringComparison.OrdinalIgnoreCase));
        if (selectedMap is not null && IsStakeLocked(selectedMap))
        {
            HasError = true;
            StatusMessage = $"Containment is still active for {GetContainmentLabel(selectedMap)}.";
            Notifications.Warning(StatusMessage);
            return;
        }

        await ExecuteActionAsync(
            async () => await Api.PostJsonAsync("api/auth/staking/unstake", new { mapId }),
            "Map withdrawn from anomaly research.");
    }

    private async Task ClaimDailyAsync()
    {
        await ExecuteActionAsync(
            async () => await Api.PostJsonAsync("api/auth/staking/claim", new { }),
            "Daily research credit payout processed.");
    }

    private async Task ExecuteActionAsync(Func<Task<HttpResponseMessage>> requestFactory, string successMessage)
    {
        if (IsBusy)
        {
            return;
        }

        IsBusy = true;
        HasError = false;
        StatusMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var response = await requestFactory();
            var payload = await Api.ReadJsonAsync<StakingActionResponse>(response);
            if (!response.IsSuccessStatusCode || payload is null)
            {
                throw new InvalidOperationException("Request failed.");
            }

            Overview = payload.Overview ?? Overview;
            Session = payload.User ?? Session;
            await SyncClientSessionAsync(payload.User);
            CurrentClientTime = DateTimeOffset.UtcNow;

            if (payload.RewardGranted && payload.RewardedMn > 0)
            {
                StartClaimBurst(payload.RewardedMn);
                StatusMessage = $"+{payload.RewardedMn:N0} MN claimed from anomaly research.";
                Notifications.Success(StatusMessage);
            }
            else
            {
                StatusMessage = successMessage;
                Notifications.Success(StatusMessage);
            }
        }
        catch (Exception ex)
        {
            HasError = true;
            StatusMessage = ex.Message;
            Notifications.Error(StatusMessage);
        }
        finally
        {
            IsBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StartClaimBurst(int rewardedMn)
    {
        LastClaimReward = Math.Max(0, rewardedMn);
        ClaimBurstActive = LastClaimReward > 0;
        _claimBurstCancellation?.Cancel();
        _claimBurstCancellation?.Dispose();

        if (!ClaimBurstActive)
        {
            return;
        }

        _claimBurstCancellation = new CancellationTokenSource();
        _ = HideClaimBurstAsync(_claimBurstCancellation.Token);
    }

    private async Task HideClaimBurstAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(1300), cancellationToken);
            ClaimBurstActive = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
            // ignored
        }
    }

    private static DateTimeOffset? ParseIsoTimestamp(string? isoUtc)
    {
        if (string.IsNullOrWhiteSpace(isoUtc))
        {
            return null;
        }

        return DateTimeOffset.TryParse(isoUtc, out var parsed)
            ? parsed.ToUniversalTime()
            : null;
    }

    private double GetClaimProgressPercent()
    {
        if (Overview is null)
        {
            return 0;
        }

        if (Overview.CanClaimToday)
        {
            return 100;
        }

        var nextClaim = ParseIsoTimestamp(Overview.NextClaimAt);
        if (nextClaim is null)
        {
            return 0;
        }

        var start = nextClaim.Value - TimeSpan.FromDays(1);
        var progress = (CurrentClientTime.ToUniversalTime() - start).TotalSeconds / TimeSpan.FromDays(1).TotalSeconds;
        return Math.Clamp(progress * 100, 0, 100);
    }

    private string GetClaimRingStyle()
    {
        return $"--claim-progress:{GetClaimProgressPercent().ToString("0.##", CultureInfo.InvariantCulture)};";
    }

    private static string GetLinearProgressStyle(double percent)
    {
        return $"width:{Math.Clamp(percent, 0, 100).ToString("0.##", CultureInfo.InvariantCulture)}%;";
    }

    private string GetClaimCountdownLabel()
    {
        if (Overview?.CanClaimToday == true)
        {
            return "Ready now";
        }

        var nextClaim = ParseIsoTimestamp(Overview?.NextClaimAt);
        if (nextClaim is null)
        {
            return "No active timer";
        }

        var remaining = nextClaim.Value - CurrentClientTime.ToUniversalTime();
        if (remaining <= TimeSpan.Zero)
        {
            return "Any moment now";
        }

        if (remaining.TotalDays >= 1)
        {
            return $"{(int)remaining.TotalDays}d {remaining.Hours}h";
        }

        if (remaining.TotalHours >= 1)
        {
            return $"{(int)remaining.TotalHours}h {remaining.Minutes}m";
        }

        return $"{Math.Max(0, remaining.Minutes)}m {Math.Max(0, remaining.Seconds)}s";
    }

    private bool IsStakeLocked(StakedMapEntry map)
    {
        var lockedUntil = ParseIsoTimestamp(map.LockedUntil);
        return lockedUntil is DateTimeOffset value && value > CurrentClientTime.ToUniversalTime();
    }

    private string GetStakeLockLabel(StakedMapEntry map)
    {
        if (!IsStakeLocked(map))
        {
            return "Ready";
        }

        var lockedUntil = ParseIsoTimestamp(map.LockedUntil);
        if (lockedUntil is not DateTimeOffset value)
        {
            return "Locked";
        }

        var remaining = value - CurrentClientTime.ToUniversalTime();
        if (remaining <= TimeSpan.Zero)
        {
            return "Ready";
        }

        if (remaining.TotalDays >= 1)
        {
            return $"{(int)remaining.TotalDays}d {remaining.Hours}h";
        }

        if (remaining.TotalHours >= 1)
        {
            return $"{(int)remaining.TotalHours}h {remaining.Minutes}m";
        }

        return $"{Math.Max(0, remaining.Minutes)}m {Math.Max(0, remaining.Seconds)}s";
    }

    private string GetStakeLockTooltip(StakedMapEntry map)
    {
        if (!IsStakeLocked(map))
        {
            return "This map can be withdrawn from research.";
        }

        return $"Containment unlocks in {GetStakeLockLabel(map)}.";
    }

    private double GetResearchDataPercent(StakedMapEntry map)
    {
        if (Overview is null || string.IsNullOrWhiteSpace(map.AnalysisStartedAt))
        {
            return Math.Clamp(map.ResearchDataPercent, 0, 100);
        }

        var start = ParseIsoTimestamp(map.AnalysisStartedAt);
        if (start is null)
        {
            return Math.Clamp(map.ResearchDataPercent, 0, 100);
        }

        var elapsed = (CurrentClientTime.ToUniversalTime() - start.Value).TotalSeconds;
        if (elapsed <= 0)
        {
            return 0;
        }

        const double fullDepthSeconds = 14 * 24 * 3600;
        return Math.Clamp((elapsed / fullDepthSeconds) * 100.0, 0, 100);
    }

    private string GetContainmentLabel(StakedMapEntry map)
    {
        if (!map.ContainmentActive)
        {
            return "Stabilized";
        }

        var remaining = TimeSpan.FromSeconds(Math.Max(0, map.ContainmentRemainingSeconds));
        if (remaining.TotalDays >= 1)
        {
            return $"{(int)remaining.TotalDays}d {remaining.Hours}h remaining";
        }

        if (remaining.TotalHours >= 1)
        {
            return $"{(int)remaining.TotalHours}h {remaining.Minutes}m remaining";
        }

        return $"{Math.Max(0, remaining.Minutes)}m {Math.Max(0, remaining.Seconds)}s remaining";
    }

    private string GetResearchPhaseLabel(StakedMapEntry map)
    {
        if (map.ContainmentActive)
        {
            return "Initial Containment";
        }

        return string.IsNullOrWhiteSpace(map.AnalysisPhaseLabel) ? "Continuous Research" : map.AnalysisPhaseLabel;
    }

    private string GetResearchDepthLabel(StakedMapEntry map)
    {
        var depthLabel = string.IsNullOrWhiteSpace(map.ResearchDepthLabel) ? "Containment Pending" : map.ResearchDepthLabel;
        return map.ResearchDepthLevel > 0 ? $"Level {map.ResearchDepthLevel}: {depthLabel}" : depthLabel;
    }

    private string GetNextMilestoneLabel(StakedMapEntry map)
    {
        if (map.AnalysisUnlocks is null || map.AnalysisUnlocks.Count == 0)
        {
            return string.Empty;
        }

        var next = map.AnalysisUnlocks
            .Where(static unlock => !unlock.Unlocked)
            .OrderBy(static unlock => unlock.RequiredHours)
            .FirstOrDefault();

        if (next is null)
        {
            return "All research milestones unlocked.";
        }

        return $"Next milestone: {next.Label} at {next.RequiredHours:0.##}h";
    }

    private IReadOnlyList<YieldSlice> GetYieldSlices()
    {
        if (Overview is null || Overview.StakedMaps.Count == 0)
        {
            return [];
        }

        var orderedMaps = Overview.StakedMaps
            .Where(static map => map.DailyReward > 0)
            .OrderByDescending(static map => map.DailyReward)
            .ThenBy(static map => map.MapName, StringComparer.OrdinalIgnoreCase)
            .ToList();
        if (orderedMaps.Count == 0)
        {
            return [];
        }

        var totalReward = orderedMaps.Sum(static map => map.DailyReward);
        if (totalReward <= 0)
        {
            return [];
        }

        var slices = new List<YieldSlice>(orderedMaps.Count);
        for (var index = 0; index < orderedMaps.Count; index += 1)
        {
            var map = orderedMaps[index];
            var share = (map.DailyReward * 100.0) / totalReward;
            slices.Add(new YieldSlice(map.MapName, map.DailyReward, share, YieldColors[index % YieldColors.Length]));
        }

        return slices;
    }

    private string GetYieldDonutStyle()
    {
        var slices = GetYieldSlices();
        if (slices.Count == 0)
        {
            return string.Empty;
        }

        var segments = new List<string>(slices.Count + 1);
        var cursor = 0.0;
        foreach (var slice in slices)
        {
            var end = Math.Min(100, cursor + slice.Share);
            segments.Add(
                $"{slice.Color} {cursor.ToString("0.##", CultureInfo.InvariantCulture)}% {end.ToString("0.##", CultureInfo.InvariantCulture)}%"
            );
            cursor = end;
        }

        if (cursor < 100)
        {
            segments.Add($"rgba(74, 88, 117, 0.72) {cursor.ToString("0.##", CultureInfo.InvariantCulture)}% 100%");
        }

        return $"--yield-breakdown: conic-gradient({string.Join(", ", segments)});";
    }

    private double YieldEfficiencyPercent
    {
        get
        {
            if (Overview is null || Overview.StakedMaps.Count == 0)
            {
                return 0;
            }

            var count = Overview.StakedMaps.Count;
            var countFactor = Math.Clamp(count / 10.0, 0, 1);

            var scoreTotal = 0.0;
            foreach (var map in Overview.StakedMaps)
            {
                var difficultyScore = Math.Clamp(map.BaseReward / 25.0, 0, 1);
                var sizeScore = Math.Clamp(map.SizeMultiplier / 2.0, 0, 1);
                scoreTotal += (difficultyScore * 0.6) + (sizeScore * 0.4);
            }

            var qualityAverage = scoreTotal / count;
            var efficiency = ((qualityAverage * 0.8) + (countFactor * 0.2)) * 100;
            return Math.Round(Math.Clamp(efficiency, 0, 100), 1);
        }
    }

    private string YieldEfficiencyLabel =>
        YieldEfficiencyPercent switch
        {
            >= 85 => "Elite",
            >= 70 => "Strong",
            >= 50 => "Balanced",
            _ => "Needs tuning",
        };

    private async Task SyncClientSessionAsync(LoginUserSummary? session)
    {
        if (session is null)
        {
            return;
        }

        await JS.InvokeVoidAsync("enigmaGame.refreshUserSession", session);
        await JS.InvokeVoidAsync("enigmaGame.setPlayerIdentity", new Enigma.Client.Models.Gameplay.PlayerIdentity { Username = session.Username }, false);
    }

    private static string FormatTimestamp(string? isoUtc)
    {
        if (string.IsNullOrWhiteSpace(isoUtc))
        {
            return "Unknown";
        }

        return DateTimeOffset.TryParse(isoUtc, out var parsed)
            ? parsed.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
            : isoUtc;
    }

    private static string GetDifficultyClass(string difficulty)
    {
        return difficulty?.Trim().ToLowerInvariant() switch
        {
            "easy" => "easy",
            "medium" => "medium",
            "hard" => "hard",
            "elite" => "elite",
            _ => "default",
        };
    }

    private static string FormatDifficultyLabel(string difficulty)
    {
        return difficulty?.Trim().ToLowerInvariant() switch
        {
            "easy" => "Easy",
            "medium" => "Medium",
            "hard" => "Hard",
            "elite" => "Elite",
            _ => "Unknown",
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (_clockCancellation is not null)
        {
            try
            {
                await _clockCancellation.CancelAsync();
            }
            catch
            {
                // ignored
            }

            if (_clockTask is not null)
            {
                try
                {
                    await _clockTask;
                }
                catch (OperationCanceledException)
                {
                    // ignored
                }
            }

            _clockCancellation.Dispose();
            _clockCancellation = null;
        }

        _claimBurstCancellation?.Cancel();
        _claimBurstCancellation?.Dispose();
        _claimBurstCancellation = null;

        if (_refreshCancellation is not null)
        {
            try
            {
                await _refreshCancellation.CancelAsync();
            }
            catch
            {
                // ignored
            }

            if (_refreshTask is not null)
            {
                try
                {
                    await _refreshTask;
                }
                catch (OperationCanceledException)
                {
                    // ignored
                }
            }

            _refreshCancellation.Dispose();
            _refreshCancellation = null;
        }
    }
}
